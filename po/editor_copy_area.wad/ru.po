#: addons/editor_copy_area.wad/addon:2 input:9 standard
msgid "Editor: Copy Area"
msgstr "Редактор: Копирование области"

#: addons/editor_copy_area.wad/addon:3 input:6 standard
msgid ""
"A plugin for the editor to copy the contents of a map region to another "
"region."
msgstr ""
"Плагин для редактора, позволяющий копировать содержимое одного из участков "
"карты в другое место."

#: addons/editor_copy_area.wad/callback.lua:62 input:62 standard
msgid "Overlap"
msgstr "Перекрытие"

#: addons/editor_copy_area.wad/callback.lua:62 input:62 standard
msgid "The two rectangles must not overlap."
msgstr "Два прямоугольника не должны перекрываться."

#: addons/editor_copy_area.wad/init.lua:8
#: addons/editor_copy_area.wad/show_window.lua:14 input:8 input:14 standard
