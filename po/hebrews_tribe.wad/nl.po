#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:634 input:627 input:634
#: standard
msgid "The remains of a destroyed building."
msgstr "De overblijfselen van een verwoest gebouw."

#. TRANSLATORS: Helptext for a Hebrew immovable: Wheat field
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:641 input:641 standard
msgid "This field has just been planted."
msgstr "Dit veld is net aangeplant."

#. TRANSLATORS: Helptext for a Hebrew immovable: Wheat field
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:648
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:655 input:648 input:655
#: standard
msgid "This field is growing."
msgstr "Dit veld groeit."

#. TRANSLATORS: Helptext for a Hebrew immovable: Wheat field
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:662 input:662 standard
msgid "This field is ready for harvesting."
msgstr "Dit veld is klaar om geoogst te worden."

#. TRANSLATORS: Helptext for a Hebrew immovable: Wheat field
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:669 input:669 standard
msgid "This field has been harvested."
msgstr "Dit veld is geoogst."

#. TRANSLATORS: Helptext for a Hebrew resource indicator: No resources
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:676 input:676 standard
msgid "There are no resources in the ground here."
msgstr "Er zitten hier geen grondstoffen in de grond."

#. TRANSLATORS: Helptext for a Hebrew resource indicator: Copper, part 1
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:684
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:717 input:684 input:717
#: standard
msgid "Copper veins contain copper ore that can be dug up by copper mines."
msgstr "Koperaders bevatten kopererts dat in kopermijnen kan worden gewonnen."

#. TRANSLATORS: Helptext for a Hebrew resource indicator: Copper, part 2
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:686 input:686 standard
msgid "There is only a little bit of copper here."
msgstr "Er is hier maar een klein beetje koper."

#. TRANSLATORS: Helptext for a Hebrew resource indicator: Gold, part 1
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:695
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:728 input:695 input:728
#: standard
msgid "Gold veins contain gold ore that can be dug up by gold mines."
msgstr "Goudaders bevatten gouderts dat kan worden opgegraven in goudmijnen."

#. TRANSLATORS: Helptext for a Hebrew resource indicator: Gold, part 2
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:697 input:697 standard
msgid "There is only a little bit of gold here."
msgstr "Er is hier maar een klein beetje goud."

#. TRANSLATORS: Helptext for a Hebrew resource indicator: Stones, part 1
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:706
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:739 input:706 input:739
#: standard
msgid ""
"Granite is a basic building material and can be dug up by a granite mine."
msgstr ""
"Graniet is een basisbouwmateriaal en kan worden gewonnen in een granietmijn."

#. TRANSLATORS: Helptext for a Hebrew resource indicator: Stones, part 2
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:708 input:708 standard
msgid "There is only a little bit of granite here."
msgstr "Er is hier maar een klein beetje graniet."

#. TRANSLATORS: Helptext for a Hebrew resource indicator: Copper, part 2
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:719 input:719 standard
msgid "There is a lot of copper here."
msgstr "Er is hier veel koper."

#. TRANSLATORS: Helptext for a Hebrew resource indicator: Gold, part 2
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:730 input:730 standard
msgid "There is a lot of gold here."
msgstr "Er is hier veel goud."

#. TRANSLATORS: Helptext for a Hebrew resource indicator: Stones, part 2
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:741 input:741 standard
msgid "There is a lot of granite here."
msgstr "Er is hier veel graniet."

#. TRANSLATORS: Helptext for a Hebrew resource indicator: Water
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:749 input:749 standard
msgid "There is water in the ground here that can be pulled up by a well."
msgstr ""
"Er zit hier water in de grond dat kan worden opgepompt met een waterput."

#. TRANSLATORS: Helptext for a Hebrew immovable: Ship Under Construction
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:756 input:756 standard
msgctxt "hebrews_immovable"
msgid "A ship is being constructed at this site."
msgstr "Op deze plek wordt een schip gebouwd."

#. TRANSLATORS: Helptext for an Amazon immovable usable by the Hebrews: Dead Tree
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:764 input:764 standard
msgid "The remains of an old tree."
msgstr "De resten van een oude boom."

