#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1414
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1427 input:1414 input:1427
#: standard
msgctxt "hebrews_building"
msgid ""
"If you're low on soldiers to occupy new military sites, use the downward "
"arrow button to decrease the capacity. You can also click on a soldier to "
"send him away."
msgstr ""
"Als je te weinig soldaten hebt om nieuwe militaire locaties te bezetten, "
"gebruik je de pijltjestoets omlaag om de capaciteit te verlagen. Je kunt ook "
"op een soldaat klikken om hem weg te sturen."

#. TRANSLATORS: Lore helptext for a Hebrew military site: Massada
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1421 input:1421 standard
msgctxt "hebrews_building"
msgid "'Massada shall not fall again!'"
msgstr "'Massada zal niet opnieuw vallen!'"

#. TRANSLATORS: Lore author helptext for a Hebrew military site: Massada
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1423 input:1423 standard
msgctxt "hebrews_building"
msgid "Ancient Hebrew oath"
msgstr "Oude Hebreeuwse eed"

#. TRANSLATORS: Lore helptext for a Hebrew production site: Shipyard
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1436 input:1436 standard
msgctxt "hebrews_building"
msgid ""
"'For King Solomon had a fleet of ships of Tarshish at sea with the fleet of "
"Hiram.'"
msgstr ""
"'Want koning Salomo had een vloot van schepen uit Tarsis op zee, samen met "
"de vloot van Hiram.'"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Shipyard
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1440 input:1440 standard
msgctxt "hebrews_building"
msgid "Constructs ships for overseas exploration and trade."
msgstr "Bouwt schepen voor overzeese verkenning en handel."

#. TRANSLATORS: Lore helptext for a Hebrew building: Construction Site
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1449 input:1449 standard
msgctxt "building"
msgid "'Don't swear at the builder who is short of building materials.'"
msgstr "'Scheld niet op de bouwer die een tekort aan bouwmaterialen heeft.'"

#. TRANSLATORS: Lore author helptext for a Hebrew building: Construction Site
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1451 input:1451 standard
msgctxt "building"
msgid "Proverb widely used for impossible tasks of any kind"
msgstr ""
"Spreekwoord veel gebruikt voor onmogelijke taken van welke aard dan ook"

#. TRANSLATORS: Purpose helptext for a Hebrew building: Construction Site
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1453 input:1453 standard
msgctxt "building"
msgid "A new building is being built at this construction site."
msgstr "Op deze bouwplaats wordt een nieuw gebouw neergezet."

#. TRANSLATORS: Lore helptext for a Hebrew building: Dismantle Site
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1460 input:1460 standard
msgctxt "building"
msgid "'New paths will appear when you are willing to tear down the old.'"
msgstr ""
"'Nieuwe paden zullen verschijnen als je bereid bent de oude af te breken.'"

#. TRANSLATORS: Lore author helptext for a Hebrew building: Dismantle Site
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1462 input:1462 standard
msgctxt "building"
msgid "Proverb"
msgstr "Spreekwoord"

#. TRANSLATORS: Purpose helptext for a Hebrew building: Dismantle Site
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1464 input:1464 standard
msgctxt "building"
msgid ""
"A building is being dismantled at this dismantle site, returning some of the "
"resources that were used during this building's construction to your tribe's "
"stores."
msgstr ""
"Er wordt een gebouw ontmanteld op deze ontmantelingslocatie, waardoor een "
"deel van de grondstoffen die gebruikt zijn tijdens de bouw van dit gebouw "
"terugkomt in de opslagplaatsen van je stam."

