#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1131
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1245 input:1060 input:1131
#: input:1245 standard
msgctxt "hebrews_building"
msgid "Book of Proverbs"
msgstr "Boek der Spreuken"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Spinning Mill
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1062 input:1062 standard
msgctxt "hebrews_building"
msgid "Spins wool into yarn."
msgstr "Spint wol tot garen."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Zizijot Maker's Hut
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1069 input:1069 standard
msgctxt "hebrews_building"
msgid ""
"'They shall make fringes on the corners of their garments throughout their "
"generations.'"
msgstr ""
"'Zij zullen aan de hoeken van hun kledingstukken franjes maken, van "
"generatie op generatie.'"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Zizijot Maker's Hut
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1073 input:1073 standard
msgctxt "hebrews_building"
msgid "Produces zizit from yarn."
msgstr "Produceert zizit van garen."

#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1079 input:1079 standard
msgctxt "hebrews_building"
msgid ""
"You need to connect this flag to a scout's hut before you can send a scout "
"here."
msgstr ""
"Je moet deze vlag aan een scoutshut bevestigen voordat je hier een scout "
"naartoe kunt sturen."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Scout's Hut
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1081 input:1081 standard
msgctxt "hebrews_building"
msgid ""
"'Send men to spy out the land of Canaan, which I am giving to the people of "
"Israel.'"
msgstr ""
"'Stuur mannen om het land Kanaän te verkennen, dat ik aan het volk van "
"Israël geef.'"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Scout's Hut
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1085 input:1085 standard
msgctxt "building"
msgid "Explores unknown territory."
msgstr "Verkent onbekend terrein."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Mill
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1094 input:1094 standard
msgctxt "hebrews_building"
msgid "'Two women will be grinding at the mill.'"
msgstr "'Twee vrouwen zullen bij de molen malen.'"

#. TRANSLATORS: Lore author helptext for a Hebrew production site: Mill
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1096 input:1096 standard
msgctxt "hebrews_building"
msgid "Gospel of Matthew"
msgstr "Evangelie volgens Matteüs"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Mill
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1098 input:1098 standard
msgctxt "hebrews_building"
msgid "Grinds wheat grains into flour and presses olives into olive oil."
msgstr "Maalt tarwekorrels tot meel en perst olijven tot olijfolie."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Bakery
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1105 input:1105 standard
msgctxt "hebrews_building"
msgid "'Give us this day our daily bread.'"
msgstr "'Geef ons heden ons dagelijks brood.'"

#. TRANSLATORS: Lore author helptext for a Hebrew production site: Bakery
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1107 input:1107 standard
msgctxt "hebrews_building"
msgid "Traditional prayer"
msgstr "Traditioneel gebed"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Bakery
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1109 input:1109 standard
msgctxt "hebrews_building"
msgid "Bakes bread from flour and water for soldiers and miners."
msgstr "Bakt brood van bloem en water voor soldaten en mijnwerkers."

#. TRANSLATORS: Performance helptext for a Hebrew production site: Bakery
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1111 input:1111 standard
#, lua-format
msgctxt "hebrews_building"
msgid ""
"If all needed wares are delivered in time, this building can produce a bread "
"in %s on average."
msgstr ""
"Als alle benodigde goederen op tijd worden geleverd, kan dit gebouw "
"gemiddeld %s brood produceren."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Butchery
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1118 input:1118 standard
msgctxt "hebrews_building"
msgid "'Every moving thing that lives shall be food for you.'"
msgstr "'Alles wat beweegt en leeft, zal jullie tot voedsel dienen.'"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Butchery
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1122 input:1122 standard
msgctxt "hebrews_building"
msgid "Slaughters sheep to produce meat, wool and fur."
msgstr "Slacht schapen voor de productie van vlees, wol en vacht."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Weaving Mill
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1129 input:1129 standard
msgctxt "hebrews_building"
msgid "'She seeks wool and flax, and works with willing hands.'"
msgstr "'Ze zoekt wol en vlas en werkt met bereidwillige handen.'"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Weaving Mill
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1133 input:1133 standard
msgctxt "hebrews_building"
msgid "Weaves yarn into cloth."
msgstr "Weeft garen tot stof."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Winery
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1140 input:1140 standard
msgctxt "hebrews_building"
msgid "'Wine gladdens the heart of man.'"
msgstr "'Wijn verblijdt het hart van de mens.'"

#. TRANSLATORS: Lore author helptext for a Hebrew production site: Winery
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1142 input:1142 standard
msgctxt "hebrews_building"
msgid "Psalm 104"
msgstr "Psalm 104"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Winery
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1144 input:1144 standard
msgctxt "hebrews_building"
msgid "Produces wine from grapes and water."
msgstr "Produceert wijn van druiven en water."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Dressmakery
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1151 input:1151 standard
msgctxt "hebrews_building"
msgid "'And they sewed fig leaves together and made themselves loincloths.'"
msgstr ""
"'En zij naaiden vijgenbladeren aan elkaar en maakten zich lendendoeken.'"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Dressmakery
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1155 input:1155 standard
msgctxt "hebrews_building"
msgid ""
"Produces tunics, tallit katan and tallitot from cloth and gold leaf for "
"soldiers."
msgstr ""
"Produceert tunieken, tallit katan en tallitot van stof en bladgoud voor "
"soldaten."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Clay Furnace
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1162 input:1162 standard
msgctxt "hebrews_building"
msgid ""
"'As silver is melted in the midst of the furnace, so shall ye be melted in "
"the midst thereof.'"
msgstr ""
"'Zoals zilver in het midden van de smeltoven wordt gesmolten, zo zult gij in "
"het midden daarvan worden gesmolten.'"

#. TRANSLATORS: Lore author helptext for a Hebrew production site: Clay Furnace
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1164 input:1164 standard
msgctxt "hebrews_building"
msgid "Book of Ezekiel"
msgstr "Boek Ezechiël"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Clay Furnace
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1166 input:1166 standard
msgctxt "hebrews_building"
msgid "Smelts copper ore into copper using branches as fuel."
msgstr "Smelt kopererts tot koper met takken als brandstof."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Gold Beater's Workshop
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1173 input:1173 standard
msgctxt "hebrews_building"
msgid "'And they did beat the gold into thin plates, and cut it into wires.'"
msgstr "'En zij sloegen het goud tot dunne plaatjes en sneden het in draden.'"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Gold Beater's Workshop
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1177 input:1177 standard
msgctxt "hebrews_building"
msgid "Beats gold ore into gold leaf and crafts sacred menorahs."
msgstr "Slaat gouderts tot bladgoud en vervaardigt heilige menorahs."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Workshop
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1184 input:1184 standard
msgctxt "hebrews_building"
msgid "'The craftsman stretches out his arm, he shapes it with hammers.'"
msgstr "'De ambachtsman strekt zijn arm uit en vormt deze met hamers.'"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Workshop
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1188 input:1188 standard
msgctxt "hebrews_building"
msgid ""
"Crafts basic tools such as picks, hammers and fishing rods from branches and "
"granite."
msgstr ""
"Maakt basisgereedschap zoals pikhouwelen, hamers en hengels van takken en "
"graniet."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Sofer's Workshop
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1195 input:1195 standard
msgctxt "hebrews_building"
msgid ""
"'And thou shalt write them upon the door-posts of thy house and upon thy "
"gates.'"
msgstr ""
"'En gij zult ze schrijven op de deurposten van uw huis en op uw poorten.'"

