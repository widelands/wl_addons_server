msgstr "Deze wijnstok is klaar om geoogst te worden."

#. TRANSLATORS: Helptext for a Hebrew immovable: Olive Tree
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:827
msgid "This olive tree has just been planted."
msgstr "Deze olijfboom is net geplant."

#. TRANSLATORS: Helptext for a Hebrew immovable: Olive Tree
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:834
