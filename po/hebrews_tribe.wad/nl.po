msgstr "Deze olijfboom is klaar om geoogst te worden."

#. TRANSLATORS: Helptext for a Hebrew immovable: Dry Pond
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:848
msgid ""
"A shallow depression left by clay digging. It will fill in naturally over "
"time."
msgstr ""
"Een ondiepe kuil die is ontstaan door het graven van klei. Deze zal na "
"verloop van tijd vanzelf weer opvullen."

#. TRANSLATORS: Lore helptext for a Hebrew warehouse: Headquarters
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:916
msgctxt "hebrews_building"
msgid "'The Tabernacle was the dwelling place of the Lord among His people.'"
msgstr "'De tabernakel was de woonplaats van de Heer onder Zijn volk.'"

#. TRANSLATORS: Lore author helptext for a Hebrew warehouse: Headquarters
#. TRANSLATORS: Lore author helptext for a Hebrew production site: Gold Beater's Workshop
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:918
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1175
msgctxt "hebrews_building"
msgid "Book of Exodus"
msgstr "Boek Exodus"

#. TRANSLATORS: Purpose helptext for a Hebrew warehouse: Headquarters
#. TRANSLATORS: Purpose helptext for a Hebrew warehouse: Headquarters Tent
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:920
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:929
msgctxt "hebrews_building"
msgid "Accommodation for your people. Also stores your wares and tools."
msgstr ""
"Verblijfplaats voor uw mensen. Ook geschikt voor het opslaan van uw goederen "
"en gereedschap."

#. TRANSLATORS: Note helptext for a Hebrew warehouse: Headquarters
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:922
msgctxt "hebrews_building"
msgid "The headquarters is your main building."
msgstr "Het hoofdkantoor is uw hoofdgebouw."

#. TRANSLATORS: Note helptext for a Hebrew warehouse: Headquarters Tent
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:931
msgctxt "hebrews_building"
msgid "The headquarters tent is your main building."
msgstr "De hoofdkwartiertent is je hoofdgebouw."

#. TRANSLATORS: Lore helptext for a Hebrew warehouse: Warehouse
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:938
msgctxt "hebrews_building"
msgid ""
"'Store your grain in times of plenty, for lean years will surely follow.'"
msgstr ""
"'Sla je graan op in tijden van overvloed, want er zullen zeker magere jaren "
"volgen.'"

#. TRANSLATORS: Lore author helptext for a Hebrew warehouse: Warehouse
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:940
msgctxt "hebrews_building"
msgid "Ancient Hebrew proverb"
msgstr "Oud Hebreeuws spreekwoord"

#. TRANSLATORS: Purpose helptext for a Hebrew warehouse: Warehouse
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:942
msgctxt "hebrews_building"
msgid ""
"Your workers and soldiers will find shelter here. Also stores your wares and "
"tools."
msgstr ""
"Je arbeiders en soldaten vinden hier onderdak. Je kunt er ook je goederen en "
"gereedschap opslaan."

#. TRANSLATORS: Lore helptext for a Hebrew warehouse: Port
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:949
msgctxt "hebrews_building"
msgid "'King Solomon built a fleet of ships at Ezion-Geber.'"
msgstr "Koning Salomo bouwde een vloot schepen in Ezion-Geber.'"

#. TRANSLATORS: Lore author helptext for a Hebrew warehouse: Port
#. TRANSLATORS: Lore author helptext for a Hebrew production site: Quarry
