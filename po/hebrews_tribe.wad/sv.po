#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:780
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:787
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:850
