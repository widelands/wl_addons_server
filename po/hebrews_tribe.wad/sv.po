#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:998
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1066
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1078
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1405
msgctxt "hebrews_building"
msgid "Book of Numbers"
msgstr "Fjärde Moseboken"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Well
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1000
msgctxt "hebrews_building"
msgid "Draws water out of the deep."
msgstr "Hämtar vatten från djupet."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Quarry
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1007
msgctxt "hebrews_building"
msgid "'Solomon's builders and Hiram's builders cut the stone.'"
msgstr "\"Salomos byggare och Hirams byggare högg ut stenarna.\""

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Quarry
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1011
msgctxt "hebrews_building"
msgid "Cuts raw pieces of granite out of rocks in the vicinity."
msgstr "Skär ut råa granitbitar ur stenar i närheten."

#. TRANSLATORS: Note helptext for a Hebrew production site: Quarry
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1013
msgctxt "hebrews_building"
msgid "The quarry needs rocks to cut within the work area."
msgstr "Stenbrottet behöver stenar att bryta inom arbetsområdet."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Clay Pit
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1020
msgctxt "hebrews_building"
msgid "'Like clay in the hand of the potter, so are you in My hand.'"
msgstr "\"Som lera i krukmakarens hand, så är du i Min hand.\""

#. TRANSLATORS: Lore author helptext for a Hebrew production site: Clay Pit
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1022
msgctxt "hebrews_building"
msgid "Book of Jeremiah"
msgstr "Jeremias bok"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Clay Pit
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1024
msgctxt "hebrews_building"
msgid "Digs clay out of the ground."
msgstr "Gräver lera ur marken."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Brick Kiln
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1031
msgctxt "hebrews_building"
msgid "'Come, let us make bricks and burn them thoroughly.'"
msgstr "\"Kom, låt oss tillverka tegelstenar och bränna dem ordentligt.\""

#. TRANSLATORS: Lore author helptext for a Hebrew production site: Brick Kiln
#. TRANSLATORS: Lore author helptext for a Hebrew production site: Butchery
#. TRANSLATORS: Lore author helptext for a Hebrew production site: Dressmakery
#. TRANSLATORS: Lore author helptext for a Hebrew production site: Donkey Farm
#. TRANSLATORS: Lore author helptext for a Hebrew production site: Gold Mine
#. TRANSLATORS: Lore author helptext for a Hebrew production site: Vineyard
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1033
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1115
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1148
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1214
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1319
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1371
msgctxt "hebrews_building"
msgid "Book of Genesis"
msgstr "Första Moseboken"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Brick Kiln
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1035
msgctxt "hebrews_building"
msgid ""
"Burns clay and branches into bricks, which are used as granite for "
"construction."
msgstr ""
"Bränner lera och grenar till tegelstenar, som används som granit för "
"byggnation."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Clearing Tent
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1042
msgctxt "hebrews_building"
msgid ""
"'Clear the way for the people; build up the highway, remove the stones.'"
msgstr "\"Gör plats för folket; bygg upp landsvägen, ta bort stenarna.\""

#. TRANSLATORS: Lore author helptext for a Hebrew production site: Clearing Tent
#. TRANSLATORS: Lore author helptext for a Hebrew production site: Workshop
#. TRANSLATORS: Lore author helptext for a Hebrew production site: Weaponsmithy
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1044
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1181
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1203
msgctxt "hebrews_building"
msgid "Book of Isaiah"
msgstr "Jesajas bok"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Clearing Tent
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1046
msgctxt "hebrews_building"
msgid ""
"Clears trees to obtain logs. This allows the Hebrews to remove trees that "
"block construction."
msgstr ""
"Röjer träd för att få virke. Detta gör det möjligt för hebréerna att ta bort "
"träd som hindrar byggandet."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Spinning Mill
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1053
msgctxt "hebrews_building"
msgid "'She puts her hands to the distaff, and her hands hold the spindle.'"
msgstr "\"Hon lägger händerna på spinnrocken och håller spindeln i händerna.\""

#. TRANSLATORS: Lore author helptext for a Hebrew production site: Spinning Mill
#. TRANSLATORS: Lore author helptext for a Hebrew production site: Weaving Mill
#. TRANSLATORS: Lore author helptext for a Hebrew production site: Farm
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1055
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1126
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1240
msgctxt "hebrews_building"
msgid "Book of Proverbs"
msgstr "Ordspråksboken"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Spinning Mill
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1057
msgctxt "hebrews_building"
msgid "Spins wool into yarn."
msgstr "Spinner ull till garn."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Zizijot Maker's Hut
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1064
msgctxt "hebrews_building"
msgid ""
"'They shall make fringes on the corners of their garments throughout their "
"generations.'"
msgstr ""
"\"De skall göra fransar på hörnen av sina kläder i alla generationer.\""

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Zizijot Maker's Hut
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1068
msgctxt "hebrews_building"
msgid "Produces zizit from yarn."
msgstr "Tillverkar zizit av garn."

#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1074
msgctxt "hebrews_building"
msgid ""
"You need to connect this flag to a scout's hut before you can send a scout "
"here."
msgstr ""
"Du måste ansluta denna flagga till en scoutstuga innan du kan skicka en "
"scout hit."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Scout's Hut
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1076
msgctxt "hebrews_building"
msgid ""
"'Send men to spy out the land of Canaan, which I am giving to the people of "
"Israel.'"
msgstr ""
"\"Sänd män för att spionera på Kanaans land, som jag ger till Israels folk.\""

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Scout's Hut
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1080
msgctxt "building"
msgid "Explores unknown territory."
msgstr "Utforskar okänt territorium."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Mill
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1089
msgctxt "hebrews_building"
msgid "'Two women will be grinding at the mill.'"
msgstr "\"Två kvinnor kommer att mala på kvarnen.\""

#. TRANSLATORS: Lore author helptext for a Hebrew production site: Mill
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1091
msgctxt "hebrews_building"
msgid "Gospel of Matthew"
msgstr "Matteusevangeliet"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Mill
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1093
msgctxt "hebrews_building"
msgid "Grinds wheat grains into flour and presses olives into olive oil."
msgstr "Mal vetekorn till mjöl och pressar oliver till olivolja."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Bakery
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1100
msgctxt "hebrews_building"
msgid "'Give us this day our daily bread.'"
msgstr "\"Ge oss i dag vårt dagliga bröd.\""

#. TRANSLATORS: Lore author helptext for a Hebrew production site: Bakery
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1102
msgctxt "hebrews_building"
msgid "Traditional prayer"
msgstr "Traditionell bön"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Bakery
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1104
msgctxt "hebrews_building"
msgid "Bakes bread from flour and water for soldiers and miners."
msgstr "Bakar bröd av mjöl och vatten till soldater och gruvarbetare."

#. TRANSLATORS: Performance helptext for a Hebrew production site: Bakery
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1106
#, lua-format
msgctxt "hebrews_building"
msgid ""
"If all needed wares are delivered in time, this building can produce a bread "
"in %s on average."
msgstr ""
"Om alla nödvändiga varor levereras i tid kan denna byggnad producera ett "
"bröd i %s i genomsnitt."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Butchery
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1113
msgctxt "hebrews_building"
msgid "'Every moving thing that lives shall be food for you.'"
msgstr "\"Allt som rör sig och lever skall vara föda för er.\""

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Butchery
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1117
msgctxt "hebrews_building"
msgid "Slaughters sheep to produce meat, wool and fur."
msgstr "Slaktar får för att producera kött, ull och päls."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Weaving Mill
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1124
msgctxt "hebrews_building"
msgid "'She seeks wool and flax, and works with willing hands.'"
msgstr "\"Hon söker ull och lin och arbetar med villiga händer.\""

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Weaving Mill
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1128
msgctxt "hebrews_building"
msgid "Weaves yarn into cloth."
msgstr "Vävs garn till tyg."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Winery
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1135
msgctxt "hebrews_building"
msgid "'Wine gladdens the heart of man.'"
msgstr "\"Vin gläder människans hjärta.\""

#. TRANSLATORS: Lore author helptext for a Hebrew production site: Winery
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1137
msgctxt "hebrews_building"
msgid "Psalm 104"
msgstr "Psalm 104"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Winery
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1139
msgctxt "hebrews_building"
msgid "Produces wine from grapes and water."
msgstr "Producerar vin från druvor och vatten."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Dressmakery
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1146
msgctxt "hebrews_building"
msgid "'And they sewed fig leaves together and made themselves loincloths.'"
msgstr "\"Och de sydde ihop fikonblad och gjorde sig lårkläder.\""

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Dressmakery
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1150
msgctxt "hebrews_building"
msgid ""
"Produces tunics, tallit katan and tallitot from cloth and gold leaf for "
"soldiers."
msgstr ""
"Tillverkar tunikor, tallit katan och tallitot av tyg och bladguld för "
"soldater."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Clay Furnace
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1157
msgctxt "hebrews_building"
msgid ""
"'As silver is melted in the midst of the furnace, so shall ye be melted in "
"the midst thereof.'"
msgstr "\"Såsom silver smälts i ugnen, så skall ni smältas i den.\""

#. TRANSLATORS: Lore author helptext for a Hebrew production site: Clay Furnace
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1159
msgctxt "hebrews_building"
msgid "Book of Ezekiel"
msgstr "Ezekiels bok"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Clay Furnace
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1161
msgctxt "hebrews_building"
msgid "Smelts copper ore into copper using branches as fuel."
msgstr "Smälter kopparmalm till koppar med hjälp av grenar som bränsle."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Gold Beater's Workshop
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1168
msgctxt "hebrews_building"
msgid "'And they did beat the gold into thin plates, and cut it into wires.'"
msgstr "\"Och de slog guldet till tunna plattor och skar det till trådar.\""

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Gold Beater's Workshop
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1172
msgctxt "hebrews_building"
msgid "Beats gold ore into gold leaf and crafts sacred menorahs."
msgstr "Smidar guldmalm till bladguld och tillverkar heliga menoror."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Workshop
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1179
msgctxt "hebrews_building"
msgid "'The craftsman stretches out his arm, he shapes it with hammers.'"
msgstr "\"Hantverkaren sträcker ut armen och formar den med hammare.\""

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Workshop
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1183
msgctxt "hebrews_building"
msgid ""
"Crafts basic tools such as picks, hammers and fishing rods from branches and "
"granite."
msgstr ""
"Tillverkar grundläggande verktyg såsom hackor, hammare och fiskespön av "
"grenar och granit."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Sofer's Workshop
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1190
msgctxt "hebrews_building"
msgid ""
"'And thou shalt write them upon the door-posts of thy house and upon thy "
"gates.'"
msgstr ""
"\"Och du skall skriva dem på dörrposterna till ditt hus och på dina portar.\""

#. TRANSLATORS: Lore author helptext for a Hebrew production site: Sofer's Workshop
#. TRANSLATORS: Lore author helptext for a Hebrew production site: Copper Mine
#. TRANSLATORS: Lore author helptext for a Hebrew production site: Deep Gold Mine
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1192
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1306
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1332
msgctxt "hebrews_building"
msgid "Book of Deuteronomy"
msgstr "Femte Moseboken"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Sofer's Workshop
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1194
msgctxt "hebrews_building"
msgid ""
"A sacred workshop where a Sofer (scribe) crafts tefilin from wood, fur and "
"gold leaf. Tefilin are used to train soldiers in the training camp."
msgstr ""
"En helig verkstad där en sofer (skriftlärd) tillverkar tefilin av trä, päls "
"och bladguld. Tefilin används för att träna soldater i träningslägret."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Weaponsmithy
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1201
msgctxt "hebrews_building"
msgid "'They shall beat their swords into plowshares.'"
msgstr "\"De ska smida sina svärd till plogbillar.\""

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Weaponsmithy
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1205
msgctxt "hebrews_building"
msgid ""
"Forges slingshots from fur and granite, and copper daggers from copper and "
"fur for soldiers."
msgstr ""
"Tillverkar slangbågar av päls och granit, samt koppar dolkar av koppar och "
"päls för soldater."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Donkey Farm
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1212
msgctxt "hebrews_building"
msgid "'Issachar is a strong donkey, crouching between the sheepfolds.'"
msgstr "Issakar är en stark åsna, som ligger på lur mellan fållorna."

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Donkey Farm
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1216
msgctxt "hebrews_building"
msgid "Breeds donkeys for adding them to the transportation system."
msgstr "Uppfödning av åsnor för att använda dem i transportsystemet."

#. TRANSLATORS: Performance helptext for a Hebrew production site: Donkey Farm
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1218
#, lua-format
msgctxt "hebrews_building"
msgid ""
"If all needed wares are delivered in time, this building can produce a "
"donkey in %s on average."
msgstr ""
"Om alla nödvändiga varor levereras i tid kan denna byggnad producera en åsna "
"i %s i genomsnitt."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Machane
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1225
msgctxt "hebrews_building"
msgid ""
"'Be strong and courageous, for the Lord your God is with you wherever you "
"go.'"
msgstr "Var stark och modig, ty Herren din Gud är med dig vart du än går."

#. TRANSLATORS: Lore author helptext for a Hebrew production site: Machane
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1227
msgctxt "hebrews_building"
msgid "Book of Joshua"
msgstr "Josuas bok"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Machane
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1229
msgctxt "hebrews_building"
msgid ""
"Turns Talmidim into military recruits by equipping them with slingshots. "
"Recruits are then sent to the Initiation Site to become soldiers."
msgstr ""
"Förvandlar Talmidim till militärer genom att utrusta dem med slangbågar. "
"Rekryterna skickas sedan till initieringsplatsen för att bli soldater."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Farm
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1238
msgctxt "hebrews_building"
msgid "'He who tills his land will have plenty of bread.'"
msgstr "Den som brukar sin mark kommer att ha bröd i överflöd."

#. TRANSLATORS: Purpose helptext for production site: Farm
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1242
msgctxt "building"
msgid "Sows and harvests wheat."
msgstr "Sår och skördar vete."

#. TRANSLATORS: Performance helptext for a Hebrew production site: Farm
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1244
msgctxt "hebrews_building"
msgid "The farmer needs %1% on average to sow and harvest a sheaf of wheat."
msgstr "Bonden behöver i genomsnitt %1% för att så och skörda en kärve vete."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Olive Plantation
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1251
msgctxt "hebrews_building"
msgid ""
"'The olive tree said: Should I leave my richness, by which God and men are "
"honoured?'"
msgstr ""
"Olivträdet sade: \"Ska jag lämna min rikedom, genom vilken Gud och människor "
"hedras?\""

#. TRANSLATORS: Lore author helptext for a Hebrew production site: Olive Plantation
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1253
msgctxt "hebrews_building"
msgid "Book of Judges"
msgstr "Domarboken"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Olive Plantation
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1255
msgctxt "hebrews_building"
msgid "Plants and harvests olives."
msgstr "Planterar och skördar oliver."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Yeshiva
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1262
msgctxt "hebrews_building"
msgid "'The study of Torah is equal to all other commandments.'"
msgstr "\"Studiet av Torah är likvärdigt med alla andra bud.\""

#. TRANSLATORS: Lore author helptext for a Hebrew production site: Yeshiva
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1264
msgctxt "hebrews_building"
msgid "Talmud, Shabbat 127a"
msgstr "Talmud, Shabbat 127a"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Yeshiva
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1266
msgctxt "hebrews_building"
msgid ""
"Educates workers to higher levels of learning: Sabalim become Talmidim, "
"Talmidim become Talmidei Chachamim, and Talmidei Chachamim become Rebbes."
msgstr ""
"Utbildar arbetare till högre kunskapsnivåer: Sabalim blir Talmidim, Talmidim "
"blir Talmidei Chachamim och Talmidei Chachamim blir Rebbes."

#. TRANSLATORS: Note helptext for a Hebrew production site: Yeshiva
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1268
msgctxt "hebrews_building"
msgid ""
"Requires a Rebbe to run the Yeshiva. Educated workers are needed to staff "
"specialized buildings."
msgstr ""
"Kräver en rabbin för att driva yeshivan. Utbildade arbetare behövs för att "
"bemanna specialiserade byggnader."

#. TRANSLATORS: Performance helptext for a Hebrew production site: Yeshiva
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1270
#, lua-format
msgctxt "hebrews_building"
msgid ""
"If all needed wares and workers are delivered in time, the Yeshiva needs "
"about %s to educate a worker to the next level."
msgstr ""
"Om alla nödvändiga varor och arbetare levereras i tid behöver Yeshiva cirka "
"%s för att utbilda en arbetare till nästa nivå."

#. TRANSLATORS: Lore helptext for a Hebrew building: Market
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1277
msgctxt "hebrews_building"
msgid "'King Solomon excelled all the kings of the earth in riches and trade.'"
msgstr "\"Kung Salomo överträffade alla jordens kungar i rikedom och handel.\""

#. TRANSLATORS: Purpose helptext for a Hebrew building: Market
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1281
msgctxt "hebrews_building"
msgid ""
"Enables trade with other players. The Hebrews rely on the market to trade "
"gold for the wood they cannot produce."
msgstr ""
"Möjliggör handel med andra spelare. Hebréerna är beroende av marknaden för "
"att byta guld mot trä som de inte kan producera själva."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Solomon's Harbour
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1289
msgctxt "hebrews_building"
msgid ""
"'King Solomon built a fleet of ships at Ezion-Geber, on the shore of the Red "
"Sea.'"
msgstr ""
"Kung Salomo byggde en flotta av skepp i Ezion-Geber, vid Röda havets kust."

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Solomon's Harbour
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1293
msgctxt "hebrews_building"
msgid ""
"Trades sacred menorahs with foreign merchants in exchange for lumber. This "
"is the only way for the Hebrews to obtain wood."
msgstr ""
"Handlar med heliga menoror med utländska köpmän i utbyte mot timmer. Detta "
"är det enda sättet för hebréerna att få tag på trä."

#. TRANSLATORS: Performance helptext for a Hebrew production site: Solomon's Harbour
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1295
#, lua-format
msgctxt "hebrews_building"
msgid ""
"If all needed wares are delivered in time, this building can produce two "
"logs in %s on average."
msgstr ""
"Om alla nödvändiga varor levereras i tid kan denna byggnad producera två "
"stockar i %s i genomsnitt."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Copper Mine
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1304
msgctxt "hebrews_building"
msgid "'The land where you will dig copper out of the hills.'"
msgstr "\"Det land där du kommer att gräva koppar ur bergen.\""

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Copper Mine
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1308
msgctxt "hebrews_building"
msgid "Digs copper ore out of the ground in mountain terrain."
msgstr "Gräver kopparmalm ur marken i bergig terräng."

#. TRANSLATORS: Performance helptext for a Hebrew production site: Copper Mine
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1310
#, lua-format
msgctxt "hebrews_building"
msgid ""
"If the food supply is steady, this mine can produce copper ore in %s on "
"average."
msgstr ""
"Om livsmedelsförsörjningen är stabil kan denna gruva producera kopparmalm i "
"%s i genomsnitt."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Gold Mine
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1317
msgctxt "hebrews_building"
msgid "'The gold of that land is good.'"
msgstr "\"Guldet i det landet är bra.\""

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Gold Mine
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1321
msgctxt "hebrews_building"
msgid "Digs gold ore out of the ground in mountain terrain."
msgstr "Gräver guldmalm ur marken i bergig terräng."

#. TRANSLATORS: Performance helptext for a Hebrew production site: Gold Mine
#. TRANSLATORS: Performance helptext for a Hebrew production site: Deep Gold Mine
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1323
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1336
#, lua-format
msgctxt "hebrews_building"
msgid ""
"If the food supply is steady, this mine can produce gold ore in %s on "
"average."
msgstr ""
"Om livsmedelsförsörjningen är stabil kan denna gruva producera guldmalm i "
"genomsnitt %s."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Deep Gold Mine
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1330
msgctxt "hebrews_building"
msgid ""
"'A land whose stones are iron, and out of whose hills you can dig copper.'"
msgstr ""
"\"Ett land vars stenar är av järn och vars berg man kan bryta koppar ur.\""

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Deep Gold Mine
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1334
msgctxt "hebrews_building"
msgid ""
"Digs gold ore out of the ground in mountain terrain. This mine reaches the "
"deepest veins."
msgstr ""
"Gräver guldmalm ur marken i bergsterräng. Denna gruva når de djupaste "
"ådrorna."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Granite Mine
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1343
msgctxt "hebrews_building"
msgid ""
"'Solomon's builders cut the great stones to lay the foundation of the "
"temple.'"
msgstr ""
"\"Salomos byggare högg ut de stora stenarna för att lägga grunden till "
"templet.\""

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Granite Mine
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1347
msgctxt "hebrews_building"
msgid "Carves granite out of the rock in mountain terrain."
msgstr "Hugger granit ur berget i bergsterräng."

#. TRANSLATORS: Note helptext for a Hebrew production site: Granite Mine
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1349
msgctxt "hebrews_building"
msgid "It cannot be enhanced."
msgstr "Det kan inte förbättras."

#. TRANSLATORS: Performance helptext for a Hebrew production site: Granite Mine
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1351
#, lua-format
msgctxt "hebrews_building"
msgid ""
"If the food supply is steady, this mine can produce granite in %s on average."
msgstr ""
"Om livsmedelsförsörjningen är stabil kan denna gruva producera granit i %s i "
"genomsnitt."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Threshing Floor
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1358
msgctxt "hebrews_building"
msgid "'Ornan was threshing wheat on the threshing floor.'"
msgstr "Ornan tröskade vete på tröskplatsen."

#. TRANSLATORS: Lore author helptext for a Hebrew production site: Threshing Floor
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1360
msgctxt "hebrews_building"
msgid "First Book of Chronicles"
msgstr "Första Krönikeboken"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Threshing Floor
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1362
msgctxt "hebrews_building"
msgid "Threshes harvested wheat into wheat grains."
msgstr "Tröskar skördat vete till vetekorn."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Vineyard
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1369
msgctxt "hebrews_building"
msgid "'Noah began to be a man of the soil, and he planted a vineyard.'"
msgstr "Noah började bli en jordbrukare och planterade en vingård."

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Vineyard
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1373
msgctxt "hebrews_building"
msgid "Cultivates grapevines and harvests grapes."
msgstr "Odlar vindruvor och skördar druvor."

#. TRANSLATORS: Lore helptext for a Hebrew training site: Training Camp
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1382
msgctxt "hebrews_building"
msgid ""
"'Blessed be the Lord my Rock, who trains my hands for war and my fingers for "
"battle.'"
msgstr ""
"\"Välsignad vare Herren, min klippa, som tränar mina händer för krig och "
"mina fingrar för strid.\""

#. TRANSLATORS: Lore author helptext for a Hebrew training site: Training Camp
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1384
msgctxt "hebrews_building"
msgid "Psalm 144"
msgstr "Psalm 144"

#. TRANSLATORS: Purpose helptext for a Hebrew training site: Training Camp, part 1
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1387
msgctxt "hebrews_building"
msgid "Trains soldiers in 'Attack', 'Health' and 'Evade'."
msgstr "Tränar soldater i \"Attack\", \"Hälsa\" och \"Undvik\"."

#. TRANSLATORS: Purpose helptext for a Hebrew training site: Training Camp, part 2
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1389
msgctxt "hebrews_building"
msgid "Equips the soldiers with all necessary weapons and armor parts."
msgstr "Utrustar soldaterna med alla nödvändiga vapen och rustningsdelar."

#. TRANSLATORS: Note helptext for a Hebrew training site: Training Camp
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1392
msgctxt "hebrews_building"
msgid ""
"Hebrew soldiers cannot be trained in 'Defense' and will remain at their "
"initial level."
msgstr ""
"Hebreiska soldater kan inte tränas i \"försvar\" och kommer att förbli på "
"sin ursprungliga nivå."

#. TRANSLATORS: Performance helptext for a Hebrew training site: Training Camp
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1394
#, lua-format
msgctxt "hebrews_building"
msgid ""
"If all needed wares are delivered in time, a training camp can train one new "
"soldier in attack, health and evade to the final level in %s on average."
msgstr ""
"Om alla nödvändiga varor levereras i tid kan ett träningsläger i genomsnitt "
"träna en ny soldat i attack, hälsa och undvikande till den slutliga nivån på "
"%s."

#. TRANSLATORS: Lore helptext for a Hebrew military site: Small Tent
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1403
msgctxt "hebrews_building"
msgid "'How good are your tents, O Jacob, your dwelling places, O Israel!'"
msgstr "\"Hur bra är dina tält, Jakob, dina boningar, Israel!\""

#. TRANSLATORS: Purpose helptext for a Hebrew military site: Small Tent
#. TRANSLATORS: Purpose helptext for a Hebrew military site: Massada
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1407
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1420
msgctxt "hebrews_building"
msgid "Garrisons soldiers to expand your territory."
msgstr "Garrisons soldater för att utvidga ditt territorium."

#. TRANSLATORS: Note helptext for a Hebrew military site: Small Tent
#. TRANSLATORS: Note helptext for a Hebrew military site: Massada
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1409
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1422
msgctxt "hebrews_building"
msgid ""
"If you're low on soldiers to occupy new military sites, use the downward "
"arrow button to decrease the capacity. You can also click on a soldier to "
"send him away."
msgstr ""
"Om du har för få soldater för att ockupera nya militära platser kan du "
"använda nedåtpilen för att minska kapaciteten. Du kan också klicka på en "
"soldat för att skicka iväg honom."

#. TRANSLATORS: Lore helptext for a Hebrew military site: Massada
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1416
msgctxt "hebrews_building"
msgid "'Massada shall not fall again!'"
msgstr "\"Masada ska inte falla igen!\""

#. TRANSLATORS: Lore author helptext for a Hebrew military site: Massada
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1418
msgctxt "hebrews_building"
msgid "Ancient Hebrew oath"
msgstr "Forntida hebreisk ed"

#. TRANSLATORS: Lore helptext for a Hebrew production site: Shipyard
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1431
msgctxt "hebrews_building"
msgid ""
"'For King Solomon had a fleet of ships of Tarshish at sea with the fleet of "
"Hiram.'"
msgstr ""
"\"Kung Salomo hade nämligen en flotta av skepp från Tarsis till havs "
"tillsammans med Hirams flotta.\""

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Shipyard
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1435
msgctxt "hebrews_building"
msgid "Constructs ships for overseas exploration and trade."
msgstr "Bygger fartyg för utforskning och handel utomlands."

#. TRANSLATORS: Lore helptext for a Hebrew building: Construction Site
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1444
msgctxt "building"
msgid "'Don't swear at the builder who is short of building materials.'"
msgstr "\"Svär inte åt byggaren som har brist på byggmaterial.\""

#. TRANSLATORS: Lore author helptext for a Hebrew building: Construction Site
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1446
msgctxt "building"
msgid "Proverb widely used for impossible tasks of any kind"
msgstr "Ordspråk som ofta används för omöjliga uppgifter av alla slag."

#. TRANSLATORS: Purpose helptext for a Hebrew building: Construction Site
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1448
msgctxt "building"
msgid "A new building is being built at this construction site."
msgstr "En ny byggnad håller på att uppföras på denna byggarbetsplats."

#. TRANSLATORS: Lore helptext for a Hebrew building: Dismantle Site
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1455
msgctxt "building"
msgid "'New paths will appear when you are willing to tear down the old.'"
msgstr ""
"\"Nya vägar kommer att dyka upp när du är villig att riva ner de gamla.\""

#. TRANSLATORS: Lore author helptext for a Hebrew building: Dismantle Site
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1457
msgctxt "building"
msgid "Proverb"
msgstr "Ordspråk"

#. TRANSLATORS: Purpose helptext for a Hebrew building: Dismantle Site
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1459
msgctxt "building"
msgid ""
"A building is being dismantled at this dismantle site, returning some of the "
"resources that were used during this building's construction to your tribe's "
"stores."
msgstr ""
"En byggnad rivs på denna rivningsplats, vilket återför en del av de resurser "
"som användes vid byggandet av denna byggnad till din stam."

