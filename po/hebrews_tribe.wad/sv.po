#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:899
msgid ""
"This tree is only planted by the Amazon tribe but can be harvested for logs."
msgstr ""
"Detta träd planteras endast av Amazonasstammarna, men kan avverkas för "
"timmer."

#. TRANSLATORS: Helptext for a Hebrew immovable: Grapevine
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:794
msgid "This grapevine has just been planted."
msgstr "Denna vinranka har just planterats."

#. TRANSLATORS: Helptext for a Hebrew immovable: Grapevine
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:801
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:808
msgid "This grapevine is growing."
msgstr "Denna vinranka växer."

#. TRANSLATORS: Helptext for a Hebrew immovable: Grapevine
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:815
msgid "This grapevine is ready for harvesting."
msgstr "Denna vindruva är redo för skörd."

#. TRANSLATORS: Helptext for a Hebrew immovable: Olive Tree
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:822
msgid "This olive tree has just been planted."
msgstr "Detta olivträd har just planterats."

#. TRANSLATORS: Helptext for a Hebrew immovable: Olive Tree
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:829
msgid "This olive tree is growing."
msgstr "Detta olivträd växer."

#. TRANSLATORS: Helptext for a Hebrew immovable: Olive Tree
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:836
msgid "This olive tree is ready for harvesting."
msgstr "Detta olivträd är redo för skörd."

#. TRANSLATORS: Helptext for a Hebrew immovable: Dry Pond
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:843
msgid ""
"A shallow depression left by clay digging. It will fill in naturally over "
"time."
msgstr ""
"En grund fördjupning som uppstått genom grävning i lerjord. Den kommer att "
"fyllas igen naturligt med tiden."

#. TRANSLATORS: Lore helptext for a Hebrew warehouse: Headquarters
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:911
msgctxt "hebrews_building"
msgid "'The Tabernacle was the dwelling place of the Lord among His people.'"
msgstr "Tabernaklet var Herrens boning bland sitt folk."

#. TRANSLATORS: Lore author helptext for a Hebrew warehouse: Headquarters
#. TRANSLATORS: Lore author helptext for a Hebrew production site: Gold Beater's Workshop
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:913
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1170
msgctxt "hebrews_building"
msgid "Book of Exodus"
msgstr "Andra Moseboken"

#. TRANSLATORS: Purpose helptext for a Hebrew warehouse: Headquarters
#. TRANSLATORS: Purpose helptext for a Hebrew warehouse: Headquarters Tent
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:915
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:924
msgctxt "hebrews_building"
msgid "Accommodation for your people. Also stores your wares and tools."
msgstr "Boende för dina medarbetare. Förvarar även dina varor och verktyg."

#. TRANSLATORS: Note helptext for a Hebrew warehouse: Headquarters
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:917
msgctxt "hebrews_building"
msgid "The headquarters is your main building."
msgstr "Huvudkontoret är din huvudbyggnad."

#. TRANSLATORS: Note helptext for a Hebrew warehouse: Headquarters Tent
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:926
msgctxt "hebrews_building"
msgid "The headquarters tent is your main building."
msgstr "Huvudkontorstältet är din huvudbyggnad."

#. TRANSLATORS: Lore helptext for a Hebrew warehouse: Warehouse
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:933
msgctxt "hebrews_building"
msgid ""
"'Store your grain in times of plenty, for lean years will surely follow.'"
msgstr ""
"\"Lagra ditt spannmål i tider av överflöd, för magra år kommer säkert att "
"följa.\""

#. TRANSLATORS: Lore author helptext for a Hebrew warehouse: Warehouse
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:935
msgctxt "hebrews_building"
msgid "Ancient Hebrew proverb"
msgstr "Gammalt hebreiskt ordspråk"

#. TRANSLATORS: Purpose helptext for a Hebrew warehouse: Warehouse
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:937
msgctxt "hebrews_building"
msgid ""
"Your workers and soldiers will find shelter here. Also stores your wares and "
"tools."
msgstr ""
"Dina arbetare och soldater kommer att hitta skydd här. Förvara även dina "
"varor och verktyg här."

#. TRANSLATORS: Lore helptext for a Hebrew warehouse: Port
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:944
msgctxt "hebrews_building"
msgid "'King Solomon built a fleet of ships at Ezion-Geber.'"
msgstr "Kung Salomo byggde en flotta av skepp i Ezion-Geber."

#. TRANSLATORS: Lore author helptext for a Hebrew warehouse: Port
#. TRANSLATORS: Lore author helptext for a Hebrew production site: Quarry
#. TRANSLATORS: Lore author helptext for a Hebrew building: Market
#. TRANSLATORS: Lore author helptext for a Hebrew production site: Solomon's Harbour
#. TRANSLATORS: Lore author helptext for a Hebrew production site: Granite Mine
#. TRANSLATORS: Lore author helptext for a Hebrew production site: Shipyard
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:946
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1009
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1279
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1291
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1345
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:1433
msgctxt "hebrews_building"
msgid "First Book of Kings"
msgstr "Första Konungaboken"

#. TRANSLATORS: Purpose helptext for a Hebrew warehouse: Port
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:948
msgctxt "hebrews_building"
msgid ""
"Serves as a base for overseas colonization and trade. Also stores your "
"soldiers, wares and tools."
msgstr ""
"Fungerar som bas för utländsk kolonisering och handel. Lagrar även dina "
"soldater, varor och verktyg."

#. TRANSLATORS: Note helptext for a Hebrew warehouse: Port
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:950
msgctxt "hebrews_building"
msgid ""
"Similar to the Headquarters a Port can be attacked and destroyed by an "
"enemy. It is recommendable to send soldiers to defend it."
msgstr ""
"Precis som högkvarteret kan en hamn attackeras och förstöras av en fiende. "
"Det rekommenderas att skicka soldater för att försvara den."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Branch Collector's Hut
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:959
msgctxt "hebrews_building"
msgid ""
"'For there is hope for a tree, if it be cut down, that it will sprout again, "
"and that its shoots will not cease.'"
msgstr ""
"\"Ty det finns hopp för ett träd, om det huggs ned, att det skall spira igen "
"och att dess skott inte skall upphöra.\""

#. TRANSLATORS: Lore author helptext for a Hebrew production site: Branch Collector's Hut
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:961
msgctxt "hebrews_building"
msgid "Book of Job"
msgstr "Jobs bok"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Branch Collector's Hut
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:963
msgctxt "hebrews_building"
msgid ""
"Collects fallen branches from trees in the vicinity. The trees are not "
"harmed."
msgstr "Samlar upp nedfallna grenar från träd i närheten. Träden skadas inte."

#. TRANSLATORS: Note helptext for a Hebrew production site: Branch Collector's Hut
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:965
msgctxt "hebrews_building"
msgid ""
"Branches are the primary building material and fuel. The branch collector "
"needs trees nearby."
msgstr ""
"Grenar är det viktigaste byggmaterialet och bränslet. Greninsamlaren behöver "
"träd i närheten."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Fisher's Hut
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:972
msgctxt "hebrews_building"
msgid "'Cast your net on the right side of the boat and you will find some.'"
msgstr "Kasta ditt nät på höger sida av båten så kommer du att hitta några."

#. TRANSLATORS: Lore author helptext for a Hebrew production site: Fisher's Hut
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:974
msgctxt "hebrews_building"
msgid "Gospel of John"
msgstr "Johannes evangelium"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Fisher's Hut
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:976
msgctxt "hebrews_building"
msgid "Catches fish in the nearby waters."
msgstr "Fångar fisk i närliggande vatten."

#. TRANSLATORS: Note helptext for a Hebrew production site: Fisher's Hut
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:978
msgctxt "hebrews_building"
msgid "The fisher needs water nearby to catch fish."
msgstr "Fiskaren behöver vatten i närheten för att kunna fiska."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Shepherd's Hut
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:985
msgctxt "hebrews_building"
msgid "'The Lord is my shepherd, I shall not want.'"
msgstr "\"Herren är min herde, mig skall intet fattas.\""

#. TRANSLATORS: Lore author helptext for a Hebrew production site: Shepherd's Hut
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:987
msgctxt "hebrews_building"
msgid "Psalm 23"
msgstr "Psalm 23"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Shepherd's Hut
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:989
msgctxt "hebrews_building"
msgid "Raises sheep for wool, meat and fur."
msgstr "Uppfödning av får för ull, kött och päls."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Well
#: addons/hebrews_tribe.wad/tribes/initialization/hebrews/units.lua:996
msgctxt "hebrews_building"
msgid "'Then Israel sang this song: Spring up, O well!'"
msgstr "Då sjöng Israel denna sång: \"Sprid dig, o källa!\""

#. TRANSLATORS: Lore author helptext for a Hebrew production site: Well
#. TRANSLATORS: Lore author helptext for a Hebrew production site: Zizijot Maker's Hut
#. TRANSLATORS: Lore author helptext for a Hebrew production site: Scout's Hut
