#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:931 input:931 standard
msgctxt "hebrews_building"
msgid "The headquarters tent is your main building."
msgstr "Huvudkontorstältet är din huvudbyggnad."

#. TRANSLATORS: Lore helptext for a Hebrew warehouse: Warehouse
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:938 input:938 standard
msgctxt "hebrews_building"
msgid ""
"'Store your grain in times of plenty, for lean years will surely follow.'"
msgstr ""
"\"Lagra ditt spannmål i tider av överflöd, för magra år kommer säkert att "
"följa.\""

#. TRANSLATORS: Lore author helptext for a Hebrew warehouse: Warehouse
