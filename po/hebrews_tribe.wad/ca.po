msgid "Book of Numbers"
msgstr "Llibre dels números"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Well
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1005 input:1005 standard
msgctxt "hebrews_building"
msgid "Draws water out of the deep."
msgstr "Treu aigua de les profunditats."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Quarry
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1012 input:1012 standard
msgctxt "hebrews_building"
msgid "'Solomon's builders and Hiram's builders cut the stone.'"
msgstr ""
"\"Els constructors de Salomó i els constructors d'Hiram van tallar la "
"pedra\"."

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Quarry
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1016 input:1016 standard
msgctxt "hebrews_building"
msgid "Cuts raw pieces of granite out of rocks in the vicinity."
msgstr "Talla peces crues de granit de les roques dels voltants."

#. TRANSLATORS: Note helptext for a Hebrew production site: Quarry
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1018 input:1018 standard
msgctxt "hebrews_building"
msgid "The quarry needs rocks to cut within the work area."
msgstr "La pedrera necessita roques per tallar dins de la zona de treball."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Clay Pit
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1025 input:1025 standard
msgctxt "hebrews_building"
msgid "'Like clay in the hand of the potter, so are you in My hand.'"
msgstr "\"Com el fang a la mà del terrisser, així ets tu a la meva mà\"."

#. TRANSLATORS: Lore author helptext for a Hebrew production site: Clay Pit
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1027 input:1027 standard
msgctxt "hebrews_building"
msgid "Book of Jeremiah"
msgstr "Llibre de Jeremies"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Clay Pit
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1029 input:1029 standard
msgctxt "hebrews_building"
msgid "Digs clay out of the ground."
msgstr "Excava l'argila de la terra."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Brick Kiln
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1036 input:1036 standard
msgctxt "hebrews_building"
msgid "'Come, let us make bricks and burn them thoroughly.'"
msgstr "\"Venga, fem maons i cremem-los a fons\"."

