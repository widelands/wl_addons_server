#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1197
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1311
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1337 input:1197 input:1311
#: input:1337 standard
msgctxt "hebrews_building"
msgid "Book of Deuteronomy"
msgstr "Llibre del Deuteronomi"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Sofer's Workshop
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1199 input:1199 standard
msgctxt "hebrews_building"
msgid ""
"A sacred workshop where a Sofer (scribe) crafts tefilin from wood, fur and "
"gold leaf. Tefilin are used to train soldiers in the training camp."
msgstr ""
"Un taller sagrat on un Sofer (escrivà) elabora tefilines amb fusta, pell i "
"fulla d'or. Els tefilins s'utilitzen per entrenar soldats al camp "
"d'entrenament."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Weaponsmithy
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1206 input:1206 standard
msgctxt "hebrews_building"
msgid "'They shall beat their swords into plowshares.'"
msgstr "\"Convertiran les seves espases en reixes d'arada\"."

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Weaponsmithy
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1210 input:1210 standard
msgctxt "hebrews_building"
msgid ""
"Forges slingshots from fur and granite, and copper daggers from copper and "
"fur for soldiers."
msgstr ""
"Forja fones de pell i granit, i punyals de coure de coure i pell per als "
"soldats."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Donkey Farm
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1217 input:1217 standard
msgctxt "hebrews_building"
msgid "'Issachar is a strong donkey, crouching between the sheepfolds.'"
msgstr "\"Issacar és un ruc fort, ajupit entre els ovells\"."

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Donkey Farm
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1221 input:1221 standard
msgctxt "hebrews_building"
msgid "Breeds donkeys for adding them to the transportation system."
msgstr "Cria rucs per afegir-los al sistema de transport."

#. TRANSLATORS: Performance helptext for a Hebrew production site: Donkey Farm
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1223 input:1223 standard
#, lua-format
msgctxt "hebrews_building"
msgid ""
"If all needed wares are delivered in time, this building can produce a "
"donkey in %s on average."
msgstr ""
"Si totes les mercaderies necessàries es lliuren a temps, aquest edifici pot "
"produir un ruc a %s de mitjana."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Machane
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1230 input:1230 standard
msgctxt "hebrews_building"
msgid ""
"'Be strong and courageous, for the Lord your God is with you wherever you "
"go.'"
msgstr ""
"Sigues fort i valent, perquè el Senyor, el teu Déu, és amb tu allà on vagis."

#. TRANSLATORS: Lore author helptext for a Hebrew production site: Machane
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1232 input:1232 standard
msgctxt "hebrews_building"
msgid "Book of Joshua"
msgstr "Llibre de Josuè"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Machane
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1234 input:1234 standard
msgctxt "hebrews_building"
msgid ""
"Turns Talmidim into military recruits by equipping them with slingshots. "
"Recruits are then sent to the Initiation Site to become soldiers."
msgstr ""
"Converteix Talmidim en reclutes militars equipant-los amb fones. Aleshores, "
"els reclutes s'envien al lloc d'iniciació per convertir-se en soldats."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Farm
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1243 input:1243 standard
msgctxt "hebrews_building"
msgid "'He who tills his land will have plenty of bread.'"
msgstr "\"Qui conreu la seva terra tindrà pa en abundància\"."

#. TRANSLATORS: Purpose helptext for production site: Farm
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1247 input:1247 standard
msgctxt "building"
msgid "Sows and harvests wheat."
msgstr "Sembra i cull blat."

#. TRANSLATORS: Performance helptext for a Hebrew production site: Farm
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1249 input:1249 standard
msgctxt "hebrews_building"
msgid "The farmer needs %1% on average to sow and harvest a sheaf of wheat."
msgstr ""
"El pagès necessita un 1% de mitjana per sembrar i collir una garba de blat."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Olive Plantation
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1256 input:1256 standard
msgctxt "hebrews_building"
msgid ""
"'The olive tree said: Should I leave my richness, by which God and men are "
"honoured?'"
msgstr ""
"'L'olivera va dir: He de deixar la meva riquesa, per la qual Déu i els homes "
"són honrats?'"

#. TRANSLATORS: Lore author helptext for a Hebrew production site: Olive Plantation
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1258 input:1258 standard
msgctxt "hebrews_building"
msgid "Book of Judges"
msgstr "Llibre dels Jutges"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Olive Plantation
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1260 input:1260 standard
msgctxt "hebrews_building"
msgid "Plants and harvests olives."
msgstr "Planta i cull olives."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Yeshiva
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1267 input:1267 standard
msgctxt "hebrews_building"
msgid "'The study of Torah is equal to all other commandments.'"
msgstr "\"L'estudi de la Torà és igual a tots els altres manaments\"."

#. TRANSLATORS: Lore author helptext for a Hebrew production site: Yeshiva
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1269 input:1269 standard
msgctxt "hebrews_building"
msgid "Talmud, Shabbat 127a"
msgstr "Talmud, Shabat 127a"

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Yeshiva
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1271 input:1271 standard
msgctxt "hebrews_building"
msgid ""
"Educates workers to higher levels of learning: Sabalim become Talmidim, "
"Talmidim become Talmidei Chachamim, and Talmidei Chachamim become Rebbes."
msgstr ""
"Educa els treballadors a nivells més alts d'aprenentatge: Sabalim es "
"converteix en talmidim, Talmidim es converteix en Talmidei Chachamim i "
"Talmidei Jachamim es converteix en Rebbes."

#. TRANSLATORS: Note helptext for a Hebrew production site: Yeshiva
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1273 input:1273 standard
msgctxt "hebrews_building"
msgid ""
"Requires a Rebbe to run the Yeshiva. Educated workers are needed to staff "
"specialized buildings."
msgstr ""
"Requereix un Rebe per executar la Yeshiva. Es necessiten treballadors "
"educats per dotar els edificis especialitzats."

#. TRANSLATORS: Performance helptext for a Hebrew production site: Yeshiva
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1275 input:1275 standard
#, lua-format
msgctxt "hebrews_building"
msgid ""
"If all needed wares and workers are delivered in time, the Yeshiva needs "
"about %s to educate a worker to the next level."
msgstr ""
"Si totes les mercaderies i treballadors necessaris s'entreguen a temps, la "
"Yeshiva necessita aproximadament %s per educar un treballador al següent "
"nivell."

#. TRANSLATORS: Lore helptext for a Hebrew building: Market
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1282 input:1282 standard
msgctxt "hebrews_building"
msgid "'King Solomon excelled all the kings of the earth in riches and trade.'"
msgstr ""
"\"El rei Salomó va superar tots els reis de la terra en riqueses i comerç\"."

#. TRANSLATORS: Purpose helptext for a Hebrew building: Market
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1286 input:1286 standard
msgctxt "hebrews_building"
msgid ""
"Enables trade with other players. The Hebrews rely on the market to trade "
"gold for the wood they cannot produce."
msgstr ""
"Permet el comerç amb altres jugadors. Els hebreus depenen del mercat per "
"intercanviar or per la fusta que no poden produir."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Solomon's Harbour
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1294 input:1294 standard
msgctxt "hebrews_building"
msgid ""
"'King Solomon built a fleet of ships at Ezion-Geber, on the shore of the Red "
"Sea.'"
msgstr ""
"\"El rei Salomó va construir una flota de vaixells a Ezió-Gueber, a la vora "
"del mar Roig\"."

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Solomon's Harbour
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1298 input:1298 standard
msgctxt "hebrews_building"
msgid ""
"Trades sacred menorahs with foreign merchants in exchange for lumber. This "
"is the only way for the Hebrews to obtain wood."
msgstr ""
"Comercialitza menorahs sagrades amb comerciants estrangers a canvi de fusta. "
"Aquesta és l'única manera que tenen els hebreus d'obtenir fusta."

#. TRANSLATORS: Performance helptext for a Hebrew production site: Solomon's Harbour
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1300 input:1300 standard
#, lua-format
msgctxt "hebrews_building"
msgid ""
"If all needed wares are delivered in time, this building can produce two "
"logs in %s on average."
msgstr ""
"Si tots els productes necessaris es lliuren a temps, aquest edifici pot "
"produir dos registres a %s de mitjana."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Copper Mine
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1309 input:1309 standard
msgctxt "hebrews_building"
msgid "'The land where you will dig copper out of the hills.'"
msgstr "\"La terra on excavaràs coure dels turons\"."

#. TRANSLATORS: Purpose helptext for a Hebrew production site: Copper Mine
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1313 input:1313 standard
msgctxt "hebrews_building"
msgid "Digs copper ore out of the ground in mountain terrain."
msgstr "Excava mineral de coure del sòl en terrenys de muntanya."

#. TRANSLATORS: Performance helptext for a Hebrew production site: Copper Mine
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1315 input:1315 standard
#, lua-format
msgctxt "hebrews_building"
msgid ""
"If the food supply is steady, this mine can produce copper ore in %s on "
"average."
msgstr ""
"Si el subministrament d'aliments és constant, aquesta mina pot produir "
"mineral de coure a %s de mitjana."

#. TRANSLATORS: Lore helptext for a Hebrew production site: Gold Mine
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:1322 input:1322 standard
msgctxt "hebrews_building"
msgid "'The gold of that land is good.'"
msgstr "\"L'or d'aquesta terra és bo\"."

