#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:929 input:920 input:929
#: standard
msgctxt "hebrews_building"
msgid "Accommodation for your people. Also stores your wares and tools."
msgstr ""
"Allotjament per a la teva gent. També emmagatzema les teves mercaderies i "
"eines."

#. TRANSLATORS: Note helptext for a Hebrew warehouse: Headquarters
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:922 input:922 standard
msgctxt "hebrews_building"
msgid "The headquarters is your main building."
msgstr "La seu és el vostre edifici principal."

#. TRANSLATORS: Note helptext for a Hebrew warehouse: Headquarters Tent
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:931 input:931 standard
msgctxt "hebrews_building"
msgid "The headquarters tent is your main building."
msgstr "La carpa de la seu central és el vostre edifici principal."

#. TRANSLATORS: Lore helptext for a Hebrew warehouse: Warehouse
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:938 input:938 standard
msgctxt "hebrews_building"
msgid ""
"'Store your grain in times of plenty, for lean years will surely follow.'"
msgstr ""
"\"Emgatzema el teu gra en temps d'abundància, perquè segurament els seguiran "
"anys magres\"."

#. TRANSLATORS: Lore author helptext for a Hebrew warehouse: Warehouse
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:940 input:940 standard
msgctxt "hebrews_building"
msgid "Ancient Hebrew proverb"
msgstr "Antic proverbi hebreu"

#. TRANSLATORS: Purpose helptext for a Hebrew warehouse: Warehouse
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:942 input:942 standard
msgctxt "hebrews_building"
msgid ""
"Your workers and soldiers will find shelter here. Also stores your wares and "
"tools."
msgstr ""
"Els vostres treballadors i soldats trobaran refugi aquí. També emmagatzema "
"les teves mercaderies i eines."

#. TRANSLATORS: Lore helptext for a Hebrew warehouse: Port
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:949 input:949 standard
msgctxt "hebrews_building"
msgid "'King Solomon built a fleet of ships at Ezion-Geber.'"
msgstr "\"El rei Salomó va construir una flota de vaixells a Ezió-Geber\"."

