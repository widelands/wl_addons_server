#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:929
msgctxt "hebrews_building"
msgid "Accommodation for your people. Also stores your wares and tools."
msgstr "Brengt diene Lüü unner un verwahrt diene Waren un anner Kraam."

#. TRANSLATORS: Note helptext for a Hebrew warehouse: Headquarters
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:922
msgctxt "hebrews_building"
msgid "The headquarters is your main building."
msgstr "Dat Raadhuus is dien wichtigstes Huus."

#. TRANSLATORS: Note helptext for a Hebrew warehouse: Headquarters Tent
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:931
msgctxt "hebrews_building"
msgid "The headquarters tent is your main building."
msgstr "Dat Telt-Raadhuus is dien wichtigstes Huus."

#. TRANSLATORS: Lore helptext for a Hebrew warehouse: Warehouse
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:938
msgctxt "hebrews_building"
msgid ""
"'Store your grain in times of plenty, for lean years will surely follow.'"
msgstr ""
"»Spar dien Korns in de tüchtig Tieden, for feske Johr künn ganz scheef "
"ankommen.«"

#. TRANSLATORS: Lore author helptext for a Hebrew warehouse: Warehouse
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:940
msgctxt "hebrews_building"
msgid "Ancient Hebrew proverb"
msgstr "Olle hebräisk Seggwies"

#. TRANSLATORS: Purpose helptext for a Hebrew warehouse: Warehouse
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:942
msgctxt "hebrews_building"
msgid ""
"Your workers and soldiers will find shelter here. Also stores your wares and "
"tools."
msgstr ""
"Brengt diene Lüü un Soldatsken unner un verwahrt diene Waren un anner Kraam."

#. TRANSLATORS: Lore helptext for a Hebrew warehouse: Port
#: addons/hebrews_tribe.wad/tribes/hebrews/units.lua:949
msgctxt "hebrews_building"
msgid "'King Solomon built a fleet of ships at Ezion-Geber.'"
msgstr "»König Salomo bouwt en Flott vun Schippens in Ezion-Geber.«"

