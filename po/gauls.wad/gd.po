#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1678 input:1667 input:1678
#: standard
msgctxt "gauls_building"
msgid ""
"The toiler needs %1$s to produce one basket of wheat or %2$s to produce one "
"basket of wheat and one bale of straw."
msgstr ""

#. TRANSLATORS: Purpose help text for a Gallic production site: Mill
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1685 input:1685 standard
msgctxt "gauls_building"
msgid "Grinds wheat to produce flour."
msgstr ""

#. TRANSLATORS: Performance help text for a Gallic production site: Mill
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1687 input:1687 standard
msgctxt "gauls_building"
msgid "The miller needs %1% to grind wheat into a sack of flour."
msgstr ""

#. TRANSLATORS: Purpose help text for a Gallic production site: Bakery
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1694 input:1694 standard
msgctxt "gauls_building"
msgid "Bakes bread for ration and meal preparation."
msgstr ""

#. TRANSLATORS: Performance help text for a Gallic production site: Bakery
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1696 input:1696 standard
msgctxt "gauls_building"
msgid "The baker needs %1% on average to bake a loaf of bread."
msgstr ""

#. TRANSLATORS: Purpose help text for a Gallic production site: Small Kitchen
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1703 input:1703 standard
msgctxt "gauls_building"
msgid "Prepares rations to feed the scouts and miners."
msgstr ""

#. TRANSLATORS: Performance help text for a Gallic production site: Small Kitchen
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1705 input:1705 standard
msgctxt "gauls_building"
msgid "The cook needs %1% on average to prepare one ration."
msgstr ""

#. TRANSLATORS: Purpose help text for a Gallic production site: Kitchen
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1712 input:1712 standard
msgctxt "gauls_building"
msgid ""
"Prepares rations for scouts and miners as well as meals to feed the miners "
"at advanced mines and warriors at the training sites."
msgstr ""

#. TRANSLATORS: Performance help text for a Gallic production site: Kitchen
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1714 input:1714 standard
msgctxt "gauls_building"
msgid ""
"If this building is fully supplied and all kinds of food are needed by the "
"economy, production of one of each food takes %1$s. If only one kind of food "
"is needed by the economy, production of one ration or one meal takes %2$s."
msgstr ""

#. TRANSLATORS: Purpose help text for a Gallic production site: Smokery
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1721 input:1721 standard
msgctxt "gauls_building"
msgid "Smokes fish and meat using logs."
msgstr ""

#. TRANSLATORS: Performance help text for a Gallic production site: Smokery
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1723 input:1723 standard
msgctxt "gauls_building"
msgid ""
"If this building is fully supplied, the cook needs %1% to smoke three fishes "
"or three pieces of meat."
msgstr ""

#. TRANSLATORS: Purpose help text for a Gallic production site: Druid’s House
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1730 input:1730 standard
msgctxt "gauls_building"
msgid "Produces elixirs and potions for your miners and warriors."
msgstr ""

#. TRANSLATORS: Note help text for a Gallic production site: Druid’s House
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1732 input:1732 standard
msgctxt "gauls_building"
msgid ""
"Because the druid picks some secret ingredients by himself, he needs trees "
"for potion preparation and fruit trees with fruit for elixir preparation in "
"his working area."
msgstr ""

#. TRANSLATORS: Performance help text for a Gallic production site: Druid’s House
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1734 input:1734 standard
msgctxt "gauls_building"
msgid ""
"If this building is fully supplied and all kinds of drinks are needed by the "
"economy, production of one of each drink takes %1$s. If only one kind of "
"drink is needed by the economy, production of one drink takes %2$s."
msgstr ""

#. TRANSLATORS: Purpose help text for a Gallic production site: Weaving Mill
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1741 input:1741 standard
msgctxt "gauls_building"
msgid "Weaves cloth out of wool."
msgstr ""

#. TRANSLATORS: Performance help text for a Gallic production site: Weaving Mill, the weaver is a female
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1743 input:1743 standard
msgctxt "gauls_building"
msgid "The weaver needs %1% to make one piece of cloth."
msgstr ""

#. TRANSLATORS: Purpose help text for a Gallic production site: Sewing Workshop
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1750 input:1750 standard
msgctxt "gauls_building"
msgid "Produces tunics."
msgstr ""

#. TRANSLATORS: Performance help text for a Gallic production site: Sewing Workshop, the dressmaker is a female
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1752 input:1752 standard
msgctxt "gauls_building"
msgid "The dressmaker needs %1% to sew one piece of clothing."
msgstr ""

#. TRANSLATORS: Purpose help text for a Gallic production site: Weapon Smithy
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1759 input:1759 standard
msgctxt "gauls_building"
msgid ""
"Produces spears for hunters and new warriors and swords for trainers and "
"attack training."
msgstr ""

#. TRANSLATORS: Performance help text for a Gallic production site: Weapon Smithy
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1761 input:1761 standard
msgctxt "gauls_building"
msgid ""
"If this building is fully supplied and both swords and spear are needed by "
"the economy, production of two spears, one short sword and one long sword "
"takes %1$s. If only one kind of sword or spear is needed by the economy, "
"production of one short sword takes %2$s, one long sword takes %3$s and one "
"spear takes %4$s."
msgstr ""

#. TRANSLATORS: Purpose help text for a Gallic production site: Armor Smithy
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1768 input:1768 standard
msgctxt "gauls_building"
msgid "Produces shields and armor."
msgstr ""

#. TRANSLATORS: Performance help text for a Gallic production site: Armor Smithy
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1770 input:1770 standard
msgctxt "gauls_building"
msgid ""
"If this building is fully supplied and there is a demand for all types of "
"armor, production of one of each items takes %1$s. If only one kind of armor "
"is needed, production of one bronze shield takes %2$s and production of any "
"other item takes %3$s."
msgstr ""

#. TRANSLATORS: Purpose help text for a Gallic production site: Barracks
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1777 input:1777 standard
msgctxt "gauls_building"
msgid "Equips recruits and trains them as warriors."
msgstr ""

#. TRANSLATORS: Performance help text for a Gallic production site: Barracks
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1779 input:1779 standard
#, lua-format
msgctxt "gauls_building"
msgid "The barracks need %s to recruit one warrior."
msgstr ""

#. TRANSLATORS: Purpose help text for a Gallic production site: Charcoal Kiln
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1786 input:1786 standard
msgctxt "gauls_building"
msgid "Burns logs into charcoal."
msgstr ""

#. TRANSLATORS: Performance help text for a Gallic production site: Charcoal Kiln
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1788 input:1788 standard
msgctxt "gauls_building"
msgid "The charcoal burner needs %1% to produce one lump of coal."
msgstr ""

#. TRANSLATORS: Purpose help text for a Gallic production site: Farm
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1797 input:1797 standard
msgctxt "gauls_building"
msgid "Sows wheat and harvests wheat sheaves."
msgstr ""

#. TRANSLATORS: Performance help text for a Gallic production site: Farm
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1799 input:1799 standard
msgctxt "gauls_building"
msgid ""
"The farmer sows and harvests one sheaf of wheat between %1$s and %2$s, "
"depending on how far he has to walk."
msgstr ""

#. TRANSLATORS: Purpose help text for a Gallic production site: Cattle Farm
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1806 input:1806 standard
msgctxt "gauls_building"
msgid ""
"Breeds strong oxen for adding them to the transportation system. Also keeps "
"cows for their milk and meat."
msgstr ""

#. TRANSLATORS: Note help text for a Gallic production site: Cattle Farm
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1808 input:1808 standard
msgctxt "gauls_building"
msgid ""
"Production of meat stops when economy doesn’t need meat or smoked meat, "
"production of both milk and meat stops when economy doesn’t need milk."
msgstr ""

#. TRANSLATORS: Performance help text for a Gallic production site: Cattle Farm
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1810 input:1810 standard
msgctxt "gauls_building"
msgid ""
"If this building is fully supplied and the economy needs all products, "
"breeding of two oxen, production of 2 jugs of milk and one piece of meat "
"takes %1$s. Production of one ox only takes %2$s, production of 2 jugs of "
"milk and one piece of meat takes %3$s and production of 2 jugs of milk only "
"takes %4$s."
msgstr ""

#. TRANSLATORS: Purpose help text for a Gallic production site: Sheep Farm
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1817 input:1817 standard
msgctxt "gauls_building"
msgid "Keeps sheep for their wool."
msgstr ""

#. TRANSLATORS: Performance help text for a Gallic production site: Sheep Farm
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1819 input:1819 standard
msgctxt "gauls_building"
msgid "The sheep farm needs %1% to produce one wool."
msgstr ""

