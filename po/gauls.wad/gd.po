#: addons/gauls.wad/tribes/gauls_tribe/units.lua:426 input:400 input:426
#: standard
msgctxt "gauls_ware"
msgid "It is produced by the furnaces."
msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Iron Ore, part 1
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:411 input:411 standard
msgctxt "ware"
msgid "Iron ore can be smelted into iron in a furnace."
msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Iron Ore, part 2
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:413 input:413 standard
msgctxt "gauls_ware"
msgid ""
"Your miners need rations or meals and in deep mines also potions to produce "
"it."
msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Iron, part 1
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:424 input:424 standard
msgctxt "ware"
msgid "Iron is needed for tool and weapon production."
msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Gold Ore, part 1
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:437 input:437 standard
msgctxt "ware"
msgid "Gold ore can be smelted into gold in the furnace."
msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Gold Ore, part 2
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:439 input:439 standard
msgctxt "gauls_ware"
msgid ""
"It is primarily obtained in the copper-gold mines, but miners in your copper "
"mines can usually find some too."
msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Gold, part 1
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:450 input:450 standard
msgctxt "ware"
msgid "Gold is needed for golden helmets. It is a rare building material too."
msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Gold, part 2
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:452 input:452 standard
msgctxt "gauls_ware"
msgid ""
"Gold is the most valuable of all metals and it is smelted out of gold ore in "
"furnaces."
msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Tin Ore, part 1
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:463 input:463 standard
msgctxt "ware"
msgid ""
"Tin ore can be smelted together with copper ore into bronze in a furnace."
msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Tin Ore, part 2
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:465 input:465 standard
msgctxt "gauls_ware"
msgid ""
"Your miners need rations and in deep mines meals with potion to produce it."
msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Bronze, part 1
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:476 input:476 standard
msgctxt "ware"
msgid ""
"Bronze is needed for armor production. It is a rare building material too."
msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Bronze, part 2
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:478 input:478 standard
msgctxt "gauls_ware"
msgid "It is smelted out of copper ore and tin ore in furnaces."
msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Felling Ax
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:492 input:492 standard
msgctxt "gauls_ware"
msgid ""
"The felling ax is the tool to cut down trees and is used by woodcutters."
msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Pick
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:503 input:503 standard
msgctxt "gauls_ware"
msgid "Picks are used by stonecutters and miners."
msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Shovel
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:514 input:514 standard
msgctxt "gauls_ware"
msgid "The shovel is an essential tool for six types of workers."
msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Hammer
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:525 input:525 standard
msgctxt "gauls_ware"
msgid ""
"The hammer is a widely used tool. Geologists, builders, shipwrights and "
"craftsmen, they all need hammer."
msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Scythe, part 1
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:536 input:536 standard
msgctxt "ware"
msgid "The scythe is the tool of farmers."
msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Scythe, part 2
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:538 input:538 standard
msgctxt "gauls_ware"
msgid "You need it to harvest wheat and reed."
msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Kitchen Tools, part 1
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:549 input:549 standard
msgctxt "gauls_ware"
msgid "Kitchen tools are used by cooks and bakers."
msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Kitchen Tools, part 2
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:551 input:551 standard
msgctxt "gauls_ware"
msgid "You need them to produce rations, meals, smoked meat or fish and bread."
msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Fire Tongs
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:562 input:562 standard
msgctxt "gauls_ware"
msgid "Fire tongs are the tools for smelting ores."
msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Buckets
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:573 input:573 standard
msgctxt "gauls_ware"
msgid ""
"Buckets are used by water carriers, breeders and together with a shovel by "
"clay diggers and brick makers."
msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Fishing Net
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:584 input:584 standard
msgctxt "gauls_ware"
msgid "Fishing net is used by fishers to catch fishes."
msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Basket
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:595 input:595 standard
msgctxt "gauls_ware"
msgid ""
"Basket is used together with a shovel by gardener and together with a flail "
"by toiler."
msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Flail
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:606 input:606 standard
msgctxt "gauls_ware"
msgid "Flail is used together with basket by toilers in the threshing floor."
msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Elixir, part 1
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:620 input:620 standard
msgctxt "gauls_ware"
msgid "Elixir is a magical drink that makes your warriors perform much better."
msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Elixir, part 2
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:622 input:622 standard
msgctxt "gauls_ware"
msgid ""
"Notice that for elixir preparation you actually need two doses of fruit "
"because the druid picks some secret ingredients before its preparation by "
"himself."
msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Elixir, part 3
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:624 input:624 standard
msgctxt "gauls_ware"
msgid ""
"It is consumed at the training sites (druid’s gatherings, training camps)."
msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Potion, part 1
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:635 input:635 standard
msgctxt "gauls_ware"
msgid ""
"Potion is a magical drink that makes your warriors and miners perform much "
"better."
msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Potion, part 2
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:637 input:637 standard
msgctxt "gauls_ware"
msgid "It is consumed at advanced mines and at the training sites (arenas)."
msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Spear
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:647 input:647 standard
msgctxt "gauls_ware"
msgid "Spear is a widely used weapon for hunters and new warriors."
msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Tunic, part 1
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:657 input:657 standard
msgctxt "gauls_ware"
msgid ""
"A basic piece of clothing for your new warriors, trainers, druids and scouts."
msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Tunic, part 2
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:659 input:659 standard
msgctxt "gauls_ware"
msgid ""
"It is also used for defense training under every new chain and bronze armor."
msgstr ""

