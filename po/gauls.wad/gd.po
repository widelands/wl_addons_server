#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1602 input:1602 standard
msgctxt "gauls_building"
msgid ""
"Burns bricks using granite and clay, and coal as fuel. Bricks are an "
"important building material."
msgstr ""

