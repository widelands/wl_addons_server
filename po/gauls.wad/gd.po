msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Long Sword
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:682 input:682 standard
msgctxt "gauls_ware"
msgid ""
"Long sword is produced in the weapon smithy and used at the training camp – "
"together with meal and elixir – to train warriors from attack level 1 to "
"level 2."
msgstr ""

#. TRANSLATORS: Help text for a Gallic ware: Chain Armor
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:691 input:691 standard
msgctxt "gauls_ware"
msgid ""
"This basic armor is produced in the armor smithy and used at the arena – "
