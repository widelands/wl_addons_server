#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1556 input:1556 standard
msgctxt "gauls_building"
msgid "The hunter’s hut needs animals to hunt within the work area."
msgstr ""

#. TRANSLATORS: Performance help text for a Gallic production site: Hunter’s Hut, part 1
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1559 input:1559 standard
msgctxt "gauls_building"
msgid ""
"This building can produce one meat between %1$s and %2$s, depending on how "
"far the hunter has to walk."
msgstr ""

#. TRANSLATORS: Purpose help text for a Gallic production site: Scout’s Cottage
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1569 input:1569 standard
msgctxt "building"
msgid "Explores unknown territory."
msgstr ""

#. TRANSLATORS: Performance help text for a Gallic production site: Scout’s Cottage, part 1
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1572 input:1572 standard
msgctxt "gauls_building"
msgid "One exploration trip of the scout takes between %1$s and %2$s."
msgstr ""

#. TRANSLATORS: Purpose help text for a Gallic production site: Workshop
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1584 input:1584 standard
msgctxt "gauls_building"
msgid "Forges the tools that your workers need."
msgstr ""

#. TRANSLATORS: Performance help text for a Gallic production site: Workshop
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1586 input:1586 standard
msgctxt "gauls_building"
msgid ""
"If this building is fully supplied and all produced items are needed by the "
"economy, production of one of each item takes %1$s. If only one kind of item "
"is needed by the economy, its production takes %2$s."
msgstr ""

#. TRANSLATORS: Purpose help text for a Gallic production site: Sawmill
#: addons/gauls.wad/tribes/gauls_tribe/units.lua:1593 input:1593 standard
