msgid "The whole map"
msgstr "The whole map"

#: input:4 screenshots/Down_the_Mountain.wad/descriptions:4 standard
msgid "Use ferries and ships wisely"
msgstr "Use ferries and ships wisely"

#: input:7 input:11 standard
msgid ""
"Consider using ferries to bypass long transportation of wares and ships to "
"shorten the ways for soldiers. Ai works but is slow in the beginning."
msgstr ""
"Consider using ferries to bypass long transportation of wares and ships to "
"shorten the ways for soldiers. Ai works but is slow in the beginning."
