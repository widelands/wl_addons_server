#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1378
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1720 input:1378
#: input:1720 standard
msgctxt "sumatran_building"
msgid "Needs water nearby."
msgstr "Necessita estar prop de l'aigua."

#. TRANSLATORS: Performance helptext for a Sumatran production site: Water Carrier’s Hut, part 1
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1381 input:1381
#: standard
msgctxt "sumatran_building"
msgid ""
"The reedcutter can produce one bundle of reed between %1$s and %2$s on "
"average, depending on how far he has to walk."
msgstr ""
"El tallador de canyes pot produir un paquet de canyes entre %1$s i %2$s de "
"mitjana, depenent de la distància que hagi de caminar."

#. TRANSLATORS: Purpose helptext for a Sumatran production site: Basic Workshop
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1391 input:1391
#: standard
msgctxt "sumatran_building"
msgid "Produces sandedwood, diamonds and whetstones."
msgstr "Produeix fusta de sorra, diamants i pedres d'amolar."

#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1392 input:1392
#: standard
msgctxt "sumatran_building"
msgid ""
"The craftsman needs %1% to produce sanded wood, %2% to polish one diamond or "
"%3% to produce whetstones."
msgstr ""
"L'artesà necessita un 1% per produir fusta polida, un 2% per polir un "
"diamant o un 3% per produir pedres d'esmolar."

#. TRANSLATORS: Purpose helptext for a Sumatran production site: Tools Workshop
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1399 input:1399
#: standard
msgctxt "sumatran_building"
msgid "Forges the tools that your workers need."
msgstr "Forja les eines que necessiten els vostres treballadors."

#. TRANSLATORS: Note helptext for a Sumatran production site: Tools Workshop
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1401 input:1401
#: standard
msgctxt "sumatran_building"
msgid ""
"Notice that the building needs an experienced worker. If you don’t have any, "
"your worker needs to gain some experience by working in a basic workshop for "
"some period of time."
msgstr ""
"Tingueu en compte que l'edifici necessita un treballador amb experiència. Si "
"no en teniu, el vostre treballador ha d'aconseguir una mica d'experiència "
"treballant en un taller bàsic durant un període de temps."

#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1402 input:1402
#: standard
msgctxt "sumatran_building"
msgid "The experienced craftsman needs %1% on average to make one tool."
msgstr "L'artesà experimentat necessita un 1% de mitjana per fer una eina."

#. TRANSLATORS: Purpose helptext for a Sumatran production site: Weapons Workshop
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1409 input:1409
#: standard
msgctxt "sumatran_building"
msgid "Produces spears for hunters, warriors and hunting camps."
msgstr "Produeix llances per a caçadors, guerrers i campaments de caça."

#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1410 input:1410
#: standard
msgctxt "sumatran_building"
msgid "The experienced craftsman needs %1% on average to make one spear."
msgstr "L'artesà experimentat necessita un 1% de mitjana per fer una llança."

#. TRANSLATORS: Purpose helptext for a Sumatran production site: Coppersmith’s House
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1417 input:1417
#: standard
msgctxt "sumatran_building"
msgid "Produces copper sheets and gold sheets."
msgstr "Produeix làmines de coure i làmines d'or."

#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1418 input:1418
#: standard
msgctxt "sumatran_building"
msgid ""
"The coppersmith needs %1% to produce one copper sheet or %2% to produce one "
"gold sheet."
msgstr ""
"El courer necessita un 1% per produir una làmina de coure o un 2% per "
"produir una làmina d'or."

#. TRANSLATORS: Purpose helptext for a Sumatran production site: Armorsmithy
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1425 input:1425
#: standard
msgctxt "sumatran_building"
msgid "Produces shields and armor."
msgstr "Produeix escuts i armadures."

#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1426 input:1426
#: standard
msgctxt "sumatran_building"
msgid "The armorsmith needs %1% on average to make one piece of armor."
msgstr "L'armer necessita un 1% de mitjana per fer una peça d'armadura."

#. TRANSLATORS: Purpose helptext for a Sumatran production site: Winery
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1433 input:1433
#: standard
msgctxt "sumatran_building"
msgid "Produces palm wine."
msgstr "Produeix vi de palma."

#. TRANSLATORS: Note helptext for a Sumatran production site: Winery
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1435 input:1435
#: standard
msgctxt "sumatran_building"
msgid "The worker needs old palms around his house."
msgstr "El treballador necessita palmeres velles al voltant de casa."

#. TRANSLATORS: Performance helptext for a Sumatran production site: Winery, part 1
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1438 input:1438
#: standard
msgctxt "sumatran_building"
msgid ""
"The winemaker can produce one bucket of wine between %1$s and %2$s on "
"average, depending on how far she has to walk."
msgstr ""
"L'enòleg pot produir una galleda de vi entre %1$s i %2$s de mitjana, "
"depenent de la distància que hagi de caminar."

#. TRANSLATORS: Purpose helptext for a Sumatran production site: Cassava Kitchen
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1448 input:1448
#: standard
msgctxt "sumatran_building"
msgid "Produces starch."
msgstr "Produeix midó."

#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1449 input:1449
#: standard
msgctxt "sumatran_building"
msgid "The cook needs %1% on average to cook 3 portions of starch."
msgstr "El cuiner necessita un 1% de mitjana per cuinar 3 porcions de midó."

#. TRANSLATORS: Purpose helptext for a Sumatran production site: Kitchen
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1456 input:1456
#: standard
msgctxt "sumatran_building"
msgid "Produces meal."
msgstr "Produeix menjar."

#. TRANSLATORS: Note helptext for a Sumatran production site: Kitchen
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1458 input:1458
#: standard
msgctxt "sumatran_building"
msgid ""
"Make sure you have cassava leaves or eggs on stock while meal is needed. "
"Otherwise your cook will start to throw out starch as food waste for your "
"chicken farms."
msgstr ""
"Assegureu-vos de tenir fulles de mandioca o ous en brou mentre necessiteu "
"menjar. En cas contrari, el vostre cuiner començarà a llençar midó com a "
"residu d'aliments per a les vostres granges de pollastres."

#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1459 input:1459
#: standard
msgctxt "sumatran_building"
msgid ""
"The cook needs %1% on average to prepare two meals. If there is not enough "
"cassava leaves or eggs for a meal, he throws out 2 bags of food waste in the "
"same amount of time."
msgstr ""
"El cuiner necessita un 1% de mitjana per preparar dos àpats. Si no hi ha "
"prou fulles de mandioca o ous per menjar, llença 2 bosses de residus "
"alimentaris en el mateix temps."

#. TRANSLATORS: Purpose helptext for a Sumatran production site: Sewing Workshop
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1466 input:1466
#: standard
msgctxt "sumatran_building"
msgid "Produces clothing."
msgstr "Produeix roba."

#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1467 input:1467
#: standard
msgctxt "sumatran_building"
msgid "The dressmaker needs %1% to sew one piece of clothing."
msgstr "La modista necessita %1% per cosir una peça de roba."

#. TRANSLATORS: Purpose helptext for a Sumatran production site: Furnace
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1474 input:1474
#: standard
msgctxt "sumatran_building"
msgid "Smelts ore into iron, copper and gold."
msgstr "Fona el mineral en ferro, coure i or."

#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1475 input:1475
#: standard
msgctxt "sumatran_building"
msgid ""
"The smelter needs %1% to produce one iron ingot, %2% to produce one copper "
"ingot or %3% to produce one gold bar."
msgstr ""
"La fosa necessita un 1% per produir un lingot de ferro, un 2% per produir un "
"lingot de coure o un 3% per produir una barra d'or."

#. TRANSLATORS: Purpose helptext for a Sumatran production site: Charcoal Kiln
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1482 input:1482
#: standard
msgctxt "sumatran_building"
msgid "Burns logs into charcoal."
msgstr "Crema troncs per fer-ne carbó vegetal."

#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1483 input:1483
#: standard
msgctxt "sumatran_building"
msgid "The charcoal burner needs %1% to produce one lump of coal."
msgstr "El cremador de carbó necessita un 1% per produir un tros de carbó."

#. TRANSLATORS: Purpose helptext for a Sumatran production site: Tribal Gathering, part 1
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1491 input:1491
#: standard
msgctxt "sumatran_building"
msgid "Recruits warriors, hunters, chiefs and carriers."
msgstr "Recluta guerrers, caçadors, caps i portadors."

#. TRANSLATORS: Purpose helptext for a Sumatran production site: Tribal Gathering, part 2
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1493 input:1493
#: standard
msgctxt "sumatran_building"
msgid "Equips the recruits with all necessary weapons and clothing."
msgstr "Equipa els reclutes amb totes les armes i roba necessàries."

#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1495 input:1495
#: standard
msgctxt "sumatran_building"
msgid ""
"The tribal chief needs %1% to recruit one soldier, to train one hunter or a "
"new chief and %2% to gain one carrier."
msgstr ""
"El cap tribal necessita el %1% per reclutar un soldat, entrenar un caçador o "
"un nou cap i el %2% per guanyar un portador."

