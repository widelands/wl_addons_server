#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1604
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1614 input:1604
#: input:1614 standard
msgctxt "sumatran_building"
msgid "Digs raw diamonds and granite out of the ground in mountain terrain."
msgstr "Excava diamants en brut i granit del sòl en terrenys de muntanya."

#. TRANSLATORS: Note helptext for a Sumatran production site: Stone Mine
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1606 input:1606
#: standard
msgctxt "sumatran_building"
msgid ""
"In comparison to a deep mine, production of this mine is quicker but more "
"expensive. The mine has two programs. When economy doesn’t need raw "
"diamonds, the miners don’t bother by searching them."
msgstr ""
"En comparació amb una mina profunda, la producció d'aquesta mina és més "
"ràpida però més cara. La mina té dos programes. Quan l'economia no necessita "
"diamants en brut, els miners no es molesten a buscar-los."

#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1607 input:1607
#: standard
msgctxt "sumatran_building"
msgid ""
"The miner needs %1% on average to produce one piece of granite or raw "
"diamond."
msgstr ""
"El miner necessita un 1% de mitjana per produir una peça de granit o diamant "
"en brut."

#. TRANSLATORS: Note helptext for a Sumatran production site: Deep Stone Mine
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1616 input:1616
#: standard
msgctxt "sumatran_building"
msgid ""
"In comparison to a basic mine, production of this mine is slower. The mine "
"has two programs. When economy doesn’t need raw diamonds, the miners don’t "
"bother by searching them."
msgstr ""
"En comparació amb una mina bàsica, la producció d'aquesta mina és més lenta. "
"La mina té dos programes. Quan l'economia no necessita diamants en brut, els "
"miners no es molesten a buscar-los."

#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1617 input:1617
#: standard
msgctxt "sumatran_building"
msgid ""
"The miners need %1% on average to produce one piece of granite or raw "
"diamond."
msgstr ""
"Els miners necessiten un 1% de mitjana per produir una peça de granit o "
"diamant en brut."

#. TRANSLATORS: Purpose helptext for a Sumatran training site: Training Camp, part 1
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1627 input:1627
#: standard
msgctxt "sumatran_building"
msgid "Trains warriors in ‘Evade’, ‘Defense’ and ‘Health’."
msgstr "Entrena guerrers a \"Evadir\", \"Defensa\" i \"Salut\"."

#. TRANSLATORS: Purpose helptext for a Sumatran training site: Training Camp, part 2
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1629 input:1629
#: standard
msgctxt "sumatran_building"
msgid "Equips the warriors with all necessary armor parts and weapons."
msgstr ""
"Equipa els guerrers amb totes les peces d'armadura i armes necessàries."

#. TRANSLATORS: Performance helptext for a Sumatran training site: Training Camp, part 1
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1633 input:1633
#: standard
#, lua-format
msgctxt "sumatran_building"
msgid ""
"If all needed wares are delivered in time, a training camp can train one "
"soldier one level in evade, defense or health in %s."
msgstr ""
"Si totes les mercaderies necessàries es lliuren a temps, un camp "
"d'entrenament pot entrenar un soldat d'un nivell en evasió, defensa o salut "
"a %s."

#. TRANSLATORS: Performance helptext for a Sumatran training site: Training Camp, part 2
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1635 input:1635
#: standard
#, lua-format
msgctxt "sumatran_building"
msgid "Complete training of one soldier takes %s."
msgstr "L'entrenament complet d'un soldat requereix %s."

#. TRANSLATORS: Purpose helptext for a Sumatran training site: Hunting Camp
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1643 input:1643
#: standard
msgctxt "sumatran_building"
msgid "Trains warriors in ‘Attack’."
msgstr "Entrena guerrers a \"Atac\"."

#. TRANSLATORS: Note helptext for a Sumatran training site: Hunting Camp
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1645 input:1645
#: standard
msgctxt "sumatran_building"
msgid ""
"The warriors improve their attack abilities by hunting crocodiles. Make sure "
"there is enough tropical swamps around the building."
msgstr ""
"Els guerrers milloren les seves habilitats d'atac caçant cocodrils. "
"Assegureu-vos que hi hagi prou pantans tropicals al voltant de l'edifici."

#. TRANSLATORS: Performance helptext for a Sumatran training site: Hunting Camp, part 1
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1648 input:1648
#: standard
msgctxt "sumatran_building"
msgid ""
"If all needed wares are delivered in time, a hunting camp needs between %1$s "
"and %2$s to train one soldier one level in attack, depending on how far the "
"hunter has to walk."
msgstr ""
"Si totes les mercaderies necessàries s'entreguen a temps, un campament de "
"caça necessita entre %1$s i %2$s per entrenar un soldat un nivell en atac, "
"depenent de la distància que hagi de caminar el caçador."

#. TRANSLATORS: Performance helptext for a Sumatran training site: Hunting Camp, part 3
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1652 input:1652
#: standard
#, lua-format
msgctxt "sumatran_building"
msgid "Complete training of one soldier takes %s on average."
msgstr "L'entrenament complet d'un soldat requereix %s de mitjana."

