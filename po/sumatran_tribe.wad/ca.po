#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:866 input:866
#: standard
msgctxt "sumatran_worker"
msgid "Dressmaker is an experienced weaver and produces clothing."
msgstr "La modista és una teixidora experimentada i produeix roba."

