#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1564
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1574 input:1564
#: input:1574 standard
msgctxt "sumatran_building"
msgid "Digs iron ore out of the ground in mountain terrain."
msgstr "Excava mineral de ferro del sòl en terrenys de muntanya."

#. TRANSLATORS: Note helptext for a Sumatran production site: Iron Mine
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1566 input:1566
#: standard
msgctxt "sumatran_building"
msgid ""
"In comparison to a deep mine, production of this mine is quicker but more "
"expensive."
msgstr ""
"En comparació amb una mina profunda, la producció d'aquesta mina és més "
"ràpida però més cara."

#. TRANSLATORS: Note helptext for a Sumatran production site: Deep Iron Mine
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1576 input:1576
#: standard
msgctxt "sumatran_building"
msgid ""
"In comparison to a basic mine, production of this mine is slower but cheaper."
msgstr ""
"En comparació amb una mina bàsica, la producció d'aquesta mina és més lenta "
"però més barata."

#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1577
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1597 input:1577
#: input:1597 standard
msgctxt "sumatran_building"
msgid "The miners need %1% on average to produce one piece of ore."
msgstr ""
"Els miners necessiten un 1% de mitjana per produir una peça de mineral."

