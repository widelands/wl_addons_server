#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1504
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1514 input:1504
#: input:1514 standard
msgctxt "sumatran_building"
msgid "Grows cassava for roots and leaves."
msgstr "Cultiva la mandioca per a arrels i fulles."

#. TRANSLATORS: Note helptext for a Sumatran production site: Cassava Fields
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1506 input:1506
#: standard
msgctxt "sumatran_building"
msgid ""
"The farmer harvest one cassava root from every field. The remained leaves "
"can be harvested by leaf gatherer."
msgstr ""
"El pagès cull una arrel de mandioca de cada camp. Les fulles restants es "
"poden collir amb un recol·lector de fulles."

#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1507 input:1507
#: standard
msgctxt "sumatran_building"
msgid ""
"The inexperienced resp. experienced farmer needs %1% resp. %2% on average to "
"produce one cassava root."
msgstr ""
"Els inexperts resp. agricultor experimentat necessita %1% resp. %2% de "
"mitjana per produir una arrel de mandioca."

#. TRANSLATORS: Note helptext for a Sumatran production site: Cassava Plantation
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1516 input:1516
#: standard
msgctxt "sumatran_building"
msgid ""
"Thanks to watering, the farmer harvests two roots from every field. "
"Unfortunately, the amount of leaves left remains unchanged and leaf gatherer "
"can pick up one bundle of leaves from every harvested field."
msgstr ""
"Gràcies al reg, el pagès recull dues arrels de cada camp. Malauradament, la "
"quantitat de fulles que queden no canvia i el recol·lector de fulles pot "
"recollir un paquet de fulles de cada camp collit."

#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1517 input:1517
#: standard
msgctxt "sumatran_building"
msgid "The farmer needs %1% on average to produce one cassava root."
msgstr ""
"L'agricultor necessita un 1% de mitjana per produir una arrel de mandioca."

#. TRANSLATORS: Purpose helptext for a Sumatran production site: Chicken Farm
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1524 input:1524
#: standard
msgctxt "sumatran_building"
msgid "Breeds chickens for eggs and meat."
msgstr "Cria gallines per a ous i carn."

#. TRANSLATORS: Note helptext for a Sumatran production site: Chicken Farm
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1526 input:1526
#: standard
msgctxt "sumatran_building"
msgid ""
"The production of eggs is divided into two cycles. In first one only eggs "
"are produced, in second one, you gain eggs and meat."
msgstr ""
"La producció d'ous es divideix en dos cicles. En el primer només es "
"produeixen ous, en el segon, guanyen ous i carn."

#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1527 input:1527
#: standard
msgctxt "sumatran_building"
msgid "The breeder needs %1% on average to produce one basket of eggs or meat."
msgstr ""
"El criador necessita un 1% de mitjana per produir una cistella d'ous o carn."

#. TRANSLATORS: Purpose helptext for a Sumatran production site: Weaving Mill
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1534 input:1534
#: standard
msgctxt "sumatran_building"
msgid "Weaves cloth out of reed and palm leaves."
msgstr "Teixeix tela amb canya i fulles de palmera."

#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1535 input:1535
#: standard
msgctxt "sumatran_building"
msgid "The weaver needs %1% on average to make one piece of cloth."
msgstr "El teixidor necessita un 1% de mitjana per fer una peça de tela."

#. TRANSLATORS: Purpose helptext for a Sumatran production site: Tropical Swamp
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1542 input:1542
#: standard
msgctxt "sumatran_building"
msgid ""
"Home to tropical animals. Source of meat and crocodile skin for your hunters."
msgstr ""
"La llar dels animals tropicals. Font de carn i pell de cocodril per als teus "
"caçadors."

#. TRANSLATORS: Note helptext for a Sumatran production site: Tropical Swamp
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1544 input:1544
#: standard
msgctxt "sumatran_building"
msgid ""
"If animals don’t leave a swamp, you have probably built too many roads "
"around the swamp. Roads can block the way for animals to leave. Out of 4 "
"animals leaving the swamp, there is one crocodile. When economy doesn’t need "
"meat, the ratio is 2 animals to one crocodile."
msgstr ""
"Si els animals no surten d'un pantà, probablement heu construït massa "
"carreteres al voltant del pantà. Les carreteres poden bloquejar el pas als "
"animals. De 4 animals que surten del pantà, hi ha un cocodril. Quan "
"l'economia no necessita carn, la proporció és de 2 animals per un cocodril."

#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1545 input:1545
#: standard
msgctxt "sumatran_building"
msgid ""
"If your economy needs meat, there is one animal leaving the swamp in %1% on "
"average. Otherwise it takes %2%."
msgstr ""
"Si la vostra economia necessita carn, hi ha un animal que surt del pantà en "
"un 1% de mitjana. En cas contrari, es necessita el %2%."

#. TRANSLATORS: Purpose helptext for a Sumatran production site: Coal Mine
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1554 input:1554
#: standard
msgctxt "sumatran_building"
msgid "Digs coal out of the ground in mountain terrain."
msgstr "Excava carbó del sòl en terrenys de muntanya."

#. TRANSLATORS: Note helptext for a Sumatran production site: Coal Mine
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1556 input:1556
#: standard
msgctxt "sumatran_building"
msgid ""
"This mine can’t be enhanced. You can use it as an alternative to your "
"charcoal burners, when you have enough meal or lack of wood."
msgstr ""
"Aquesta mina no es pot millorar. Podeu utilitzar-lo com a alternativa als "
"vostres carboners, quan tingueu prou menjar o manca de llenya."

#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1557
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1567
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1587 input:1557
#: input:1567 input:1587 standard
msgctxt "sumatran_building"
msgid "The miner needs %1% on average to produce one piece of ore."
msgstr "El miner necessita un 1% de mitjana per produir una peça de mineral."

