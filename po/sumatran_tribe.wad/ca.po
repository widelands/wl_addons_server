#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:815 input:815
#: standard
msgctxt "sumatran_worker"
msgid "Produces sanded wood, whetstones and polished diamonds."
msgstr "Produeix fusta polida, pedres d'esmolar i diamants polits."

