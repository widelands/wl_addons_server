#. Translation for adaptation of a classical Latin quote:
#. "Hic sunt crocodili."
#: addons/sumatran_tribe.wad/postload.lua:229 input:229 standard
msgid "Here be crocodiles."
msgstr "Aquí hi ha cocodrils."

