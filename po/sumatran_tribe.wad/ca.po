#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:338
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:364
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:390 input:338
#: input:364 input:390 standard
msgctxt "sumatran_ware"
msgid "Your miners need meals and in deep mines also palm wine to produce it."
msgstr ""
"Els vostres miners necessiten àpats i a les mines profundes també el vi de "
"palma per produir-lo."

#. TRANSLATORS: Helptext for a Sumatran ware: Copper, part 1
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:349 input:349
#: standard
msgctxt "sumatran_ware"
msgid ""
"Copper is needed for armor production. It is a rare building material too."
msgstr ""
"El coure és necessari per a la producció d'armadures. També és un material "
"de construcció rar."

