#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:905 input:905
#: standard
msgid ""
"Palm leaves can be picked up by a leaf gatherer and used as building "
"material and for weaving cloth."
msgstr ""
"Les fulles de palmera es poden recollir amb un recol·lector de fulles i "
"utilitzar-les com a material de construcció i per teixir draps."

