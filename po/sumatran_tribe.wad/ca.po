#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:531
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:542 input:531
#: input:542 standard
msgctxt "sumatran_ware"
msgid "Source material for armor production."
msgstr "Material d'origen per a la producció d'armadures."

#. TRANSLATORS: Helptext for a Sumatran ware: Spear
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:552 input:552
#: standard
msgctxt "sumatran_ware"
msgid "Spear is a widely used weapon for hunters and warriors."
msgstr "La llança és una arma molt utilitzada per als caçadors i guerrers."

#. TRANSLATORS: Helptext for a Sumatran ware: Crocodile Jacket
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:561 input:561
#: standard
msgctxt "sumatran_ware"
msgid "A basic piece of clothing for your warriors, hunters and chiefs."
msgstr "Una peça de roba bàsica per als teus guerrers, caçadors i caps."

#. TRANSLATORS: Helptext for a Sumatran ware: Warrior's Dress
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:570 input:570
#: standard
msgctxt "sumatran_ware"
msgid ""
"The warriors dress is an ideal type clothing for warriors. It is produced in "
"a sewing workshop and used in a training camp – together with meal and palm "
"wine – to ensure that the warrior’s health will be on the highest level."
msgstr ""
"El vestit de guerrers és un tipus de roba ideal per als guerrers. Es "
"produeix en un taller de costura i s'utilitza en un camp d'entrenament, "
"juntament amb menjar i vi de palma, per garantir que la salut del guerrer "
"estigui al màxim nivell."

#. TRANSLATORS: Helptext for a Sumatran ware: Crocodile Shoes
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:579 input:579
#: standard
msgctxt "sumatran_ware"
msgid ""
"This shoes are produced in a sewing workshop and used in a training camp – "
"together with meal and palm wine – to train soldiers in evade. Scouts wear "
"this type of shoes too."
msgstr ""
"Aquestes sabates es produeixen en un taller de costura i s'utilitzen en un "
"camp d'entrenament, juntament amb menjar i vi de palma, per entrenar soldats "
"en l'evasió. Els escoltes també porten aquest tipus de sabates."

#. TRANSLATORS: Helptext for a Sumatran ware: Copper Armor
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:588 input:588
#: standard
msgctxt "sumatran_ware"
msgid ""
"The copper armor is a basic defense tool for warriors. It is produced in an "
"armorsmithy and used in a training camp – together with meal and palm wine – "
"to train warriors in defense."
msgstr ""
"L'armadura de coure és una eina de defensa bàsica per als guerrers. Es "
"produeix en una armeria i s'utilitza en un camp d'entrenament, juntament amb "
"menjar i vi de palma, per entrenar guerrers en defensa."

#. TRANSLATORS: Helptext for a Sumatran ware: Golden Armor
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:597 input:597
#: standard
msgctxt "sumatran_ware"
msgid ""
"The golden armor is an improved defense tool for warriors. It is produced in "
"an armorsmithy and used in a training camp – together with meal and palm "
"wine – to train warriors in defense."
msgstr ""
"L'armadura daurada és una eina de defensa millorada per als guerrers. Es "
"produeix en una armeria i s'utilitza en un camp d'entrenament, juntament amb "
"menjar i vi de palma, per entrenar guerrers en defensa."

#. TRANSLATORS: Helptext for a Sumatran ware: Golden Shield
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:606 input:606
#: standard
msgctxt "sumatran_ware"
msgid ""
"The golden shield is the most efficient defense tool for warriors. It is "
"produced in an armorsmithy and used in a training camp – together with meal "
"and palm wine – to train warriors in defense."
msgstr ""
"L'escut daurat és l'eina de defensa més eficient per als guerrers. Es "
"produeix en una armeria i s'utilitza en un camp d'entrenament, juntament amb "
"menjar i vi de palma, per entrenar guerrers en defensa."

