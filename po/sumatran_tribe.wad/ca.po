#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:618
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:627 input:618
#: input:627 standard
msgctxt "sumatran_worker"
msgid "Carries items along roads."
msgstr "Porta objectes per les carreteres."

#. TRANSLATORS: Helptext for a Sumatran worker: Ferry
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:634 input:634
#: standard
msgctxt "sumatran_worker"
msgid "Ships wares across narrow rivers and straights."
msgstr "Envia mercaderies a través de rius estrets i rectes."

#. TRANSLATORS: Helptext for a Sumatran worker: Recruit
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:641 input:641
#: standard
msgctxt "sumatran_worker"
msgid "Eager to become a soldier and defend his tribe!"
msgstr "Amb ganes de convertir-se en soldat i defensar la seva tribu!"

#. TRANSLATORS: Helptext for a Sumatran worker: Breeder
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:648 input:648
#: standard
msgctxt "sumatran_worker"
msgid "Breeds animals."
msgstr "Cria animals."

#. TRANSLATORS: Helptext for a Sumatran worker: Scout
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:655 input:655
#: standard
msgctxt "sumatran_worker"
msgid "Explores territory of your enemy."
msgstr "Explora el territori del teu enemic."

#. TRANSLATORS: Helptext for a Sumatran worker: Jungle Ghost
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:662 input:662
#: standard
msgctxt "sumatran_worker"
msgid "Gives life to the tropical animals and dwells in thermal springs."
msgstr "Dóna vida als animals tropicals i habita a les aigües termals."

#. TRANSLATORS: Helptext for a Sumatran worker: Stonecutter
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:672 input:672
#: standard
msgctxt "sumatran_worker"
msgid "Mines stone."
msgstr "Mines de pedra."

#. TRANSLATORS: Helptext for a Sumatran worker: Woodcutter
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:679 input:679
#: standard
msgctxt "sumatran_worker"
msgid "Fells trees."
msgstr "Talla arbres."

#. TRANSLATORS: Helptext for a Sumatran worker: Forester
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:686 input:686
#: standard
msgctxt "sumatran_worker"
msgid "Plants trees."
msgstr "Planta arbres."

#. TRANSLATORS: Helptext for a Sumatran worker: Reedcutter
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:693 input:693
#: standard
msgctxt "sumatran_worker"
msgid "Grows reed."
msgstr "Creix canya."

#. TRANSLATORS: Helptext for a Sumatran worker: Leaf Gatherer
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:700 input:700
#: standard
msgctxt "sumatran_worker"
msgid "Collects palm and cassava leaves."
msgstr "Recull fulles de palmera i mandioca."

#. TRANSLATORS: Helptext for a Sumatran worker: Shipwright
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:707 input:707
#: standard
msgctxt "sumatran_worker"
msgid "Works at the shipyard and constructs new ships."
msgstr "Treballa a la drassana i construeix nous vaixells."

#. TRANSLATORS: Helptext for a Sumatran worker: Builder
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:714 input:714
#: standard
msgctxt "sumatran_worker"
msgid "Works at construction sites to raise new buildings."
msgstr "Treballs en obres per aixecar nous edificis."

#. TRANSLATORS: Helptext for a Sumatran worker: Water Carrier
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:724 input:724
#: standard
msgctxt "sumatran_worker"
msgid "Carries water."
msgstr "Porta aigua."

#. TRANSLATORS: Helptext for a Sumatran worker: Hunter
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:733 input:733
#: standard
msgctxt "sumatran_worker"
msgid "Produces meat and fish."
msgstr "Produeix carn i peix."

#. TRANSLATORS: Helptext for a Sumatran worker: Chief Hunter
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:742 input:742
#: standard
msgctxt "sumatran_worker"
msgid "Produces meat, fish and crocodile skin."
msgstr "Produeix carn, peix i pell de cocodril."

