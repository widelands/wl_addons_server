#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:834 input:834
#: standard
msgctxt "sumatran_worker"
msgid "Defend and Conquer!"
msgstr "Defensa i venç!"

#. TRANSLATORS: Helptext for a Sumatran worker: Chief
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:843 input:843
#: standard
msgctxt "sumatran_worker"
msgid "Trains warriors."
msgstr "Entrena guerrers."

#. TRANSLATORS: Helptext for a Sumatran worker: Tribal Chief
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:852 input:852
#: standard
msgctxt "sumatran_worker"
msgid ""
"Trains and recruits warriors. Recruits hunters, new chiefs and carriers too."
msgstr ""
"Entrena i recluta guerrers. També recluta caçadors, nous caps i portadors."

#. TRANSLATORS: Helptext for a Sumatran worker: Weaver
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:859 input:859
#: standard
msgctxt "sumatran_worker"
msgid "Weaves cloth."
msgstr "Teixeix tela."

