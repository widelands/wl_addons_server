#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:351
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:377 input:351
#: input:377 standard
msgctxt "sumatran_ware"
msgid "It is produced by the furnaces."
msgstr "Es produeix pels forns."

#. TRANSLATORS: Helptext for a Sumatran ware: Iron Ore, part 1
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:362 input:362
#: standard
msgctxt "ware"
msgid "Iron ore can be smelted into iron in a furnace."
msgstr "El mineral de ferro es pot fondre en ferro en un forn."

#. TRANSLATORS: Helptext for a Sumatran ware: Iron, part 1
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:375 input:375
#: standard
msgctxt "ware"
msgid "Iron is needed for tool and weapon production."
msgstr "El ferro és necessari per a la producció d'eines i armes."

#. TRANSLATORS: Helptext for a Sumatran ware: Gold Ore, part 1
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:388 input:388
#: standard
msgctxt "ware"
msgid "Gold ore can be smelted into gold in a furnace."
msgstr "El mineral d'or es pot fondre en or en un forn."

#. TRANSLATORS: Helptext for a Sumatran ware: Gold, part 1
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:401 input:401
#: standard
msgctxt "ware"
msgid ""
"Gold is needed for armor production. It is a rare building material too."
msgstr ""
"L'or és necessari per a la producció d'armadures. També és un material de "
"construcció rar."

#. TRANSLATORS: Helptext for a Sumatran ware: Gold, part 2
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:403 input:403
#: standard
msgctxt "sumatran_ware"
msgid ""
"Gold is the most valuable of all metals, and it is smelted out of gold ore "
"in furnaces."
msgstr ""
"L'or és el més valuós de tots els metalls, i es fon amb mineral d'or als "
"forns."

#. TRANSLATORS: Helptext for a Sumatran ware: Felling Ax, part 1
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:417 input:417
#: standard
msgctxt "sumatran_ware"
msgid ""
"The felling ax is the tool to cut down trees and is used by woodcutters."
msgstr ""
"La destral de tala és l'eina per talar arbres i la fan servir els "
"llenyataires."

