#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:454
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:467
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:480
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:493
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:506 input:419
#: input:454 input:467 input:480 input:493 input:506 standard
msgctxt "sumatran_ware"
msgid "They are produced by tools workshops."
msgstr "Són produïts per tallers d'eines."

#. TRANSLATORS: Helptext for a Sumatran ware: Pick
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:430 input:430
#: standard
msgctxt "sumatran_ware"
msgid "Picks are used by stonecutters and miners."
msgstr "Els pics són utilitzats pels picapedrers i els miners."

#. TRANSLATORS: Helptext for a Sumatran ware: Shovel
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:441 input:441
#: standard
msgctxt "sumatran_ware"
msgid "The shovel is an essential tool for foresters and farmers."
msgstr "La pala és una eina essencial per als forestals i pagesos."

#. TRANSLATORS: Helptext for a Sumatran ware: Hammer, part 1
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:452 input:452
#: standard
msgctxt "sumatran_ware"
msgid ""
"The hammer is the most used tool. Geologists, builders, coppersmiths, "
"shipwrights and craftsmen, they all need hammer."
msgstr ""
"El martell és l'eina més utilitzada. Geòlegs, constructors, calderes, "
"naviliers i artesans, tots necessiten martell."

#. TRANSLATORS: Helptext for a Sumatran ware: Machete, part 1
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:465 input:465
#: standard
msgctxt "sumatran_ware"
msgid ""
"The machete is a tool for leaf gatherers, reedcutters and together with "
"buckets also for wine makers."
msgstr ""
"El matxet és una eina per a recol·lectors de fulles, talladors de canyes i "
"juntament amb galledes també per a enòlegs."

#. TRANSLATORS: Helptext for a Sumatran ware: Kitchen Tools, part 1
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:478 input:478
#: standard
msgctxt "sumatran_ware"
msgid "Kitchen tools are used by cooks."
msgstr "Les eines de cuina són utilitzades pels cuiners."

#. TRANSLATORS: Helptext for a Sumatran ware: Fire Tongs, part 1
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:491 input:491
#: standard
msgctxt "sumatran_ware"
msgid "Fire tongs are the tools for smelting ores."
msgstr "Les pinces de foc són les eines per a la fosa de minerals."

#. TRANSLATORS: Helptext for a Sumatran ware: Buckets, part 1
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:504 input:504
#: standard
msgctxt "sumatran_ware"
msgid ""
"Buckets are used by water carriers and together with a machete by wine "
"makers."
msgstr ""
"Els cubells són utilitzats pels portadors d'aigua i juntament amb un matxet "
"pels elaboradors de vi."

#. TRANSLATORS: Helptext for a Sumatran ware: Whetstone
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:517 input:517
#: standard
msgctxt "sumatran_ware"
msgid "Whetstones are used by craftsmen and are produced in a basic workshop."
msgstr ""
"Les pedres d'afilar són utilitzades pels artesans i es produeixen en un "
"taller bàsic."

