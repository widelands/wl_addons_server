#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1584
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1594 input:1584
#: input:1594 standard
msgctxt "sumatran_building"
msgid "Digs copper ore and gold ore out of the ground in mountain terrain."
msgstr ""
"Excava mineral de coure i mineral d'or del sòl en terrenys de muntanya."

#. TRANSLATORS: Note helptext for a Sumatran production site: Copper-Gold Mine
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1586 input:1586
#: standard
msgctxt "sumatran_building"
msgid ""
"In comparison to a deep mine, production of this mine is quicker but more "
"expensive. The mine has two programs. Can produce higher ratio of gold ore "
"when gold ore is needed. "
msgstr ""
"En comparació amb una mina profunda, la producció d'aquesta mina és més "
"ràpida però més cara. La mina té dos programes. Pot produir una proporció "
"més alta de mineral d'or quan es necessita mineral d'or."

#. TRANSLATORS: Note helptext for a Sumatran production site: Deep Copper-Gold Mine
#: addons/sumatran_tribe.wad/tribes/sumatran_tribe/units.lua:1596 input:1596
#: standard
msgctxt "sumatran_building"
msgid ""
"In comparison to a basic mine, production of this mine is slower but "
"cheaper. The mine has two programs. Can produce higher ratio of gold ore "
"when gold ore is needed. Empty mines produce gold primarily, when gold is "
"needed."
msgstr ""
"En comparació amb una mina bàsica, la producció d'aquesta mina és més lenta "
"però més barata. La mina té dos programes. Pot produir una proporció més "
"alta de mineral d'or quan es necessita mineral d'or. Les mines buides "
"produeixen or principalment, quan es necessita or."

