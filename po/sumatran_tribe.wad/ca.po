#: addons/sumatran_tribe.wad/postload.lua:231 input:231 standard
msgctxt "empire_building"
msgid "Written on uncharted territories of imperial maps"
msgstr "Escrit en territoris inexplorats de mapes imperials"

#. TRANSLATORS: Note helptext for an Empire production site: Crocodile Hunter’s House, part 1
