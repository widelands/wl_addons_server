#: addons/editor_swap_terrains.wad/addon:2 input:9 standard
msgid "Editor: Swap Terrains"
msgstr "Redigerare: Byt terräng"

#: addons/editor_swap_terrains.wad/addon:3 input:6 standard
msgid ""
"A plugin for the editor to easily replace or swap two terrain types globally."
msgstr ""
"Ett plugin för redigeraren som gör det enkelt att ersätta eller byta ut två "
"terrängtyper globalt."

#: addons/editor_swap_terrains.wad/init.lua:8
#: addons/editor_swap_terrains.wad/show_window.lua:24 input:8 standard input:24
msgid "Swap Terrains"
msgstr "Byt terräng"

#: addons/editor_swap_terrains.wad/init.lua:9 input:9 standard
msgid "Globally exchange two terrains with each other"
msgstr "Byt två terränger med varandra globalt"

#: addons/editor_swap_terrains.wad/show_window.lua:77 standard input:77
msgid "Replace"
msgstr "Ersätt"

#: addons/editor_swap_terrains.wad/show_window.lua:78 standard input:78
msgid ""
"Globally replace all occurrences of the left terrain with the right terrain"
msgstr ""
"Ersätt globalt alla förekomster av den vänstra terrängen med den högra "
"terrängen"

#: addons/editor_swap_terrains.wad/show_window.lua:90 standard input:90
msgid "Swap"
msgstr "Byt"

#: addons/editor_swap_terrains.wad/show_window.lua:91 standard input:91
msgid "Globally swap the two selected terrains"
msgstr "Byt plats på de två valda terrängerna globalt"
