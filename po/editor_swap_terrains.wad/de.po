#: addons/editor_swap_terrains.wad/addon:2 input:9 standard
msgid "Editor: Swap Terrains"
msgstr "Editor: Geländearten tauschen"

#: addons/editor_swap_terrains.wad/addon:3 input:6 standard
msgid ""
"A plugin for the editor to easily replace or swap two terrain types globally."
msgstr ""
"Eine Erweiterung für den Editor um zwei Geländearten auf der ganzen Karte "
"einfach zu ersetzen oder auszutauschen."

#: addons/editor_swap_terrains.wad/init.lua:8
#: addons/editor_swap_terrains.wad/show_window.lua:24 input:8 input:24 standard
msgid "Swap Terrains"
msgstr "Tausche Geländearten"

#: addons/editor_swap_terrains.wad/init.lua:9 input:9 standard
msgid "Globally exchange two terrains with each other"
msgstr "Tausche zwei Geländearten auf der Karte miteinander aus"

#: addons/editor_swap_terrains.wad/show_window.lua:77 input:77 standard
msgid "Replace"
msgstr "Ersetzen"

#: addons/editor_swap_terrains.wad/show_window.lua:78 input:78 standard
msgid ""
"Globally replace all occurrences of the left terrain with the right terrain"
msgstr ""
"Ersetze alle Vorkommen der linken Geländeart auf der ganzen Karte mit der "
"rechten Geländeart"

#: addons/editor_swap_terrains.wad/show_window.lua:90 input:90 standard
msgid "Swap"
msgstr "Tausche"

#: addons/editor_swap_terrains.wad/show_window.lua:91 input:91 standard
msgid "Globally swap the two selected terrains"
msgstr "Tausche die beiden ausgewählten Geländearten auf der Karte miteinander"
