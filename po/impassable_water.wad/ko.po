#. TRANSLATORS: A category in the editor for placing terrains on the map.
#: addons/impassable_water.wad/addon:2 addons/impassable_water.wad/editor.lua:6
#: input:6 input:7 standard
msgid "Impassable Water"
msgstr "지나갈 수 없는 물길"

#: addons/impassable_water.wad/addon:3 input:6 standard
msgid "Shallow water terrains, impassable for ships but walkable."
msgstr "얕은 수중 지형, 걸어갈 수 있지만 배로 지나갈 수 없음."

#: addons/impassable_water.wad/world/terrains/desert/reef/init.lua:6 input:6
#: standard
msgid "Reef"
msgstr "암초"

#: addons/impassable_water.wad/world/terrains/summer/water_lily/init.lua:7
#: input:7 standard
msgid "Water Lily"
msgstr "수련"

#: addons/impassable_water.wad/world/terrains/wasteland/algae_slick/init.lua:6
#: input:6 standard
msgid "Algae slick"
msgstr "해조류 지역"

#: input:3 screenshots/impassable_water.wad/descriptions:1 standard
msgid "Wasteland terrain algae slick"
msgstr "불모지 해조류 지형"

#: input:4 screenshots/impassable_water.wad/descriptions:2 standard
msgid "Desert terrain reef"
msgstr "암초 사막 지형"

#: input:5 screenshots/impassable_water.wad/descriptions:3 standard
msgid "Summer terrain water lily"
msgstr "수련 여름 지형"
