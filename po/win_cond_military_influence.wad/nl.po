#: addons/win_cond_military_influence.wad/functions.lua:588
#, lua-format
msgid "Congratulations! You have trained %d heroes."
msgstr "Gefeliciteerd! Je hebt %d helden getraind."

#: addons/win_cond_military_influence.wad/functions.lua:663
#, lua-format
msgid ""
"Expand your territory, train your soldiers, and guard your territory with "
"military sites filled with heroes. You have to do all of them to get a "
"really good score. Highest score after %s wins."
msgstr ""
"Breid je grondgebied uit, train je soldaten en verdedig je grondgebied met "
"militaire bases vol helden. Je moet ze allemaal voltooien om een hele hoge "
"score te halen. De speler met de hoogste score na %s wint."

#: addons/win_cond_military_influence.wad/functions.lua:670
msgid "Final Score"
msgstr "Eindscore"

