#: addons/win_cond_military_influence.wad/functions.lua:321
msgid ""
"(The building scores are only indicative of the potential strength of each "
"building itself, they are not directly related to the scoring of the win "
"condition.)"
msgstr ""
"(Az épület pontszámok nem vethetők össze a játékmód pontszámaival, csak az "
"épületek általános összehasonlítását segítik.)"

#: addons/win_cond_military_influence.wad/functions.lua:346
