#: addons/frisians-economy-ultra.wad/postload.lua:9 input:9 standard
msgid "This rye field has been harvested."
msgstr "Dieses Roggenfeld wurde abgeerntet."

#: addons/frisians-economy-ultra.wad/postload.lua:12 input:12 standard
msgid "This rye field is ready for harvesting."
msgstr "Dieses Roggenfeld ist erntereif."

#: addons/frisians-economy-ultra.wad/postload.lua:15 input:15 standard
msgid "This rye field is flowering. Beekeepers can use it to produce honey."
msgstr "Dieses Roggenfeld blüht. Honig kann von einem Imker geerntet werden."

#: addons/frisians-economy-ultra.wad/postload.lua:18 input:18 standard
msgid "This rye field is growing."
msgstr "Dieses Roggenfeld wächst."

#: addons/frisians-economy-ultra.wad/postload.lua:21 input:21 standard
msgid "This rye field has just been planted."
msgstr "Dieses Roggenfeld wurde eben erst bepflanzt."

#: addons/frisians-economy-ultra.wad/postload.lua:25 input:25 standard
msgid "This oat field has been harvested."
msgstr "Dieses Haferfeld wurde abgeerntet."

#: addons/frisians-economy-ultra.wad/postload.lua:28 input:28 standard
msgid "This oat field is ready for harvesting."
msgstr "Dieses Haferfeld ist erntereif."

#: addons/frisians-economy-ultra.wad/postload.lua:31 input:31 standard
msgid "This oat field is flowering. Beekeepers can use it to produce honey."
msgstr "Dieses Haferfeld blüht. Honig kann von einem Imker geerntet werden."

#: addons/frisians-economy-ultra.wad/postload.lua:34 input:34 standard
msgid "This oat field is growing."
msgstr "Dieses Haferfeld wächst."

#: addons/frisians-economy-ultra.wad/postload.lua:37 input:37 standard
msgid "This oat field has just been planted."
msgstr "Dieses Haferfeld wurde eben erst bepflanzt."

#: addons/frisians-economy-ultra.wad/postload.lua:45 input:45 standard
msgid "Salt is washed from the sea and used to conserve meat and fish."
msgstr ""
"Salz wird aus dem Meer gewaschen und benutzt um Fisch und Fleisch zu "
"konservieren."

#: addons/frisians-economy-ultra.wad/postload.lua:48 input:48 standard
msgid "Rye is used to bake bread. It needs to be ground into flour first."
msgstr ""
"Roggen wird benutzt um Brot zu backen. Es muss erst zu Mehl gemahlen werden."

#: addons/frisians-economy-ultra.wad/postload.lua:51 input:51 standard
msgid "After being ground to flour, rye can be used to bake bread."
msgstr ""
"Nachdem er zu Mehl gemahlen wurde, kann Roggen benutzt werden um Brot zu "
"backen."

#: addons/frisians-economy-ultra.wad/postload.lua:54 input:54 standard
msgid "After being ground to flour, barley can be used to bake bread."
msgstr ""
"Nachdem sie zu Mehl gemahlen wurde, kann Gerste benutzt werden um Brot zu "
"backen."

#: addons/frisians-economy-ultra.wad/postload.lua:57 input:57 standard
msgid "Oat is used to bake bread and also fed to the reindeer."
msgstr ""
"Hafer wird benutzt um Brot zu backen und auch an die Rentiere verfüttert."

#: addons/frisians-economy-ultra.wad/postload.lua:60 input:60 standard
msgid "Fur can be tanned into leather, which is needed to produce garments."
msgstr ""
"Fell kann ztu Leder Gegerbt werden, welches zur Produktion von Gewändern "
"benötigt wird."

#: addons/frisians-economy-ultra.wad/postload.lua:104 input:104 standard
msgid "The salter washes salt from the shores of the sea."
msgstr "Der Salzsieder wäscht Salz von den Küsten der See."

#: addons/frisians-economy-ultra.wad/postload.lua:107 input:107 standard
msgid "The miller grinds barley and rye into flour."
msgstr "Der Müller mahlt Gerste und Roggen zu Mehl."

#: addons/frisians-economy-ultra.wad/postload.lua:110 input:110 standard
msgid "The tanner tans furs to produce leather."
msgstr "Der Gerber gerbt Felle um Leder zu produzieren."

#: addons/frisians-economy-ultra.wad/postload.lua:118 input:118 standard
msgid "The salter working at the salt works washes salt from the sea."
msgstr "Der Salzsieder in den Salinen wäscht Salz aus dem Meer."

#: addons/frisians-economy-ultra.wad/postload.lua:119 input:119 standard
msgid "The salter needs water within its work area."
msgstr "Der Salzsieder braucht Wasser in seinem Arbeitsbereich."

#: addons/frisians-economy-ultra.wad/postload.lua:122 input:122 standard
msgid "The tannery tans fur into leather."
msgstr "Die Gerberei gerbt Fell zu Leder."

#: addons/frisians-economy-ultra.wad/postload.lua:125 input:125 standard
msgid "The barley mill grinds barley into barley flour."
msgstr "Die Gerstenmühle mahlt Gerste zu Gerstenmehl."

#: addons/frisians-economy-ultra.wad/postload.lua:128 input:128 standard
msgid "The rye mill grinds rye into rye flour."
msgstr "Die Roggenmühle mahlt Roggen zu Roggenmehl."

#: addons/frisians-economy-ultra.wad/postload.lua:131 input:131 standard
msgid "The rye farm sows and harvests rye."
msgstr "Der Roggenhof sät und erntet Roggen."

#: addons/frisians-economy-ultra.wad/postload.lua:134 input:134 standard
msgid "The oat farm sows and harvests oat."
msgstr "Der Haferhof sät und erntet Hafer."

