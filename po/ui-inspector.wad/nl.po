msgstr "%1$s (%2$s):"

#: addons/ui-inspector.wad/show_window.lua:266 input:266 standard
msgid "Copy value"
msgstr "Waarde kopiëren"

#: addons/ui-inspector.wad/show_window.lua:266 input:266 standard
