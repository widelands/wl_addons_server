#: addons/ui-inspector.wad/show_window.lua:143 input:143 standard
msgid "The panel no longer exists."
msgstr "Het panel bestaat niet meer."

#: addons/ui-inspector.wad/show_window.lua:160 input:160 standard
msgid "Copy class name"
msgstr "Klassenaam kopiëren"

#: addons/ui-inspector.wad/show_window.lua:224 input:224 standard
msgid "Copy property name"
msgstr "Naam eigenschap kopiëren"

#: addons/ui-inspector.wad/show_window.lua:242 input:242 standard
