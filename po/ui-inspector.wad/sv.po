msgstr "%1$s (%2$s):"

#: addons/ui-inspector.wad/show_window.lua:266 input:266 standard
msgid "Copy value"
msgstr "Kopiera värde"

#: addons/ui-inspector.wad/show_window.lua:266 input:266 standard
msgid "Go to this item"
msgstr "Gå till detta objekt"

#: addons/ui-inspector.wad/show_window.lua:397 input:397 standard
msgid "Filter by name or class"
msgstr "Filtrera efter namn eller klass"

#: addons/ui-inspector.wad/show_window.lua:404 input:404 standard
msgid "Clear filter"
msgstr "Töm filter"

#: addons/ui-inspector.wad/show_window.lua:417 input:417 standard
msgid "Refresh"
