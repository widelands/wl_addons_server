#: addons/ui-inspector.wad/addon:2 addons/ui-inspector.wad/init.lua:7
#: addons/ui-inspector.wad/init.lua:16
#: addons/ui-inspector.wad/show_window.lua:380 input:7 input:9 input:16
#: input:380 standard
msgid "UI Inspector"
msgstr "Grafisk gränssnittsinspekterare"

#: addons/ui-inspector.wad/addon:3 input:6 standard
msgid ""
"This utility allows add-on designers to inspect the structure, hierarchy, "
"and properties of panels and windows. This allows you to obtain the internal "
"names of panels and mimic existing windows without searching their source "
"code, and assists with troubleshooting misbehaving plugins."
msgstr ""
"Med detta verktyg kan tilläggsutvecklare inspektera strukturen, hierarkin "
"och egenskaperna hos paneler och fönster. Detta gör det möjligt att få fram "
"de interna namnen på paneler och efterlikna befintliga fönster utan att "
"behöva söka i källkoden, samt hjälper till med felsökning av insticksmoduler "
"som inte fungerar som de ska."

#: addons/ui-inspector.wad/init.lua:8 input:8 standard
msgid "Inspect all open panels"
msgstr "Inspektera alla öppna paneler"

#: addons/ui-inspector.wad/show_window.lua:10
