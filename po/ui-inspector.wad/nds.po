#: addons/ui-inspector.wad/addon:2 addons/ui-inspector.wad/init.lua:7
#: addons/ui-inspector.wad/init.lua:16
#: addons/ui-inspector.wad/show_window.lua:380 input:7 input:9 input:16
#: input:380 standard
msgid "UI Inspector"
msgstr "Schnittstee-Inspizerer"

#: addons/ui-inspector.wad/addon:3 input:6 standard
msgid ""
"This utility allows add-on designers to inspect the structure, hierarchy, "
"and properties of panels and windows. This allows you to obtain the internal "
"names of panels and mimic existing windows without searching their source "
"code, and assists with troubleshooting misbehaving plugins."
msgstr ""
"Deeses Warktüüg verlöövt Verwiederns-Entwicklers, de Struktuur, Örnung un "
"Eegenskuppen vun Balkens un Fensters to inspizeren. Dat lett di de binnern "
"Namen vun Balkens utfinnen un bestahn Fensters natomaken, sünner hör "
"Quelltext to dörsöken, un hülpt mit de Fehler-Söök, wenn een Schnittstee-"
"Inschuuv tokehrgaht."

#: addons/ui-inspector.wad/init.lua:8 input:8 standard
msgid "Inspect all open panels"
msgstr "All open Balkens inspizeren."

#: addons/ui-inspector.wad/show_window.lua:10
#: addons/ui-inspector.wad/show_window.lua:182
#: addons/ui-inspector.wad/show_window.lua:209 input:10 input:182 input:209
#: standard
msgid "%1$s “%2$s”"
msgstr "%1$s »%2$s«"

#: addons/ui-inspector.wad/show_window.lua:143 input:143 standard
msgid "The panel no longer exists."
msgstr "Deesen Balken gifft dat nich mehr."

#: addons/ui-inspector.wad/show_window.lua:160 input:160 standard
msgid "Copy class name"
msgstr "Klassnaam koperen"

#: addons/ui-inspector.wad/show_window.lua:224 input:224 standard
msgid "Copy property name"
msgstr "Eegenskupps-Naam koperen"

#: addons/ui-inspector.wad/show_window.lua:242 input:242 standard
msgid "%1$s (%2$s):"
msgstr "%1$s (%2$s):"

#: addons/ui-inspector.wad/show_window.lua:266 input:266 standard
msgid "Copy value"
msgstr "Weert koperen"

#: addons/ui-inspector.wad/show_window.lua:266 input:266 standard
msgid "Go to this item"
msgstr "To deesem Ding gahn"

#: addons/ui-inspector.wad/show_window.lua:397 input:397 standard
msgid "Filter by name or class"
msgstr "Na Naam of Klass filtern"

#: addons/ui-inspector.wad/show_window.lua:404 input:404 standard
msgid "Clear filter"
msgstr "Filter leegmaken"

#: addons/ui-inspector.wad/show_window.lua:417 input:417 standard
msgid "Refresh"
msgstr "Vernejen"

#: input:3 screenshots/ui-inspector.wad/descriptions:3 standard
msgid ""
"The Inspector in action: View the hierarchy and properties of current panels."
msgstr ""
"So löppt de Inspizerer: Kiek de Örnung un Eegenskuppen vun stedenwies "
"Balkens an."

#: input:4 screenshots/ui-inspector.wad/descriptions:4 standard
msgid "Too much clutter? Apply a filter to find a panel by name or type."
msgstr ""
"To vööl Kuddelmuddel? Sett eenen Filter, um eenen Balken na sienem Naam of "
"siener Aard to finnen."
