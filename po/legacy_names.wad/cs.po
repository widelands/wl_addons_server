#. TRANSLATORS: This is a building name used in lists of buildings
#: addons/legacy_names.wad/stronghold/init.lua:8 input:8 standard
msgctxt "barbarians_building"
msgid "Stronghold"
msgstr "Malá pevnost"

#. TRANSLATORS: Message sent by a Barbarian military site
#: addons/legacy_names.wad/stronghold/init.lua:44 input:44 standard
msgctxt "barbarians_building"
msgid "Your soldiers have occupied your stronghold."
msgstr "Malá pevnost obydlena tvou posádkou."

#. TRANSLATORS: Message sent by a Barbarian military site
#: addons/legacy_names.wad/stronghold/init.lua:46 input:46 standard
