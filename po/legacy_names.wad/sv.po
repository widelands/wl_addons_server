msgstr "Din fästning är under attack."

#. TRANSLATORS: Message sent by a Barbarian military site
#: addons/legacy_names.wad/stronghold/init.lua:50 input:50 standard
msgctxt "barbarians_building"
msgid "The enemy defeated your soldiers at the stronghold."
msgstr "Fienden besegrade dina soldater vid fästningen."

#. TRANSLATORS: Message sent by a Barbarian military site
