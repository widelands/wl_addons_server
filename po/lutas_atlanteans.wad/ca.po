#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1454
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1470
#: input:1454 input:1470 standard
msgctxt "lutas_atlanteans_building"
msgid "Atlantean nursery rhyme"
msgstr "Cançó infantil atlant"

#. TRANSLATORS: Performance helptext for a Lutas’ Atlantean production site: Weapon Smithy
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1456
#: input:1456 standard
msgctxt "lutas_atlanteans_building"
msgid ""
"If this building is fully supplied and all tridents are needed by the "
"economy, production of one of each trident takes %1$s on average. If only "
"one kind of trident is needed by the economy, production of one light "
"trident takes %2$s and one long trident, one steel trident, one diamond "
"double trident or one heavy double trident takes %3$s on average."
msgstr ""
"Si aquest edifici està completament proveït i tots els tridents són "
"necessaris per l'economia, la producció d'un de cada trident triga %1$s de "
"mitjana. Si l'economia només necessita un tipus de trident, la producció "
"d'un trident lleuger necessita %2$s i un trident llarg, un trident d'acer, "
"un trident doble de diamant o un trident doble pesat necessita de mitjana "
"%3$s."

#. TRANSLATORS: Purpose helptext for a Lutas’ Atlantean production site: Armor Smithy
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1463
#: input:1463 standard
msgctxt "lutas_atlanteans_building"
msgid ""
"Forges shields that are used for training soldiers’ defense in the labyrinth."
msgstr ""
"Forja escuts que s'utilitzen per entrenar la defensa dels soldats al "
"laberint."

#. TRANSLATORS: Lore helptext for a Lutas’ Atlantean production site: Armor Smithy
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1465
#: input:1465 standard
msgctxt "lutas_atlanteans_building"
msgid ""
"‘She twists and tweaks the steel with might<br>that soldiers may therewith "
"once fight<br>most skillful foes, whose lethal lance<br>from this their "
"armour off will glance!’"
msgstr ""
"\"Ella retorça i retoca l'acer amb força<br> perquè els soldats puguin "
"lluitar una vegada amb <br>enemics més hàbils, la llança letal dels "
"quals<br>des d'aquí la seva armadura es veurà apagada!\""

#. TRANSLATORS: Performance helptext for a Lutas’ Atlantean production site: Armor Smithy
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1472
#: input:1472 standard
msgctxt "lutas_atlanteans_building"
msgid ""
"If this building is fully supplied and both kinds of shields are needed by "
"the economy, production of one of each kind takes %1$s on average. If only "
"one kind of shield is needed by the economy, production of one steel shield "
"takes %2$s and one advanced shield takes %3$s on average."
msgstr ""
"Si aquest edifici està completament proveït i l'economia necessita ambdós "
"tipus d'escuts, la producció d'un de cada tipus necessita de mitjana %1$s. "
"Si l'economia només necessita un tipus d'escut, la producció d'un blindatge "
"d'acer triga %2$s i un blindatge avançat triga %3$s de mitjana."

#. TRANSLATORS: Purpose helptext for a Lutas’ Atlantean production site: Barracks
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1479
#: input:1479 standard
msgctxt "lutas_atlanteans_building"
msgid "Equips recruits and trains them as soldiers."
msgstr "Equipa els reclutes i els entrena com a soldats."

#. TRANSLATORS: Lore helptext for a Lutas’ Atlantean production site: Barracks
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1481
#: input:1481 standard
msgctxt "lutas_atlanteans_building"
msgid ""
"See these fine silk tabards and those sharp tridents? This is your way to "
"defend your tribe!"
msgstr ""
"Veus aquests tabards de seda fina i aquests tridents afilats? Aquesta és la "
"teva manera de defensar la teva tribu!"

#. TRANSLATORS: Lore author helptext for a Lutas’ Atlantean production site: Barracks
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1483
#: input:1483 standard
msgctxt "lutas_atlanteans_building"
msgid "Recruiting poster"
msgstr "Cartell de contractació"

#. TRANSLATORS: Performance helptext for a Lutas’ Atlantean production site: Barracks
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1485
#: input:1485 standard
#, lua-format
msgctxt "lutas_atlanteans_building"
msgid "The barracks need %s on average to recruit one soldier."
msgstr "Les barraques necessiten %s de mitjana per reclutar un soldat."

#. TRANSLATORS: Purpose helptext for a Lutas’ Atlantean production site: Horse Farm
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1494
#: input:1494 standard
msgctxt "lutas_atlanteans_building"
msgid ""
"Breeds the strong Atlantean horses for adding them to the transportation "
"system."
msgstr ""
"Cria els forts cavalls atlantes per afegir-los al sistema de transport."

#. TRANSLATORS: Lore helptext for a Lutas’ Atlantean production site: Horse Farm
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1496
#: input:1496 standard
msgctxt "lutas_atlanteans_building"
msgid "I walk all day just back and forth. I need? I need … I need a horse!"
msgstr ""
"Camino tot el dia d'anada i tornada. Necessito? Necessito... necessito un "
"cavall!"

#. TRANSLATORS: Lore author helptext for a Lutas’ Atlantean production site: Horse Farm
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1498
#: input:1498 standard
msgctxt "lutas_atlanteans_building"
msgid "Busy carrier murmuring to himself"
msgstr "Portador ocupat murmurant per a si mateix"

#. TRANSLATORS: Purpose helptext for a Lutas’ Atlantean production site: Farm
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1505
#: input:1505 standard
msgctxt "lutas_atlanteans_building"
msgid "Sows and harvests corn."
msgstr "Sembra i cull blat de moro."

#. TRANSLATORS: Lore helptext for a Lutas’ Atlantean production site: Farm
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1507
#: input:1507 standard
msgctxt "lutas_atlanteans_building"
msgid "I use my feet, I use my arm, I’m caring for this farm!"
msgstr ""
"Jo faig servir els peus, faig servir el braç, estic cuidant aquesta granja!"

#. TRANSLATORS: Lore author helptext for a Lutas’ Atlantean production site: Farm
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1509
#: input:1509 standard
msgctxt "lutas_atlanteans_building"
msgid "Atlantean harvesting song"
msgstr "Cançó de la collita atlante"

#. TRANSLATORS: Performance helptext for a Lutas’ Atlantean production site: Farm
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1511
#: input:1511 standard
msgctxt "lutas_atlanteans_building"
msgid "The farmer needs %1% on average to sow and harvest a sheaf of corn."
msgstr ""
"El pagès necessita un 1% de mitjana per sembrar i collir una garba de blat "
"de moro."

#. TRANSLATORS: Purpose helptext for a Lutas’ Atlantean production site: Blackroot Farm
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1518
#: input:1518 standard
msgctxt "lutas_atlanteans_building"
msgid "Sows and harvests blackroot."
msgstr "Sembra i cull arrel negre."

#. TRANSLATORS: Lore helptext for a Lutas’ Atlantean production site: Blackroot Farm
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1520
#: input:1520 standard
msgctxt "lutas_atlanteans_building"
msgid ""
"The secret of Atlantean health and strength is hidden in these roots. It’s "
"not spinach, it’s not a carrot, it’s … a secret."
msgstr ""
"El secret de la salut i la força atlante s'amaga en aquestes arrels. No és "
"espinacs, no és una pastanaga, és... un secret."

#. TRANSLATORS: Lore author helptext for a Lutas’ Atlantean production site: Blackroot Farm
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1523
#: input:1523 standard
msgctxt "lutas_atlanteans_building"
msgid "Blackroot farmer asked by a foreigner"
msgstr "Pagès d'arrel negra preguntat per un estranger"

#. TRANSLATORS: Performance helptext for a Lutas’ Atlantean production site: Blackroot Farm
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1525
#: input:1525 standard
msgctxt "lutas_atlanteans_building"
msgid ""
"The blackroot farmer needs %1% on average to sow and harvest a bundle of "
"blackroot."
msgstr ""
"L'agricultor d'arrel negra necessita un 1% de mitjana per sembrar i collir "
"un paquet d'arrel negra."

#. TRANSLATORS: Purpose helptext for a Lutas’ Atlantean production site: Spider Farm
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1532
#: input:1532 standard
msgctxt "building"
msgid "Breeds spiders for silk."
msgstr "Cria aranyes per a la seda."

#. TRANSLATORS: Lore helptext for a Lutas’ Atlantean production site: Spider Farm
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1534
#: input:1534 standard
msgctxt "lutas_atlanteans_building"
msgid ""
"No, the spiders are not fed with corn. We feed it to fat grasshoppers, which "
"in turn are digested by our spiders. We put them on a special device to gain "
"the spider silk once a day. There is no need to spin this again. The thread "
"can directly be used by the weaving mill. Oh hello, here is one of our nice "
"spiders … Hey! Why are you running away?"
msgstr ""
"No, les aranyes no s'alimenten amb blat de moro. L'alimentem a llagostes "
"grasses, que al seu torn són digerides per les nostres aranyes. Els posem en "
"un dispositiu especial per obtenir la seda d'aranya un cop al dia. No cal "
"tornar-ho a girar. El fil pot ser utilitzat directament pel teixit. Hola, "
"aquí teniu una de les nostres simpàtiques aranyes... Ei! Per què fuges?"

#. TRANSLATORS: Lore author helptext for a Lutas’ Atlantean production site: Spider Farm
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1538
#: input:1538 standard
msgctxt "lutas_atlanteans_building"
msgid "A spider breeder showing his farm"
msgstr "Un criador d'aranya mostrant la seva granja"

#. TRANSLATORS: Purpose helptext for a Lutas’ Atlantean production site: Weaving Mill
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1546
#: input:1546 standard
msgctxt "lutas_atlanteans_building"
msgid ""
"Weaves spidercloth for buildings and ships’ sails, and tabards to equip and "
"train the soldiers."
msgstr ""
"Teixeix tela d'aranya per als edificis i les veles dels vaixells, i tabardes "
"per equipar i entrenar els soldats."

#. TRANSLATORS: Lore helptext for a Lutas’ Atlantean production site: Weaving Mill
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1548
#: input:1548 standard
msgctxt "lutas_atlanteans_building"
msgid ""
"Here are the Wide Lands where people may dwell, walking around caring "
"everything’s well."
msgstr ""
"Aquí hi ha les Terres Amples on la gent pot habitar, caminant cuidant que "
"tot vagi bé."

#. TRANSLATORS: Lore author helptext for a Lutas’ Atlantean production site: Weaving Mill
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1551
#: input:1551 standard
msgctxt "lutas_atlanteans_building"
msgid "Part of the silkweavers’ song"
msgstr "Part de la cançó dels teixidors de seda"

#. TRANSLATORS: Performance helptext for a Lutas’ Atlantean production site: Weaving Mill
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1553
#: input:1553 standard
msgctxt "lutas_atlanteans_building"
msgid ""
"If this building is fully supplied and all kinds of cloth and tabards are "
"needed by the economy, production of one of each cloth and tabard takes %1$s "
"on average. If only one kind of cloth or tabard is needed by the economy, "
"its production takes %2$s on average."
msgstr ""
"Si aquest edifici està completament proveït i l'economia necessita tota mena "
"de draps i tabards, la producció d'un de cada drap i tabard necessita de "
"mitjana %1$s. Si l'economia només necessita un tipus de drap o tabard, la "
"seva producció triga %2$s de mitjana."

