#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1842
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1868
#: input:1842 input:1868 standard
msgctxt "building"
msgid "Roads and trees along the shoreline block access to water."
msgstr ""
"Les carreteres i els arbres al llarg de la costa bloquegen l'accés a l'aigua."

#. TRANSLATORS: Lore helptext for a Lutas’ Atlantean production site: Ferry Yard
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1845
#: input:1845 standard
msgctxt "lutas_atlanteans_building"
msgid ""
"‘Row, row, row your boat<br>gently ’long the shore.<br>Steadily steadily "
"steadily steadily<br>bring the wares ashore.’"
msgstr ""
"‘Rema, rema, rema el teu vaixell<br>suaument ’al llarg de la costa.<br>De "
"manera constant, constantment constantment constantment<br>porteu les "
"mercaderies a terra.’"

#. TRANSLATORS: Lore author helptext for a Lutas’ Atlantean production site: Ferry Yard
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1850
#: input:1850 standard
msgctxt "lutas_atlanteans_building"
msgid "Traditional song of the ferrymen"
msgstr "Cançó tradicional dels barquers"

#. TRANSLATORS: Performance helptext for a Lutas’ Atlantean production site: Ferry Yard, part 1
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1853
#: input:1853 standard
msgctxt "lutas_atlanteans_building"
msgid ""
"This building can produce one ferry between %1$s and %2$s, depending on how "
"far the shipwright has to walk."
msgstr ""
"Aquest edifici pot produir un ferri entre %1$s i %2$s, depenent de la "
"distància que hagi de caminar l'armador."

#. TRANSLATORS: Purpose helptext for a Lutas’ Atlantean production site: Shipyard
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1863
#: input:1863 standard
msgctxt "building"
msgid ""
"Constructs ships that are used for overseas colonization and for trading "
"between ports."
msgstr ""
"Construeix vaixells que s'utilitzen per a la colonització a l'estranger i "
"per al comerç entre ports."

#. TRANSLATORS: Note helptext for a Lutas’ Atlantean production site: Shipyard, part 1
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1866
#: input:1866 standard
msgctxt "building"
msgid "Needs wide open water nearby."
msgstr "Necessita aigua oberta a prop."

#. TRANSLATORS: Lore helptext for a Lutas’ Atlantean production site: Shipyard
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1871
#: input:1871 standard
msgctxt "lutas_atlanteans_building"
msgid ""
"‘Soon may the wellerman come,<br>to bring us bread and smoked fish.<br>We "
"set sail for a faraway shore<br>we praise Lutas the best we wish.’"
msgstr ""
"\"Aviat pot venir el home de salut,<br>a portar-nos pa i peix fumat.<br>Vam "
"navegar cap a una costa llunyana<br>Elogiem Lutas el millor que desitgem.\""

#. TRANSLATORS: Lore author helptext for a Lutas’ Atlantean production site: Shipyard -- not directly stolen from the wellerman song
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1876
#: input:1876 standard
msgctxt "lutas_atlanteans_building"
msgid "Transcript from oral tradition"
msgstr "Transcripció de la tradició oral"

#. TRANSLATORS: Performance helptext for a Lutas’ Atlantean production site: Shipyard, part 1
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:1879
#: input:1879 standard
msgctxt "lutas_atlanteans_building"
msgid ""
"This building can produce one ship between %1$s and %2$s, depending on how "
"far the shipwright has to walk."
msgstr ""
"Aquest edifici pot produir un vaixell entre %1$s i %2$s, depenent de la "
