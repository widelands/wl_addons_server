#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/tips.lua:4 input:4
#: standard
msgid ""
"Your Temple needs to be built close to water. The priestess who is living "
"there needs a coast to pray."
msgstr ""
"El teu temple s'ha de construir prop de l'aigua. La sacerdotessa que hi viu "
"necessita una costa per pregar."

