#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:923
#: input:923 standard
msgid "There are no resources in the ground here."
msgstr "Aquí no hi ha recursos."

#. TRANSLATORS: Helptext for a Lutas’ Atlantean resource indicator: Water
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:930
#: input:930 standard
msgid "There is water in the ground here that can be pulled up by a well."
msgstr "Aquí hi ha aigua subterrània que es pot extreure amb un pou."

#. TRANSLATORS: Helptext for a Lutas’ Atlantean resource indicator: Coal, part 1
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:938
#: addons/lutas_atlanteans.wad/tribes/lutas_atlanteans_tribe/units.lua:982
#: input:938 input:982 standard
