msgstr "Smelt ijzererts om in ijzer en goudstof of gouderts in goud."

#. TRANSLATORS: Purpose helptext for a Europeans production site: Recycling Center
#: addons/europeans_all.wad/tribes/initialization/units.lua:4976 input:4976
#: standard
msgctxt "europeans_building"
msgid "Smelts scrap iron into iron and scrap metal mixed into iron and gold."
msgstr ""
"Smelt schrootijzer om tot ijzer en schrootmetaal vermengd met ijzer en goud."

#. TRANSLATORS: Purpose helptext for a Europeans production site: Micro Brewery
#: addons/europeans_all.wad/tribes/initialization/units.lua:4983 input:4983
#: standard
msgctxt "europeans_building"
msgid "Produces simple barbarians beer out of water and wheat."
msgstr "Produceert eenvoudig barbaars bier uit water en tarwe."

#. TRANSLATORS: Purpose helptext for a Europeans production site: Brewery
#: addons/europeans_all.wad/tribes/initialization/units.lua:4990 input:4990
#: standard
msgctxt "europeans_building"
msgid "Produces additional barbarians strong beer out of water and wheat."
msgstr "Produceert extra sterk barbaren bier uit water en tarwe."

#. TRANSLATORS: Purpose helptext for a Europeans production site: Chocolate Brewery
#: addons/europeans_all.wad/tribes/initialization/units.lua:4997 input:4997
#: standard
msgctxt "europeans_building"
msgid "Produces additional amazons chocolate out of water and cacao."
msgstr "Produceert extra Amazons-chocolade uit water en cacao."

#. TRANSLATORS: Purpose helptext for a Europeans production site: Brewery
#: addons/europeans_all.wad/tribes/initialization/units.lua:5004 input:5004
#: standard
msgctxt "europeans_building"
msgid "Produces empire beer out of water and barley."
msgstr "Produceert keizerrijk bier uit water en gerst."

#. TRANSLATORS: Purpose helptext for a Europeans production site: Vinery
#: addons/europeans_all.wad/tribes/initialization/units.lua:5011 input:5011
#: standard
msgctxt "europeans_building"
msgid "Produces additional wine out of grapes."
msgstr "Produceert extra wijn uit druiven."

#. TRANSLATORS: Purpose helptext for a Europeans production site: Brewery
#: addons/europeans_all.wad/tribes/initialization/units.lua:5018 input:5018
#: standard
msgctxt "europeans_building"
msgid "Produces frisians beer out of water and barley."
msgstr "Produceert Fries bier uit water en gerst."

#. TRANSLATORS: Purpose helptext for a Europeans production site: Mead Brewery
#: addons/europeans_all.wad/tribes/initialization/units.lua:5025 input:5025
#: standard
msgctxt "europeans_building"
msgid "Produces additional mead out of water, honey and barley."
msgstr "Produceert Fries bier uit water en gerst."

#. TRANSLATORS: Purpose helptext for an Europeans production site: Mill
#: addons/europeans_all.wad/tribes/initialization/units.lua:5032 input:5032
#: standard
msgctxt "europeans_building"
msgid "Grinds corn and blackroot to produce cornmeal and blackroot_flour."
msgstr "Maalt maïs en helmkruid om maïsmeel en helmkruidmeel te produceren."

#. TRANSLATORS: Purpose helptext for an Europeans production site: Mill
#: addons/europeans_all.wad/tribes/initialization/units.lua:5039 input:5039
#: standard
msgctxt "europeans_building"
msgid "Grinds grain, corn and blackroot to produce various kinds of flour."
msgstr ""
"Maalt graan, maïs en zwarte wortel om verschillende soorten meel te "
"produceren."

#. TRANSLATORS: Purpose helptext for a Europeans production site: Bakery
#: addons/europeans_all.wad/tribes/initialization/units.lua:5046 input:5046
#: standard
msgctxt "europeans_building"
msgid "Produces simple barbarians bread out of water and wheat."
msgstr "Maakt eenvoudig barbarenbrood van water en tarwe."

#. TRANSLATORS: Purpose helptext for a Europeans production site: Cassava Root Cooker
#: addons/europeans_all.wad/tribes/initialization/units.lua:5053 input:5053
#: standard
msgctxt "europeans_building"
msgid "Produces additional amazons bread out of water and cassavaroot."
msgstr "Produceert extra amazonesbrood uit water en cassavewortel."

#. TRANSLATORS: Purpose helptext for a Europeans production site: Bakery
#: addons/europeans_all.wad/tribes/initialization/units.lua:5060 input:5060
#: standard
msgctxt "europeans_building"
msgid ""
"Produces additional atlanteans bread out of water, cornmeal and blackroot "
"flour."
msgstr ""
"Produceert extra Atlantaans brood uit water, maïsmeel en helmkruidbloem."

#. TRANSLATORS: Purpose helptext for a Europeans production site: Bakery
#: addons/europeans_all.wad/tribes/initialization/units.lua:5067 input:5067
#: standard
msgctxt "europeans_building"
msgid "Produces additional empire bread out of water, flour and rye flour."
msgstr "Maakt extra keirerbrood van water, bloem en roggemeel."

#. TRANSLATORS: Purpose helptext for a Europeans production site: Bakery
#: addons/europeans_all.wad/tribes/initialization/units.lua:5074 input:5074
#: standard
msgctxt "europeans_building"
msgid ""
"Produces additional frisians bread out of water, barley flour and oat flour."
msgstr "Produceert extra Fries brood uit water, gerstemeel en havermeel."

#. TRANSLATORS: Purpose helptext for a Europeans production site: Honey Bakery
#: addons/europeans_all.wad/tribes/initialization/units.lua:5081 input:5081
#: standard
msgctxt "europeans_building"
msgid ""
"Produces additional honey bread out of water, barley flour, out flour and "
"honey."
msgstr "Maakt extra honingbrood van water, gerstemeel, bloem en honing."

#. TRANSLATORS: Purpose helptext for an Europeans production site: Smokery
#: addons/europeans_all.wad/tribes/initialization/units.lua:5088
#: addons/europeans_all.wad/tribes/initialization/units.lua:5096 input:5088
#: input:5096 standard
msgctxt "europeans_building"
msgid "Smokes meat and fish."
msgstr "Rookt vlees en vis."

