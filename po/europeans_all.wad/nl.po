#: addons/europeans_all.wad/tribes/initialization/units.lua:758
#: addons/europeans_all.wad/tribes/initialization/units.lua:806 input:758
#: input:806 standard
msgctxt "frisians_ware"
msgid ""
"Discarded weapons and armor can be recycled in a recycling center to produce "
"new tools, weapon and armor."
msgstr ""
"Afgedankte wapens en harnassen kunnen in een recyclingcentrum worden "
"gerecycled om nieuwe gereedschappen, wapens en harnassen te produceren."

#. TRANSLATORS: Helptext for an Empire ware: Iron, part 1
#: addons/europeans_all.wad/tribes/initialization/units.lua:768 input:768
#: standard
msgctxt "ware"
msgid "Iron is smelted out of iron ores."
msgstr "IJzer wordt gesmolten uit ijzererts."

#. TRANSLATORS: Helptext for an Empire ware: Iron, part 2
#: addons/europeans_all.wad/tribes/initialization/units.lua:770 input:770
#: standard
msgctxt "empire_ware"
msgid ""
"It is produced by the smelting works. Weapons, armor and tools are made of "
"iron."
msgstr ""
"Het wordt geproduceerd door smelterijen. Wapens, harnassen en gereedschappen "
"worden van ijzer gemaakt."

#. TRANSLATORS: Helptext for an Empire ware: Gold Ore, part 1
#: addons/europeans_all.wad/tribes/initialization/units.lua:781 input:781
#: standard
msgctxt "ware"
msgid "Gold ore is mined in a gold mine."
msgstr "Gouderts wordt gedolven in een goudmijn."

#. TRANSLATORS: Helptext for an Empire ware: Gold Ore, part 2
#: addons/europeans_all.wad/tribes/initialization/units.lua:783 input:783
#: standard
msgctxt "empire_ware"
msgid ""
"Smelted in a smelting works, it turns into gold which is used as a precious "
"building material and to produce weapons and armor."
msgstr ""
"Gesmolten in een hoogoven, verandert het in goud dat wordt gebruikt als "
"kostbaar bouwmateriaal en om wapens en pantsers te maken."

#. TRANSLATORS: Helptext for an Amazon ware: Gold Dust, part 1
#: addons/europeans_all.wad/tribes/initialization/units.lua:794 input:794
#: standard
msgctxt "amazons_ware"
msgid "Gold dust is washed in a gold digger dwelling."
msgstr "Goudstof wordt gewassen in een goudzoekerswoning."

#. TRANSLATORS: Helptext for an Amazon ware: Gold Dust, part 2
#: addons/europeans_all.wad/tribes/initialization/units.lua:796 input:796
#: standard
msgctxt "amazons_ware"
msgid ""
"Smelted in a furnace, it turns into gold which is used as a precious "
"building material and to produce armor."
msgstr ""
"In een smeltoven gesmolten, verandert het in goud dat wordt gebruikt als "
"kostbaar bouwmateriaal en voor de productie van harnassen."

#. TRANSLATORS: Helptext for an Empire ware: Gold, part 1
#: addons/europeans_all.wad/tribes/initialization/units.lua:816 input:816
#: standard
msgctxt "ware"
msgid ""
"Gold is the most valuable of all metals, and it is smelted out of gold ore."
msgstr ""
"Goud is het meest waardevolle van alle metalen en wordt gesmolten uit "
"gouderts."

#. TRANSLATORS: Helptext for an Empire ware: Gold, part 2
#: addons/europeans_all.wad/tribes/initialization/units.lua:818 input:818
#: standard
msgctxt "empire_ware"
msgid ""
"It is produced by the smelting works. Armor and weapons are embellished with "
"gold in the armor smithy and the weapon smithy."
msgstr ""
"Het wordt geproduceerd door de hoogoven. Pantsers en wapens worden versierd "
"met goud in de pantsersmederij en de wapensmederij."

#. TRANSLATORS: Helptext for an Atlantean ware: Gold Thread
#: addons/europeans_all.wad/tribes/initialization/units.lua:828 input:828
#: standard
msgctxt "atlanteans_ware"
msgid ""
"This thread, made of gold by the gold spinning mill, is used for weaving the "
"exclusive golden tabard in the weaving mill."
msgstr ""
"Deze draad, gemaakt van goud door de goudspinnerij, wordt gebruikt voor het "
"weven van de exclusieve gouden tabbaard in de weverij."

#. TRANSLATORS: Helptext for an Europeans ware: Copper Coin
#: addons/europeans_all.wad/tribes/initialization/units.lua:838 input:838
#: standard
msgctxt "ware"
msgid ""
"Copper coins are money made of copper or bronze (copper and tin). Its the "
"standard barter object."
msgstr ""
"Koperen munten zijn geld gemaakt van koper of brons (koper en tin). Het is "
"het standaard ruilobject."

#. TRANSLATORS: Helptext for an Europeans ware: Silver Coin
#: addons/europeans_all.wad/tribes/initialization/units.lua:849 input:849
#: standard
msgctxt "ware"
msgid "Silver coins are money made of silver. Its a valuable barter object."
msgstr ""
"Zilver munten zijn geld gemaakt van zilver. Het is een waardevol ruilobject."

#. TRANSLATORS: Helptext for an Europeans ware: Gold Coin
#: addons/europeans_all.wad/tribes/initialization/units.lua:860 input:860
#: standard
msgctxt "ware"
msgid "Gold coins are money made of gold. Its most valuable barter object."
msgstr ""
"Gouden munten zijn geld gemaakt van goud. Het meest waardevolle ruilobject."

#. TRANSLATORS: Helptext for an Empire ware: Felling Ax, part 1
#: addons/europeans_all.wad/tribes/initialization/units.lua:874 input:874
#: standard
msgctxt "ware"
msgid "The felling ax is the tool to chop down trees."
msgstr "De kapbijl is het gereedschap om bomen om te hakken."

#. TRANSLATORS: Helptext for an Empire ware: Felling Ax, part 2
#: addons/europeans_all.wad/tribes/initialization/units.lua:876 input:876
#: standard
msgctxt "empire_ware"
msgid "Felling axes are used by lumberjacks and produced by the toolsmithy."
msgstr ""
"Hakbijlen worden gebruikt door houthakkers en worden geproduceerd door de "
"werktuigsmederij."

#. TRANSLATORS: Helptext for an Amazon ware: Machete
#: addons/europeans_all.wad/tribes/initialization/units.lua:887 input:887
#: standard
msgctxt "amazons_ware"
msgid "The machete is the tool of the liana cutters."
msgstr "De machete is het gereedschap van de lianensnijders."

#. TRANSLATORS: Helptext for an Empire ware: Saw
#: addons/europeans_all.wad/tribes/initialization/units.lua:897 input:897
#: standard
msgctxt "empire_ware"
msgid "This saw is needed by the carpenter. It is produced by the toolsmith."
msgstr ""
"Deze zaag is nodig voor de houtbewerker. Hij wordt gemaakt door de "
"werktuigsmid."

#. TRANSLATORS: Helptext for an Empire ware: Pick
#: addons/europeans_all.wad/tribes/initialization/units.lua:906 input:906
#: standard
msgctxt "empire_ware"
msgid ""
"Picks are used by stonemasons and miners. They are produced by the toolsmith."
msgstr ""
"Picks worden gebruikt door steenhouwers en mijnwerkers. Ze worden "
"geproduceerd door de werktuigsmid."

#. TRANSLATORS: Helptext for an Empire ware: Shovel, part 1
#: addons/europeans_all.wad/tribes/initialization/units.lua:916 input:916
#: standard
msgctxt "ware"
msgid "Shovels are needed for the proper handling of plants."
msgstr "Schoppen zijn nodig om de planten goed te kunnen hanteren."

#. TRANSLATORS: Helptext for an Empire ware: Shovel, part 2
#: addons/europeans_all.wad/tribes/initialization/units.lua:918 input:918
#: standard
msgctxt "empire_ware"
msgid ""
"Therefore the forester and the vine farmer use them. They are produced by "
"the toolsmith."
msgstr ""
"Daarom gebruiken de boswachter en de wijnboer ze. Ze worden geproduceerd "
"door de werktuigsmid."

#. TRANSLATORS: Helptext for an Empire ware: Scythe, part 1
#: addons/europeans_all.wad/tribes/initialization/units.lua:929 input:929
#: standard
msgctxt "ware"
msgid "The scythe is the tool of the farmers."
msgstr "De zeis is het gereedschap van de boeren."

#. TRANSLATORS: Helptext for an Empire ware: Scythe, part 2
#: addons/europeans_all.wad/tribes/initialization/units.lua:931 input:931
#: standard
msgctxt "empire_ware"
msgid "Scythes are produced by the toolsmith."
msgstr "Zeisen worden gemaakt door de werktuigsmid."

#. TRANSLATORS: Helptext for an Atlantean ware: Milking Tongs
#: addons/europeans_all.wad/tribes/initialization/units.lua:941 input:941
#: standard
msgctxt "atlanteans_ware"
msgid ""
"Milking tongs are used by the spider breeder to milk the spiders. They are "
"produced by the toolsmith."
msgstr ""
"Melktangen worden door de spinnenkweker gebruikt om de spinnen te melken. Ze "
"worden geproduceerd door de werktuigsmid."

#. TRANSLATORS: Helptext for an Empire ware: Fire Tongs, part 1
#: addons/europeans_all.wad/tribes/initialization/units.lua:951 input:951
#: standard
msgctxt "ware"
msgid "Fire tongs are the tools for smelting ores."
msgstr "Vuurtangen zijn de gereedschappen voor het smelten van ertsen."

#. TRANSLATORS: Helptext for an Empire ware: Fire Tongs, part 2
#: addons/europeans_all.wad/tribes/initialization/units.lua:953 input:953
#: standard
msgctxt "empire_ware"
msgid "They are used in the smelting works and produced by the toolsmith."
msgstr "Ze worden gebruikt in de hoogoven en gemaakt door de werktuigsmid."

#. TRANSLATORS: Helptext for an Empire ware: Hammer, part 1
#: addons/europeans_all.wad/tribes/initialization/units.lua:964 input:964
#: standard
msgctxt "ware"
msgid "The hammer is an essential tool."
msgstr "De hamer is een essentieel gereedschap."

#. TRANSLATORS: Helptext for an Empire ware: Hammer, part 2
#: addons/europeans_all.wad/tribes/initialization/units.lua:966 input:966
#: standard
msgctxt "empire_ware"
msgid ""
"Geologists, builders, weaponsmiths and armorsmiths all need a hammer. Make "
"sure you’ve always got some in reserve! They are produced by the toolsmith."
msgstr ""
"Geologen, bouwvakkers, wapensmeden en wapenmakers hebben allemaal een hamer "
"nodig. Zorg ervoor dat je er altijd een paar achter de hand hebt! Ze worden "
"gemaakt door de werktuigsmid."

#. TRANSLATORS: Helptext for an Amazon ware: Chisel, part 1
#: addons/europeans_all.wad/tribes/initialization/units.lua:977 input:977
#: standard
msgctxt "ware"
msgid "The chisel is an essential tool."
msgstr "De beitel is een onmisbaar gereedschap."

#. TRANSLATORS: Helptext for an Amazon ware: Chisel, part 2
#: addons/europeans_all.wad/tribes/initialization/units.lua:979 input:979
#: standard
msgctxt "amazons_ware"
msgid ""
"Stone carvers need a chisel. Make sure you’ve always got some in reserve! "
"They are produced by the stone carvers themselves."
msgstr ""
"Steenhouwers hebben een beitel nodig. Zorg ervoor dat je er altijd een paar "
"in reserve hebt! Ze worden door de steenhouwers zelf gemaakt."

#. TRANSLATORS: Helptext for an Amazon ware: Needles
#: addons/europeans_all.wad/tribes/initialization/units.lua:990 input:990
#: standard
msgctxt "amazons_ware"
msgid ""
"Needles are used by dressmakers to make dresses, boots and armor for the "
"soldiers."
msgstr ""
"Naalden worden door kleermakers gebruikt om jurken, laarzen en harnassen "
"voor soldaten te maken."

#. TRANSLATORS: Helptext for an Empire ware: Basket
#: addons/europeans_all.wad/tribes/initialization/units.lua:1003 input:1003
#: standard
msgctxt "empire_ware"
msgid ""
"This basket is needed by the vine farmer for harvesting the grapes. It is "
"produced by the toolsmith."
msgstr ""
"Deze mand wordt door de wijnboer gebruikt voor het oogsten van de druiven. "
"Hij wordt vervaardigd door de werktuigsmid."

#. TRANSLATORS: Helptext for an Atlantean ware: Fishing Net
#: addons/europeans_all.wad/tribes/initialization/units.lua:1012 input:1012
#: standard
msgctxt "atlanteans_ware"
msgid "The fishing net is used by the fisher and produced by the toolsmith."
msgstr ""
"Het visnet wordt gebruikt door de visser en gemaakt door de werktuigsmit."

#. TRANSLATORS: Helptext for a Barbarian ware: Fishing Rod, part 1
#: addons/europeans_all.wad/tribes/initialization/units.lua:1022 input:1022
#: standard
msgctxt "ware"
msgid "Fishing rods are needed by fishers to catch fish."
msgstr "Vissers hebben hengels nodig om vis te vangen."

#. TRANSLATORS: Helptext for a Barbarian ware: Fishing Rod, part 2
#: addons/europeans_all.wad/tribes/initialization/units.lua:1024 input:1024
#: standard
msgctxt "barbarians_ware"
msgid ""
"They are one of the basic tools produced in a metal workshop (but cease to "
"be produced by the building if it is enhanced to an ax workshop and war "
"mill)."
msgstr ""
"Ze zijn een van de basisgereedschappen die in een metaalwerkplaats worden "
"geproduceerd (maar worden niet meer geproduceerd door het gebouw als het "
"wordt opgewaardeerd tot een bijlwerkplaats en oorlogsmanufactuur)."

#. TRANSLATORS: Helptext for an Atlantean ware: Buckets
#: addons/europeans_all.wad/tribes/initialization/units.lua:1034 input:1034
#: standard
msgctxt "atlanteans_ware"
msgid "Big buckets for the fish breeder – produced by the toolsmith."
msgstr "Grote emmers voor de viskweker – gemaakt door de werktuigsmid."

#. TRANSLATORS: Helptext for an Atlantean ware: Hunting Bow
#: addons/europeans_all.wad/tribes/initialization/units.lua:1043 input:1043
#: standard
msgctxt "atlanteans_ware"
msgid ""
"This bow is used by the Atlantean hunter. It is produced by the toolsmith."
msgstr ""
"Deze boog wordt gebruikt door de Atlanteense jager. Hij wordt gemaakt door "
"de werktuigsmid."

#. TRANSLATORS: Helptext for an Empire ware: Hunting Spear, part 1
#: addons/europeans_all.wad/tribes/initialization/units.lua:1053 input:1053
#: standard
msgctxt "ware"
msgid ""
"This spear is light enough to be thrown, but heavy enough to kill any animal "
"in one blow. It is only used by hunters."
msgstr ""
"Deze speer is licht genoeg om te worden geworpen, maar zwaar genoeg om elk "
"dier met één slag te doden. Hij wordt alleen gebruikt door jagers."

#. TRANSLATORS: Helptext for an Empire ware: Hunting Spear, part 2
#: addons/europeans_all.wad/tribes/initialization/units.lua:1055 input:1055
#: standard
msgctxt "empire_ware"
msgid "They are produced by the toolsmith."
msgstr "Ze worden gemaakt door de werktuigsmid."

#. TRANSLATORS: Helptext for an Atlantean ware: Hook Pole
#: addons/europeans_all.wad/tribes/initialization/units.lua:1065 input:1065
#: standard
msgctxt "atlanteans_ware"
msgid ""
"This hook pole is used by the smoker to suspend all the meat and fish from "
"the top of the smokery. It is created by the toolsmith."
msgstr ""
"Deze rookhaak wordt gebruikt door de roker om al het vlees en de vis aan de "
"bovenkant van de rokerij te hangen. Hij is gemaakt door de werktuigsmid."

#. TRANSLATORS: Helptext for an Empire ware: Bread Paddle, part 1
#: addons/europeans_all.wad/tribes/initialization/units.lua:1075 input:1075
#: standard
msgctxt "ware"
msgid "The bread paddle is the tool of the baker, each baker needs one."
msgstr ""
"De broodschep is het gereedschap van de bakker, elke bakker heeft er een "
"nodig."

#. TRANSLATORS: Helptext for an Empire ware: Bread Paddle, part 2
#: addons/europeans_all.wad/tribes/initialization/units.lua:1077 input:1077
#: standard
msgctxt "empire_ware"
msgid "Bread paddles are produced by the toolsmith."
msgstr "Broodscheppen worden gemaakt door de werktuigsmid."

#. TRANSLATORS: Helptext for an Empire ware: Kitchen Tools
#: addons/europeans_all.wad/tribes/initialization/units.lua:1087 input:1087
#: standard
msgctxt "empire_ware"
msgid ""
"Kitchen tools are needed for preparing rations and meals. They are produced "
"in a toolsmithy and used in taverns and inns."
msgstr ""
"Keukengerei is nodig voor het bereiden van rantsoenen en maaltijden. Het "
"wordt geproduceerd in een werktuigsmederij en gebruikt in tavernes en "
"herbergen."

#. TRANSLATORS: Helptext for an Amazon ware: Stone Bowl
#: addons/europeans_all.wad/tribes/initialization/units.lua:1097 input:1097
#: standard
msgctxt "amazons_ware"
msgid "Stone bowls are used to wash gold and to smelt gold dust."
msgstr ""
"Stenen kommen worden gebruikt om goud te wassen en goudstof te smelten."

#. TRANSLATORS: Helptext for an Amazon ware: Firestones
#: addons/europeans_all.wad/tribes/initialization/units.lua:1108 input:1108
#: standard
msgctxt "amazons_ware"
msgid "Firestones are used to light the fires of charcoal kilns and furnaces."
msgstr ""
"Vuurstenen worden gebruikt om de vuren van houtskool- en smeltovens aan te "
"steken."

#. TRANSLATORS: Helptext for an Atlantean ware: Light Trident
#: addons/europeans_all.wad/tribes/initialization/units.lua:1121 input:1121
#: standard
msgctxt "atlanteans_ware"
msgid ""
"This is the basic weapon of the Atlantean soldiers. Together with a tabard, "
"it makes up the equipment of young soldiers. Light tridents are produced in "
"the weapon smithy as are all other tridents."
msgstr ""
"Dit is het basiswapen van de Atlanteense soldaten. Samen met een tabberd "
"vormt het de uitrusting van jonge soldaten. Lichte drietanden worden net als "
"alle andere drietanden in de wapensmederij gemaakt."

#. TRANSLATORS: Helptext for an Atlantean ware: Long Trident
#: addons/europeans_all.wad/tribes/initialization/units.lua:1130 input:1130
#: standard
msgctxt "atlanteans_ware"
msgid ""
"The long trident is the first trident in the training of soldiers. It is "
"produced in the weapon smithy and used in the dungeon – together with food – "
"to train soldiers from attack level 0 to level 1."
msgstr ""
"De lange drietand is de eerste drietand in de training van soldaten. Hij "
"wordt geproduceerd in de wapensmederij en gebruikt in de kerker – samen met "
"voedsel – om soldaten te trainen van aanvalsniveau 0 tot niveau 1."

#. TRANSLATORS: Helptext for an Atlantean ware: Steel Trident
#: addons/europeans_all.wad/tribes/initialization/units.lua:1139 input:1139
#: standard
msgctxt "atlanteans_ware"
msgid ""
"This is the medium trident. It is produced in the weapon smithy and used by "
"advanced soldiers in the dungeon – together with food – to train from attack "
"level 1 to level 2."
msgstr ""
"Dit is de middelgrote drietand. Hij wordt gemaakt in de wapensmederij en "
"gebruikt door gevorderde soldaten in de kerker – samen met voedsel – om van "
"aanvalsniveau 1 naar niveau 2 te trainen."

#. TRANSLATORS: Helptext for an Atlantean ware: Double Trident
#: addons/europeans_all.wad/tribes/initialization/units.lua:1148 input:1148
#: standard
msgctxt "atlanteans_ware"
msgid ""
"The double trident is one of the best tridents produced by the Atlantean "
"weapon smithy. It is used in a dungeon – together with food – to train "
"soldiers from attack level 2 to level 3."
msgstr ""
"De dubbele drietand is een van de beste drietanden die door de wapensmid van "
"Atlantis worden geproduceerd. Hij wordt in een kerker gebruikt – samen met "
"voedsel – om soldaten te trainen van aanvalsniveau 2 naar niveau 3."

#. TRANSLATORS: Helptext for an Atlantean ware: Heavy Double Trident
#: addons/europeans_all.wad/tribes/initialization/units.lua:1157 input:1157
#: standard
msgctxt "atlanteans_ware"
msgid ""
"This is the most dangerous weapon of the Atlantean military. Only the best "
"of the best soldiers may use it. It is produced in the weapon smithy and "
"used in the dungeon – together with food – to train soldiers from attack "
"level 3 to level 4."
msgstr ""
"Dit is het gevaarlijkste wapen van het Atlanteaanse leger. Alleen de "
"allerbeste soldaten mogen het gebruiken. Het wordt geproduceerd in de "
"wapensmederij en gebruikt in de kerker – samen met voedsel – om soldaten van "
"aanvalsniveau 3 tot niveau 4 te trainen."

#. TRANSLATORS: Helptext for a Barbarian ware: Ax
#: addons/europeans_all.wad/tribes/initialization/units.lua:1166 input:1166
#: standard
msgctxt "barbarians_ware"
msgid ""
"The ax is the basic weapon of the Barbarians. All young soldiers are "
"equipped with it."
msgstr ""
"De bijl is het basiswapen van de barbaren. Alle jonge soldaten zijn ermee "
"uitgerust."

#. TRANSLATORS: Helptext for a Barbarian ware: Sharp Ax
#: addons/europeans_all.wad/tribes/initialization/units.lua:1175 input:1175
#: standard
msgctxt "barbarians_ware"
msgid ""
"Young soldiers are proud to learn to fight with this powerful weapon. It is "
"heavier and sharper than the ordinary ax. It is produced in ax workshops and "
"war mills. In training camps, it is used – together with food – to train "
"soldiers from attack level 0 to level 1."
msgstr ""
"Jonge soldaten zijn er trots op dat ze leren vechten met dit krachtige "
"wapen. Het is zwaarder en scherper dan een gewone bijl. Het wordt "
"geproduceerd in bijlwerkplaatsen en oorlogsmolens. In trainingskampen wordt "
"het – samen met voedsel – gebruikt om soldaten te trainen van aanvalsniveau "
"0 naar niveau 1."

#. TRANSLATORS: Helptext for a Barbarian ware: Broad Ax
#: addons/europeans_all.wad/tribes/initialization/units.lua:1184 input:1184
#: standard
msgctxt "barbarians_ware"
msgid ""
"The broad ax is produced by the ax workshop and the war mill. It is used in "
"the training camp – together with food – to train soldiers with a "
"fundamental fighting knowledge from attack level 1 to attack level 2."
msgstr ""
"De brede bijl wordt geproduceerd door de bijlwerkplaats en de "
"oorlogsmanufactuur. Hij wordt gebruikt in het trainingskamp – samen met "
"voedsel – om soldaten te trainen in fundamentele gevechtstechnieken van "
"aanvalsniveau 1 tot aanvalsniveau 2."

#. TRANSLATORS: Helptext for a Barbarian ware: Bronze Ax
#: addons/europeans_all.wad/tribes/initialization/units.lua:1193 input:1193
#: standard
msgctxt "barbarians_ware"
msgid ""
"The bronze ax is considered a weapon that is hard to handle. Only skilled "
"soldiers can use it. It is produced at the war mill and used in the training "
"camp – together with food – to train soldiers from attack level 2 to level 3."
msgstr ""
"De bronzen bijl wordt beschouwd als een wapen dat moeilijk te hanteren is. "
"Alleen ervaren soldaten kunnen het gebruiken. Het wordt geproduceerd in de "
"oorlogsmanufactuur en gebruikt in het trainingskamp – samen met voedsel – om "
"soldaten te trainen van aanvalsniveau 2 naar niveau 3."

#. TRANSLATORS: Helptext for a Barbarian ware: Battle Ax
#: addons/europeans_all.wad/tribes/initialization/units.lua:1202 input:1202
#: standard
msgctxt "barbarians_ware"
msgid ""
"This is a dangerous weapon the Barbarians are able to produce. It is "
"produced in the war mill. Only trained soldiers are able to wield such a "
"weapon. It is used – together with food – in the training camp to train "
"soldiers from attack level 3 to 4."
msgstr ""
"Dit is een gevaarlijk wapen dat de barbaren kunnen produceren. Het wordt "
"geproduceerd in de oorlogsmanufactuur. Alleen getrainde soldaten kunnen zo'n "
"wapen hanteren. Het wordt – samen met voedsel – gebruikt in het "
"trainingskamp om soldaten te trainen van aanvalsniveau 3 naar 4."

#. TRANSLATORS: Helptext for a Barbarian ware: Warrior’s Ax
#: addons/europeans_all.wad/tribes/initialization/units.lua:1211 input:1211
#: standard
msgctxt "barbarians_ware"
msgid ""
"The warrior’s ax is the most dangerous of all Barbarian weapons. Only a few "
"soldiers ever were able to handle this huge and powerful ax. It is produced "
"in a war mill and used – together with food – in a training camp to train "
"soldiers from attack level 4 to level 5."
msgstr ""
"De oorlogsbijl van de krijger is het gevaarlijkste wapen van alle barbaarse "
"wapens. Slechts enkele soldaten waren in staat om deze enorme en krachtige "
"bijl te hanteren. Hij wordt geproduceerd in een oorlogsmanufactuur en "
"gebruikt – samen met voedsel – in een trainingskamp om soldaten te trainen "
"van aanvalsniveau 4 naar niveau 5."

#. TRANSLATORS: Helptext for an Amazon ware: Wooden Spear, part 1
#: addons/europeans_all.wad/tribes/initialization/units.lua:1224 input:1224
#: standard
msgctxt "amazons_ware"
msgid ""
"This spear is the basic weapon in the Amazon military system. It is produced "
"by the stone carver. In combination with a tunic, it is the equipment to fit "
"out young soldiers."
msgstr ""
"Deze speer is het basiswapen in het militaire systeem van de Amazones. Hij "
"wordt vervaardigd door de steenhouwer. In combinatie met een tuniek vormt "
"hij de uitrusting voor jonge soldaten."

#. TRANSLATORS: Helptext for an Amazon ware: Wooden Spear, part 2
#: addons/europeans_all.wad/tribes/initialization/units.lua:1226 input:1226
#: standard
msgctxt "amazons_ware"
msgid "It is used by the Amazon hunter-gatherers as well."
msgstr "Het wordt ook gebruikt door Amazone-jagers-verzamelaars."

#. TRANSLATORS: Helptext for an Empire ware: Spear
#: addons/europeans_all.wad/tribes/initialization/units.lua:1236 input:1236
#: standard
msgctxt "empire_ware"
msgid ""
"This spear has an iron spike. It is produced in a weapon smithy and used in "
"a training camp – together with food – to train soldiers from attack level 0 "
"to attack level 1."
msgstr ""
"Deze speer heeft een ijzeren punt. Hij wordt geproduceerd in een "
"wapensmederij en gebruikt in een trainingskamp – samen met voedsel – om "
"soldaten te trainen van aanvalsniveau 0 naar aanvalsniveau 1."

#. TRANSLATORS: Helptext for an Amazon ware: Stone Tipped Spear
#: addons/europeans_all.wad/tribes/initialization/units.lua:1246 input:1246
#: standard
msgctxt "amazons_ware"
msgid ""
"This spear has a stone spike. It is produced in a stone workshop and used in "
"a warriors’ gathering – together with food – to train soldiers from attack "
"level 0 to attack level 1."
msgstr ""
"Deze speer heeft een stenen punt. Hij wordt vervaardigd in een "
"steenbewerkingsatelier en gebruikt tijdens een bijeenkomst van krijgers – "
"samen met voedsel – om soldaten te trainen van aanvalsniveau 0 naar "
"aanvalsniveau 1."

#. TRANSLATORS: Helptext for an Amazon ware: Hardened Spear
#: addons/europeans_all.wad/tribes/initialization/units.lua:1257 input:1257
#: standard
msgctxt "amazons_ware"
msgid ""
"This is a hardened spear with a stone tip. It is produced in a stone "
"workshop and used in a warriors’ gathering – together with food – to train "
"soldiers from attack level 1 to level 2."
msgstr ""
"Dit is een geharde speer met een stenen punt. Hij wordt vervaardigd in een "
"steenbewerkingsatelier en gebruikt tijdens een bijeenkomst van krijgers – "
"samen met voedsel – om soldaten te trainen van aanvalsniveau 1 naar niveau 2."

#. TRANSLATORS: Helptext for an Empire ware: Advanced Spear
#: addons/europeans_all.wad/tribes/initialization/units.lua:1267 input:1267
#: standard
msgctxt "empire_ware"
msgid ""
"This is an advanced spear with a steel tip. It is produced in a weapon "
"smithy and used in a training camp – together with food – to train soldiers "
"from attack level 1 to level 2."
msgstr ""
"Dit is een geavanceerde speer met een stalen punt. Hij wordt geproduceerd in "
"een wapensmederij en gebruikt in een trainingskamp – samen met voedsel – om "
"soldaten te trainen van aanvalsniveau 1 naar niveau 2."

#. TRANSLATORS: Helptext for an Empire ware: Heavy Spear
#: addons/europeans_all.wad/tribes/initialization/units.lua:1276 input:1276
#: standard
msgctxt "empire_ware"
msgid ""
"This is a strong spear with a steel-tip and a little blade. It is produced "
"in the weapon smithy and used in the training camp – together with food – "
"train soldiers from attack level 2 to level 3."
msgstr ""
"Dit is een sterke speer met een stalen punt en een klein lemmet. Hij wordt "
"geproduceerd in de wapensmederij en gebruikt in het trainingskamp – samen "
"met voedsel – om soldaten te trainen van aanvalsniveau 2 naar niveau 3."

#. TRANSLATORS: Helptext for an Empire ware: War Spear
#: addons/europeans_all.wad/tribes/initialization/units.lua:1285 input:1285
#: standard
msgctxt "empire_ware"
msgid ""
"This is the best and sharpest weapon the Empire weaponsmith creates for the "
"soldiers. It is used in the training camp – together with food – to train "
"soldiers from attack level 3 to level 4."
msgstr ""
"Dit is het beste en scherpste wapen dat de Keizerlijke wapensmid van het "
"Keizerrijk voor de soldaten maakt. Het wordt in het trainingskamp gebruikt – "
"samen met voedsel – om soldaten van aanvalsniveau 3 naar niveau 4 te trainen."

#. TRANSLATORS: Helptext for a Frisian ware: Short sword
#: addons/europeans_all.wad/tribes/initialization/units.lua:1294 input:1294
#: standard
msgctxt "frisians_ware"
msgid ""
"This is the basic weapon of the Frisian soldiers. Together with a fur "
"garment, it makes up the equipment of young soldiers. Short swords are "
"produced by the small armor smithy."
msgstr ""
"Dit is het basiswapen van de Friese soldaten. Samen met een bont kledingstuk "
"vormt het de uitrusting van jonge soldaten. Korte zwaarden worden "
"geproduceerd door de kleine harnassmederij."

#. TRANSLATORS: Helptext for a Frisian ware: Long Sword
#: addons/europeans_all.wad/tribes/initialization/units.lua:1303 input:1303
#: standard
msgctxt "frisians_ware"
msgid ""
"The long sword is the weapon used by level 1 soldiers. Level 4 soldiers are "
"equipped with a long and a double-edged sword."
msgstr ""
"Het lange zwaard is het wapen dat wordt gebruikt door soldaten van niveau 1. "
"Soldaten van niveau 4 zijn uitgerust met een lang zwaard en een tweesnijdend "
"zwaard."

#. TRANSLATORS: Helptext for a Frisian ware: Broadsword
#: addons/europeans_all.wad/tribes/initialization/units.lua:1312 input:1312
#: standard
msgctxt "frisians_ware"
msgid ""
"The broadsword is the weapon used by level 2 soldiers. Level 5 soldiers are "
"equipped with a broadsword and a double-edged sword."
msgstr ""
"Het slagzwaard is het wapen dat wordt gebruikt door soldaten van niveau 2. "
"Soldaten van niveau 5 zijn uitgerust met een slagzwaard en een tweesnijdend "
"zwaard."

#. TRANSLATORS: Helptext for a Frisian ware: Double-edged Sword
#: addons/europeans_all.wad/tribes/initialization/units.lua:1321 input:1321
#: standard
msgctxt "frisians_ware"
msgid ""
"The double-edged sword is the weapon used by level 3 soldiers. Level 6 "
"soldiers are equipped with two of these ferocious swords."
msgstr ""
"Het tweesnijdende zwaard is het wapen dat wordt gebruikt door soldaten van "
"niveau 3. Soldaten van niveau 6 zijn uitgerust met twee van deze woeste "
"zwaarden."

#. TRANSLATORS: Helptext for an Amazon ware: Sturdy Boots
#: addons/europeans_all.wad/tribes/initialization/units.lua:1334 input:1334
#: standard
msgctxt "amazons_ware"
msgid ""
"Sturdy boots are excellent footwear for soldiers to be quicker on their "
"feet. They are produced by the dressmaker and used to train soldiers’ evade "
"from level 0 to level 1."
msgstr ""
"Stevige laarzen zijn uitstekend schoeisel voor soldaten om sneller ter been "
"te zijn. Ze worden gemaakt door de kleermaker en worden gebruikt om het "
"ontwijken van soldaten te trainen van niveau 0 tot niveau 1."

#. TRANSLATORS: Helptext for an Amazon ware: Swift Boots
#: addons/europeans_all.wad/tribes/initialization/units.lua:1345 input:1345
#: standard
msgctxt "amazons_ware"
msgid ""
"Swift boots are light and durable footwear for soldiers to be quicker on "
"their feet. They are produced by the dressmaker and used to train soldiers’ "
"evade from level 1 to level 2."
msgstr ""
"Vlugge laarzen zijn licht en duurzaam schoeisel voor soldaten om sneller ter "
"been te zijn. Ze worden gemaakt door de kleermaker en worden gebruikt om het "
"ontwijken van soldaten te trainen van niveau 1 naar niveau 2."

#. TRANSLATORS: Helptext for an Amazon ware: Hero Boots
#: addons/europeans_all.wad/tribes/initialization/units.lua:1356 input:1356
#: standard
msgctxt "amazons_ware"
msgid ""
"Hero boots! The only suitable footwear for a real hero. They are produced by "
"the dressmaker and used to train soldiers’ evade from level 2 to level 3."
msgstr ""
"Heldenlaarzen! Het enige geschikte schoeisel voor een echte held. Ze worden "
"gemaakt door de kleermaker en gebruikt om het ontwijken van soldaten te "
"trainen van niveau 2 naar niveau 3."

#. TRANSLATORS: Helptext for an Amazon ware: Wodden Helmet
#: addons/europeans_all.wad/tribes/initialization/units.lua:1367 input:1367
#: standard
msgctxt "amazons_ware"
msgid ""
"A wooden helmet is a basic piece of equipment for protecting soldiers. It is "
"produced by the dressmaker and used to train soldiers from health level 1 to "
"level 2."
msgstr ""
"Een houten helm is een basisuitrusting voor de bescherming van soldaten. Hij "
"wordt geproduceerd door de kleermaker en gebruikt om soldaten te trainen van "
"gezondheidsniveau 1 naar niveau 2."

#. TRANSLATORS: Helptext for an Empire ware: Helmet
#: addons/europeans_all.wad/tribes/initialization/units.lua:1377 input:1377
#: standard
msgctxt "empire_ware"
msgid "The helmet is the basic defense of a soldier."
msgstr "De helm is de basisbescherming van een soldaat."

#. TRANSLATORS: Helptext for a Barbarian ware: Helmet
#: addons/europeans_all.wad/tribes/initialization/units.lua:1386 input:1386
#: standard
msgctxt "barbarians_ware"
msgid "A helmet is a basic tool to protect soldiers."
msgstr "Een helm is een basisuitrusting om soldaten te beschermen."

#. TRANSLATORS: Helptext for a Barbarian ware: Mask
#: addons/europeans_all.wad/tribes/initialization/units.lua:1395 input:1395
#: standard
msgctxt "barbarians_ware"
msgid ""
"A mask is an enhanced armor for Barbarian soldiers. It is produced in the "
"helm smithy and used in the training camp – together with food – to train "
"soldiers from health level 1 to level 2."
msgstr ""
"Een masker is een verbeterd pantser voor barbaarse soldaten. Het wordt "
"geproduceerd in de helmsmederij en gebruikt in het trainingskamp – samen met "
"voedsel – om soldaten te trainen van gezondheidsniveau 1 naar niveau 2."

#. TRANSLATORS: Helptext for an Atlantean ware: Steel Shield
#: addons/europeans_all.wad/tribes/initialization/units.lua:1404 input:1404
#: standard
msgctxt "atlanteans_ware"
msgid ""
"This steel shield is produced in the armor smithy and used in the labyrinth "
"– together with food – to train soldiers from defense level 0 to level 1."
msgstr ""
"Dit stalen schild wordt geproduceerd in de wapensmederij en gebruikt in het "
"labyrint – samen met voedsel – om soldaten te trainen van verdedigingsniveau "
"0 tot niveau 1."

#. TRANSLATORS: Helptext for a Frisian ware: Golden Helmet
#: addons/europeans_all.wad/tribes/initialization/units.lua:1413 input:1413
#: standard
msgctxt "frisians_ware"
msgid "A golden helmet protects soldiers."
msgstr "Een gouden helm beschermt soldaten."

#. TRANSLATORS: Helptext for a Barbarian ware: Warhelm
#: addons/europeans_all.wad/tribes/initialization/units.lua:1422 input:1422
#: standard
msgctxt "barbarians_ware"
msgid "This is the most enhanced Barbarian armor."
msgstr "Dit is het meest verbeterde barbaarse harnas."

#. TRANSLATORS: Helptext for an Atlantean ware: Advanced Shield
#: addons/europeans_all.wad/tribes/initialization/units.lua:1431 input:1431
#: standard
msgctxt "atlanteans_ware"
msgid ""
"These advanced shields are used by the best soldiers of the Atlanteans. They "
"are produced in the armor smithy and used in the labyrinth – together with "
"food – to train soldiers from defense level 1 to level 2."
msgstr ""
"Deze geavanceerde schilden worden gebruikt door de beste soldaten van de "
"Atlantiërs. Ze worden geproduceerd in de wapensmederij en gebruikt in het "
"labyrint – samen met voedsel – om soldaten van verdedigingsniveau 1 tot "
"niveau 2 te trainen."

#. TRANSLATORS: Helptext for a Frisian ware: Fur Garment
#: addons/europeans_all.wad/tribes/initialization/units.lua:1443 input:1443
#: standard
msgctxt "frisians_ware"
msgid "Fur can be sewn into garments. They are used as basic armor."
msgstr ""
"Vacht kan in kledingstukken worden genaaid. Ze worden gebruikt als "
"basisbescherming."

#. TRANSLATORS: Helptext for an Atlantean ware: Tabard
#: addons/europeans_all.wad/tribes/initialization/units.lua:1452 input:1452
#: standard
msgctxt "atlanteans_ware"
msgid ""
"A tabard and a light trident are the basic equipment for young soldiers."
msgstr ""
"Een tabberd en een lichte drietand zijn de basisuitrusting voor jonge "
"soldaten."

#. TRANSLATORS: Helptext for an Amazon ware: Tunic
#: addons/europeans_all.wad/tribes/initialization/units.lua:1462 input:1462
#: standard
msgctxt "amazons_ware"
msgid ""
"Rubber can be bound into a tunic, which is used as basic armor. All new "
"soldiers are clothed in a tunic."
msgstr ""
"Rubber kan worden verwerkt tot een tuniek, die wordt gebruikt als "
"basisbescherming. Alle nieuwe soldaten worden gekleed in een tuniek."

#. TRANSLATORS: Helptext for an Amazon ware: Wooden Armor
#: addons/europeans_all.wad/tribes/initialization/units.lua:1473 input:1473
#: standard
msgctxt "amazons_ware"
msgid "This light wooden armor is a basic piece of armor."
msgstr "Dit lichte houten harnas is een basisstuk van een harnas."

#. TRANSLATORS: Helptext for an Empire ware: Armor
#: addons/europeans_all.wad/tribes/initialization/units.lua:1483 input:1483
#: standard
msgctxt "empire_ware"
msgid "Basic armor for Empire soldiers."
msgstr "Basisuitrusting voor soldaten van het Keizerrijk."

#. TRANSLATORS: Helptext for a Frisian ware: Studded Fur Garment
#: addons/europeans_all.wad/tribes/initialization/units.lua:1492 input:1492
#: standard
msgctxt "frisians_ware"
msgid ""
"Ordinary fur garments can be decorated with iron to give them a silvery "
"shine. These clothes make good armor."
msgstr ""
"Gewone vachtkledingstukken kunnen met ijzer worden versierd om ze een "
"zilverachtige glans te geven. Deze kledingstukken vormen een goede "
"bescherming."

#. TRANSLATORS: Helptext for an Amazon ware: Padded Vest
#: addons/europeans_all.wad/tribes/initialization/units.lua:1502 input:1502
#: standard
msgctxt "amazons_ware"
msgid "Padded vests are light but durable armor."
msgstr "Gewatteerde vesten zijn lichte maar duurzame beschermende kleding."

#. TRANSLATORS: Helptext for an Empire ware: Chain Armor
#: addons/europeans_all.wad/tribes/initialization/units.lua:1512 input:1512
#: standard
msgctxt "empire_ware"
msgid "The chain armor is a medium armor for soldiers."
msgstr "Het maliënkolder is een middelgroot harnas voor soldaten."

#. TRANSLATORS: Helptext for an Amazon ware: Padded Protector
#: addons/europeans_all.wad/tribes/initialization/units.lua:1522 input:1522
#: standard
msgctxt "amazons_ware"
msgid "Padded protectors are strong and durable armor."
msgstr "Gewatteerde beschermers zijn sterke en duurzame beschermingsmiddelen."

#. TRANSLATORS: Helptext for an Empire ware: Gilded Armor
#: addons/europeans_all.wad/tribes/initialization/units.lua:1532 input:1532
#: standard
msgctxt "empire_ware"
msgid "The gilded armor is the strongest armor an soldier can have."
msgstr "Het vergulde harnas is het sterkste harnas dat een soldaat kan hebben."

#. TRANSLATORS: Helptext for a Frisian ware: Golden Fur Garment
#: addons/europeans_all.wad/tribes/initialization/units.lua:1541 input:1541
#: standard
msgctxt "frisians_ware"
msgid ""
"Ordinary fur garments can be decorated with iron and gold. Such clothes are "
"the best armor."
msgstr ""
"Gewone vachtkleding kan worden versierd met ijzer en goud. Dergelijke "
"kleding is de beste bescherming."

#. TRANSLATORS: Helptext for an Atlantean ware: Golden Tabard
#: addons/europeans_all.wad/tribes/initialization/units.lua:1550 input:1550
#: standard
msgctxt "atlanteans_ware"
msgid "Golden tabards are produced in weaving mills out of gold thread."
msgstr "Gouden tabards worden in weverijen gemaakt van gouddraad."

#. TRANSLATORS: Helptext for an Amazon ware: Warrior's Coat
#: addons/europeans_all.wad/tribes/initialization/units.lua:1560 input:1560
#: standard
msgctxt "amazons_ware"
msgid ""
"Ordinary tunics can be decorated and reinforced with gold and wood chunks. "
"Such tunics are the best armor."
msgstr ""
"Gewone tunieken kunnen worden versierd en versterkt met goud en stukken "
"hout. Dergelijke tunieken zijn de beste bescherming."

#. TRANSLATORS: Helptext for a Europeans worker: Builder
#: addons/europeans_all.wad/tribes/initialization/units.lua:1578 input:1578
#: standard
msgctxt "europeans_worker"
msgid "Carries items along your roads."
msgstr "Draagt voorwerpen langs je wegen."

#. TRANSLATORS: Helptext for a Barbarian worker: Carrier
#: addons/europeans_all.wad/tribes/initialization/units.lua:1587 input:1587
#: standard
msgctxt "barbarians_worker"
msgid "Carries items along your roads."
msgstr "Draagt voorwerpen langs je wegen."

#. TRANSLATORS: Helptext for an Amazon worker: Carrier
#: addons/europeans_all.wad/tribes/initialization/units.lua:1596 input:1596
#: standard
msgctxt "amazons_worker"
msgid "Carries items along your roads."
msgstr "Draagt voorwerpen langs je wegen."

#. TRANSLATORS: Helptext for an Atlantean worker: Carrier
#: addons/europeans_all.wad/tribes/initialization/units.lua:1605 input:1605
#: standard
msgctxt "atlanteans_worker"
msgid "Carries items along your roads."
msgstr "Draagt voorwerpen langs je wegen."

#. TRANSLATORS: Helptext for an Empire worker: Carrier
#: addons/europeans_all.wad/tribes/initialization/units.lua:1614 input:1614
#: standard
msgctxt "empire_worker"
msgid "Carries items along your roads."
msgstr "Draagt voorwerpen langs je wegen."

#. TRANSLATORS: Helptext for a Frisian worker: Carrier
#: addons/europeans_all.wad/tribes/initialization/units.lua:1623 input:1623
#: standard
msgctxt "frisians_worker"
msgid "Carries items along your roads."
msgstr "Draagt voorwerpen langs je wegen."

#. TRANSLATORS: Helptext for a Barbarian worker: Ox
#: addons/europeans_all.wad/tribes/initialization/units.lua:1632 input:1632
#: standard
msgctxt "barbarians_worker"
msgid ""
"Oxen help to carry items along busy roads. They are reared in a cattle farm."
msgstr ""
"Ossen helpen om voorwerpen langs drukke wegen te dragen. Ze worden gefokt in "
"een ossenstal."

#. TRANSLATORS: Helptext for an Amazon worker: Tapir
#: addons/europeans_all.wad/tribes/initialization/units.lua:1641 input:1641
#: standard
msgctxt "amazons_worker"
msgid ""
"Tapirs help to carry items along busy roads. They are reared in a tapir farm."
msgstr ""
"Tapirs helpen bij het vervoeren van goederen langs drukke wegen. Ze worden "
"gefokt op een tapirboerderij."

#. TRANSLATORS: Helptext for an Atlantean worker: Horse
#: addons/europeans_all.wad/tribes/initialization/units.lua:1650 input:1650
#: standard
msgctxt "atlanteans_worker"
msgid ""
"Horses help to carry items along busy roads. They are reared in a horse farm."
msgstr ""
"Paarden helpen om voorwerpen langs drukke wegen te dragen. Ze worden gefokt "
"in een paardenstal."

#. TRANSLATORS: Helptext for an Empire worker: Donkey
#: addons/europeans_all.wad/tribes/initialization/units.lua:1659 input:1659
#: standard
msgctxt "empire_worker"
msgid ""
"Donkeys help to carry items along busy roads. They are reared in a donkey "
"farm."
msgstr ""
"Ezels helpen bij het vervoeren van spullen langs drukke wegen. Ze worden "
"gefokt op een ezelboerderij."

#. TRANSLATORS: Helptext for a Frisian worker: Reindeer
#: addons/europeans_all.wad/tribes/initialization/units.lua:1668 input:1668
#: standard
msgctxt "frisians_worker"
msgid ""
"Reindeer help to carry items along busy roads. They are reared in a reindeer "
"farm."
msgstr ""
"Rendieren helpen bij het vervoeren van goederen langs drukke wegen. Ze "
"worden gefokt op een rendierboerderij."

#. TRANSLATORS: Helptext for a Barbarian worker: Ferry
#: addons/europeans_all.wad/tribes/initialization/units.lua:1677 input:1677
#: standard
msgctxt "barbarians_worker"
msgid "Ships wares across narrow rivers."
msgstr "Schepen hun waren over smalle rivieren."

#. TRANSLATORS: Helptext for an Amazon worker: Ferry
#: addons/europeans_all.wad/tribes/initialization/units.lua:1686 input:1686
#: standard
msgctxt "amazons_worker"
msgid "Ships wares across narrow rivers."
msgstr "Schepen hun waren over smalle rivieren."

#. TRANSLATORS: Helptext for an Atlantean worker: Ferry
#: addons/europeans_all.wad/tribes/initialization/units.lua:1695 input:1695
#: standard
msgctxt "atlanteans_worker"
msgid "Ships wares across narrow rivers."
msgstr "Schepen hun waren over smalle rivieren."

#. TRANSLATORS: Helptext for an Empire worker: Ferry
#: addons/europeans_all.wad/tribes/initialization/units.lua:1704 input:1704
#: standard
msgctxt "empire_worker"
msgid "Ships wares across narrow rivers."
msgstr "Schepen hun waren over smalle rivieren."

#. TRANSLATORS: Helptext for a Frisian worker: Ferry
#: addons/europeans_all.wad/tribes/initialization/units.lua:1713 input:1713
#: standard
msgctxt "frisians_worker"
msgid "Ships wares across narrow rivers."
msgstr "Schepen hun waren over smalle rivieren."

#. TRANSLATORS: Helptext for a Europeans worker: Builder
#: addons/europeans_all.wad/tribes/initialization/units.lua:1725 input:1725
#: standard
msgctxt "europeans_worker"
msgid "Works at construction sites to raise new buildings."
