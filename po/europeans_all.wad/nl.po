#: addons/europeans_all.wad/tribes/initialization/units.lua:5223 input:5214
#: input:5223 standard
msgctxt "europeans_building"
msgid "Sows and harvests corn."
msgstr "Zaait en oogst maïs."

#. TRANSLATORS: Purpose helptext for an Europeans production site: Spider Farm
#: addons/europeans_all.wad/tribes/initialization/units.lua:5232 input:5232
#: standard
msgctxt "europeans_building"
msgid "Breeds spiders for silk."
msgstr "Fokt spinnen voor zijde."

#. TRANSLATORS: Purpose helptext for a Europeans production site: Weaving Mill
#: addons/europeans_all.wad/tribes/initialization/units.lua:5239 input:5239
#: standard
msgctxt "europeans_building"
msgid "Weaves cloth out of reed."
msgstr "Weeft stoffen van riet."

#. TRANSLATORS: Purpose helptext for an Europeans production site: Weaving Mill
#: addons/europeans_all.wad/tribes/initialization/units.lua:5246 input:5246
#: standard
msgctxt "europeans_building"
msgid "Weaves cloth out of cotton and rope out of liana."
msgstr "Weeft stof van katoen en touw van liana."

#. TRANSLATORS: Purpose helptext for an Europeans production site: Weaving Mill
#: addons/europeans_all.wad/tribes/initialization/units.lua:5253 input:5253
#: standard
msgctxt "europeans_building"
msgid ""
"Weaves cloth out of cotton, spidercloth out of spider silk and rope out of "
"liana."
msgstr ""
"Weeft stof van katoen, spinnenwebstof van spinnenzijde en touw van liana."

#. TRANSLATORS: Purpose helptext for an Europeans production site: Weaving Mill
#: addons/europeans_all.wad/tribes/initialization/units.lua:5260 input:5260
#: standard
msgctxt "europeans_building"
msgid ""
"Weaves cloth out of wool, spidercloth out of spider silk and rope out of "
"liana."
msgstr ""
"Weeft stof van wol, spinnenwebstof van spinnenzijde en touw van lianen."

#. TRANSLATORS: Purpose helptext for an Europeans production site: Weaving Mill
#: addons/europeans_all.wad/tribes/initialization/units.lua:5267 input:5267
#: standard
msgctxt "europeans_building"
msgid ""
"Weaves cloth out of cotton or wool, spidercloth out of spider silk and rope "
"out of liana. Additional creates armor for soliders."
msgstr ""
"Weeft stoffen van katoen of wol, spinnenwebben van spinnenzijde en touw van "
"lianen. Daarnaast maakt hij harnassen voor soldaten."

#. TRANSLATORS: Purpose helptext for an Europeans production site: Big Manufactory
#: addons/europeans_all.wad/tribes/initialization/units.lua:5274 input:5274
#: standard
msgctxt "europeans_building"
msgid "Produces all tools and armor that do not require iron."
msgstr ""
"Produceert alle gereedschappen en wapenrustingen waarvoor geen ijzer nodig "
"is."

#. TRANSLATORS: Purpose helptext for an Europeans production site: Metal Manufactory
#: addons/europeans_all.wad/tribes/initialization/units.lua:5281 input:5281
#: standard
msgctxt "europeans_building"
msgid "Produces all tools, weapons and armor that require iron."
msgstr ""
"Produceert alle gereedschappen, wapens en harnassen waarvoor ijzer nodig is."

#. TRANSLATORS: Purpose helptext for an Europeans production site: Cattle Farm
#: addons/europeans_all.wad/tribes/initialization/units.lua:5289 input:5289
#: standard
msgctxt "europeans_building"
msgid "Breeds strong oxen for adding them to the transportation system."
msgstr "Fokt sterke ossen om ze toe te voegen aan het transportsysteem."

#. TRANSLATORS: Purpose helptext for an Europeans production site: Tapir Farm
#: addons/europeans_all.wad/tribes/initialization/units.lua:5296 input:5296
#: standard
msgctxt "europeans_building"
msgid "Breeds tapirs for adding them to the transportation system."
msgstr "Fokt tapirs om ze toe te voegen aan het transportsysteem."

#. TRANSLATORS: Purpose helptext for an Europeans production site: Horse Farm
#: addons/europeans_all.wad/tribes/initialization/units.lua:5303 input:5303
#: standard
msgctxt "europeans_building"
msgid "Breeds the strong horses for adding them to the transportation system."
msgstr "Fokt sterke paarden om ze toe te voegen aan het transportsysteem."

#. TRANSLATORS: Purpose helptext for an Europeans production site: Donkey Farm
#: addons/europeans_all.wad/tribes/initialization/units.lua:5310 input:5310
#: standard
msgctxt "europeans_building"
msgid ""
"Breeds cute and helpful donkeys for adding them to the transportation system."
msgstr ""
"Fokt schattige en behulpzame ezels om ze toe te voegen aan het "
"transportsysteem."

#. TRANSLATORS: Purpose helptext for an Europeans production site: Sheep Farm
#: addons/europeans_all.wad/tribes/initialization/units.lua:5317 input:5317
#: standard
msgctxt "europeans_building"
msgid "Keeps sheep for their wool."
msgstr "Houdt schapen voor hun wol."

#. TRANSLATORS: Purpose helptext for a Europeans production site: Reindeer Farm
#: addons/europeans_all.wad/tribes/initialization/units.lua:5324 input:5324
#: standard
msgctxt "europeans_building"
msgid ""
"Breeds strong reindeer for adding them to the transportation system. Also "
"keeps them for their fur, which is turned into armor and cloth."
msgstr ""
"Kweekt sterke rendieren om ze toe te voegen aan het transportsysteem. Houdt "
"ze ook voor hun vacht, die wordt verwerkt tot harnassen en kleding."

#. TRANSLATORS: Purpose helptext for an Europeans production site: Animals Store
#: addons/europeans_all.wad/tribes/initialization/units.lua:5332 input:5332
#: standard
msgctxt "europeans_building"
msgid "Sells animals in exchange for coins."
msgstr "Verkoopt dieren in ruil voor munten."

#. TRANSLATORS: Purpose helptext for an Europeans production site: Food Store
#: addons/europeans_all.wad/tribes/initialization/units.lua:5339 input:5339
#: standard
msgctxt "europeans_building"
msgid "Sells food products in exchange for coins."
msgstr "Verkoopt voedingsmiddelen in ruil voor munten."

#. TRANSLATORS: Purpose helptext for an Europeans production site: Fur Store
#: addons/europeans_all.wad/tribes/initialization/units.lua:5346 input:5346
#: standard
msgctxt "europeans_building"
msgid "Sells animal products like fur and leather in exchange for coins."
msgstr "Verkoopt dierlijke producten zoals vacht en leer in ruil voor munten."

#. TRANSLATORS: Purpose helptext for an Europeans production site: Plants Store
#: addons/europeans_all.wad/tribes/initialization/units.lua:5353 input:5353
#: standard
msgctxt "europeans_building"
msgid "Sells plant products in exchange for coins."
msgstr "Verkoopt plantaardige producten in ruil voor munten."

#. TRANSLATORS: Purpose helptext for an Europeans production site: Basic Wood Store
#: addons/europeans_all.wad/tribes/initialization/units.lua:5360 input:5360
#: standard
msgctxt "europeans_building"
msgid "Sells basic tree products in exchange for coins."
msgstr "Verkoopt basisboomproducten in ruil voor munten."

#. TRANSLATORS: Purpose helptext for an Europeans production site: Advanced Wood Store
#: addons/europeans_all.wad/tribes/initialization/units.lua:5367 input:5367
#: standard
msgctxt "europeans_building"
msgid "Sells rare tree products in exchange for coins."
msgstr "Verkoopt zeldzame boomproducten in ruil voor munten."

#. TRANSLATORS: Purpose helptext for an Europeans production site: Trading Post
#: addons/europeans_all.wad/tribes/initialization/units.lua:5374 input:5374
#: standard
msgctxt "europeans_building"
msgid "Sells coal and metals in exchange for coins."
msgstr "Verkoopt kolen en metalen in ruil voor munten."

#. TRANSLATORS: Purpose helptext for a Europeans production site: Diker's House
#: addons/europeans_all.wad/tribes/initialization/units.lua:5382 input:5382
#: standard
msgctxt "europeans_building"
msgid "Constructs breakwaters nearby to gain new land from the sea."
msgstr "Bouw golfbrekers in de buurt om nieuw land te winnen op de zee."

#. TRANSLATORS: Note helptext for a Europeans production site: Diker's House
#: addons/europeans_all.wad/tribes/initialization/units.lua:5384 input:5384
#: standard
msgctxt "europeans_building"
msgid ""
"The diker will terraform the land around each breakwater he builds several "
"times. You can manually remove breakwaters when the land is sufficiently "
"secured to prevent wasting resources; to do so, build a flag, road, or "
"building in the dike’s place."
msgstr ""
"De dijkbouwer zal het land rondom elke golfbreker die hij bouwt meerdere "
"keren terraformen. Je kunt golfbrekers handmatig verwijderen wanneer het "
"land voldoende beveiligd is om verspilling van grondstoffen te voorkomen. Om "
"dit te doen, bouw je een vlag, weg of gebouw op de plaats van de dijk."

