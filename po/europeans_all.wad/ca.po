#: addons/europeans_all.wad/tribes/initialization/units.lua:6076
#: addons/europeans_all.wad/tribes/initialization/units.lua:6090 input:6076
#: input:6090 standard
msgctxt "europeans_building"
msgid "Ballad ‘The Battle of Kal’mavrath’ by Hakhor the Bard"
msgstr "Balada 'La batalla de Kal'mavrath' de Hakhor el Bard"

#. TRANSLATORS: Lore helptext for a Barbarian military site: Tower
#: addons/europeans_all.wad/tribes/initialization/units.lua:6088 input:6088
#: standard
msgctxt "europeans_building"
msgid ""
"‘From the height of our tower we could see far into enemy territory. The "
"enemy was well prepared, but we also noticed some weak points in their "
"defense.’"
msgstr ""
"\"Des de l'alçada de la nostra torre podíem veure molt lluny el territori "
"enemic. L'enemic estava ben preparat, però també vam notar alguns punts "
"febles en la seva defensa”."

#. TRANSLATORS: Lore helptext for a Barbarian military site: Fortress
#: addons/europeans_all.wad/tribes/initialization/units.lua:6101 input:6101
#: standard
msgctxt "europeans_building"
msgid ""
"‘This stronghold made from blackwood and stones will be a hard nut to crack "
"for them.’"
msgstr ""
"\"Aquesta fortalesa feta de fusta negra i pedres serà una nou dura de "
"trencar per a ells\"."

#. TRANSLATORS: Lore author helptext for a Barbarian military site: Fortress
#: addons/europeans_all.wad/tribes/initialization/units.lua:6103 input:6103
#: standard
msgctxt "europeans_building"
msgid "Berthron,<br>chief military adviser of Chat’Karuth"
msgstr "Berthron,<br>assessor militar en cap de Chat'Karuth"

#. TRANSLATORS: Lore helptext for a Barbarian military site: Citadel
#: addons/europeans_all.wad/tribes/initialization/units.lua:6114 input:6114
#: standard
msgctxt "europeans_building"
msgid ""
"‘The Citadel of Adlen surely is the finest masterpiece of Barbarian "
"craftsmanship. Nothing as strong and big and beautiful has ever been built "
"in such a short time.’"
msgstr ""
"\"La Ciutadella d'Adlen és sens dubte la millor obra mestra de l'artesania "
"bàrbara. No s'ha construït mai res tan fort, tan gran i bell en tan poc "
"temps."

#. TRANSLATORS: Lore author helptext for a Barbarian military site: Citadel
#: addons/europeans_all.wad/tribes/initialization/units.lua:6116 input:6116
#: standard
msgctxt "europeans_building"
msgid ""
"Colintan, chief planner of the Citadel of Adlen,<br>at its opening ceremony"
msgstr ""
"Colintan, planificador en cap de la Ciutadella d'Adlen,<br>en la seva "
"cerimònia d'obertura"

#. TRANSLATORS: DO NOT TRANSLATE, but you may transliterate into non-latin fonts.
#. Classical Latin quote meaning:
#. "An eagle doesn’t catch flies."
#: addons/europeans_all.wad/tribes/initialization/units.lua:6131 input:6131
#: standard
msgid "Aquila non captat muscas."
msgstr ""

#. TRANSLATORS: Lore helptext for an Empire military site: Blockhouse
#. Translation for the classical Latin quote:
#. "Aquila non captat muscas."
#: addons/europeans_all.wad/tribes/initialization/units.lua:6135 input:6135
#: standard
msgid "An eagle doesn’t catch flies."
msgstr "L'àguila no agafa mosques."

#. TRANSLATORS: Lore author helptext for an Empire military site: Blockhouse
#: addons/europeans_all.wad/tribes/initialization/units.lua:6139 input:6139
#: standard
msgctxt "europeans_building"
msgid ""
"General Passerus Claudius Pedestrus on why he didn’t order the destruction "
"of a rebel Blockhouse"
msgstr ""
"El general Passerus Claudius Pedestrus explica per què no va ordenar la "
"destrucció d'un Blockhouse rebel"

#. TRANSLATORS: DO NOT TRANSLATE, but you may transliterate into non-latin fonts.
#. Classical Latin quote meaning:
#. "Who watches the watchmen?"
#: addons/europeans_all.wad/tribes/initialization/units.lua:6155 input:6155
#: standard
msgid "Quis custodiet ipsos custodes?"
msgstr ""

#. TRANSLATORS: Lore helptext for an Empire production site: Sentry
#. Translation for the classical Latin quote:
#. "Quis custodiet ipsos custodes?"
#: addons/europeans_all.wad/tribes/initialization/units.lua:6159 input:6159
#: standard
msgid "Who watches the watchmen?"
msgstr "Qui vigila els vigilants?"

#. TRANSLATORS: Lore author helptext for an Empire production site: Sentry
#. (the Limes was the border defence system of fortifications of the Roman Empire)
#: addons/europeans_all.wad/tribes/initialization/units.lua:6164 input:6164
#: standard
msgctxt "europeans_building"
msgid ""
"Saledus warning Lutius that sentries are not adequate protection for the "
"Limes"
msgstr ""
"Saledus adverteix a Lutius que els sentinelles no són una protecció adequada "
"per als Limes"

#. TRANSLATORS: DO NOT TRANSLATE, but you may transliterate into non-latin fonts.
#. Classical Latin quote meaning:
#. "Two were stationed on the other side of the city than the camp: one over the river, the other by
#. the river above the camp."
#: addons/europeans_all.wad/tribes/initialization/units.lua:6180 input:6180
#: standard
msgid ""
"Binæ contra urbem a castris station erant, una ultra flumen, altera eis "
"flumen supra castra."
msgstr ""

#. TRANSLATORS: Lore helptext for an Empire military site: Outpost
#. Translation for the classical Latin quote:
#. "Binæ contra urbem a castris station erant, una ultra flumen, altera eis flumen supra castra."
#: addons/europeans_all.wad/tribes/initialization/units.lua:6184 input:6184
#: standard
msgid ""
"Two were stationed on the other side of the city than the camp: one over the "
"river, the other by the river above the camp."
msgstr ""
"Dos estaven estacionats a l'altre costat de la ciutat que no fos el "
"campament: un sobre el riu, l'altre al costat del riu sobre el campament."

#. TRANSLATORS: Lore author helptext for an Empire military site: Outpost
#: addons/europeans_all.wad/tribes/initialization/units.lua:6189 input:6189
#: standard
msgctxt "europeans_building"
msgid ""
"History of the Empire, Part III, preparation for the battle of Uliginosium"
msgstr ""
"Història de l'Imperi, part III, preparació per a la batalla d'Uliginosium"

#. TRANSLATORS: DO NOT TRANSLATE, but you may transliterate into non-latin fonts.
#. Classical Latin quote meaning:
#. "The die is cast!"
#: addons/europeans_all.wad/tribes/initialization/units.lua:6204 input:6204
#: standard
msgid "Alea iacta est!"
msgstr ""

#. TRANSLATORS: Lore helptext for an Empire military site: Barrier
#. Translation for the classical Latin quote:
#. "Alea iacta est!"
#: addons/europeans_all.wad/tribes/initialization/units.lua:6208 input:6208
#: standard
msgid "The die is cast!"
msgstr "El dau està llançat!"

#. TRANSLATORS: Lore author helptext for an Empire military site: Barrier
#: addons/europeans_all.wad/tribes/initialization/units.lua:6212 input:6212
#: standard
msgctxt "europeans_building"
msgid ""
"Rebel general Certus Ignavus Fidelius upon entering the limits of Fremil to "
"overthrow the government"
msgstr ""
"El general rebel Certus Ignavus Fidelius en entrar als límits de Fremil per "
"enderrocar el govern"

#. TRANSLATORS: DO NOT TRANSLATE, but you may transliterate into non-latin fonts.
#. Classical Latin quote meaning:
#. "I came, I saw, I conquered!"
#: addons/europeans_all.wad/tribes/initialization/units.lua:6228 input:6228
#: standard
msgid "Veni, Vidi, Vici!"
msgstr ""

#. TRANSLATORS: Lore helptext for an Empire military site: Tower
#. Translation for the classical Latin quote:
#. "Veni, Vidi, Vici!"
#: addons/europeans_all.wad/tribes/initialization/units.lua:6232 input:6232
#: standard
msgid "I came, I saw, I conquered!"
msgstr "Vaig venir, vaig veure, vaig conquerir!"

#. TRANSLATORS: Lore author helptext for an Empire military site: Tower
#: addons/europeans_all.wad/tribes/initialization/units.lua:6236 input:6236
#: standard
msgctxt "europeans_building"
msgid ""
"General Claudius Cæcus Cessus reporting a quick victory over the Barbarians "
"thanks to the superior vision of a tower"
msgstr ""
"El general Claudius Cæcus Cessus informant d'una ràpida victòria sobre els "
"bàrbars gràcies a la visió superior d'una torre"

#. TRANSLATORS: DO NOT TRANSLATE, but you may transliterate into non-latin fonts.
#. Classical Latin quote meaning:
#. "If you want peace, prepare for war."
#: addons/europeans_all.wad/tribes/initialization/units.lua:6252 input:6252
#: standard
msgid "Si vis pacem, para bellum."
msgstr ""

#. TRANSLATORS: Lore helptext for an Empire production site: Fortress
#. Translation for the classical Latin quote:
#. "Si vis pacem, para bellum."
#: addons/europeans_all.wad/tribes/initialization/units.lua:6256 input:6256
#: standard
msgid "If you want peace, prepare for war."
msgstr "Si vols la pau, prepara't per a la guerra."

#. TRANSLATORS: Lore author helptext for an Empire military site: Fortress
#: addons/europeans_all.wad/tribes/initialization/units.lua:6259 input:6259
#: standard
msgctxt "europeans_building"
msgid "Saledus arguing with Amalea"
msgstr "Saledus discutint amb Amalea"

#. TRANSLATORS: DO NOT TRANSLATE, but you may transliterate into non-latin fonts.
#. Adaptation of a classical Latin quote meaning:
#. "Furthermore, I think that Al’thunran must be destroyed!"
#: addons/europeans_all.wad/tribes/initialization/units.lua:6273 input:6273
#: standard
msgid "Ceterum autem censeo Althunranam esse delendam!"
msgstr ""

#. TRANSLATORS: Lore helptext for an Empire military site: Castle
#. Translation for the adapted classical Latin quote:
#. "Ceterum autem censeo Althunranam esse delendam!"
#: addons/europeans_all.wad/tribes/initialization/units.lua:6277 input:6277
#: standard
msgid "Furthermore, I think that Al’thunran must be destroyed!"
msgstr "A més, crec que Al'thunran s'ha de destruir!"

#. TRANSLATORS: Lore author helptext for an Empire military site: Castle
#: addons/europeans_all.wad/tribes/initialization/units.lua:6281 input:6281
#: standard
msgctxt "europeans_building"
msgid "Saledus in the Senate, urging final victory over the Barbarians"
msgstr "Saledus al Senat, demanant la victòria final sobre els bàrbars"

#. TRANSLATORS: Lore helptext for an Europeans building: Construction Site
#: addons/europeans_all.wad/tribes/initialization/units.lua:6349 input:6349
#: standard
msgctxt "europeans_building"
msgid "‘Don’t swear at the builder who is short of building materials.’"
msgstr ""
"«No maldiguis el constructor que ha fet curt amb els materials de "
"construcció»."

#. TRANSLATORS: Lore author helptext for an Europeans building: Construction Site
#: addons/europeans_all.wad/tribes/initialization/units.lua:6351 input:6351
#: standard
msgctxt "europeans_building"
msgid "Proverb widely used for impossible tasks of any kind"
msgstr "Proverbi usat per tasques impossibles de qualsevol mena"

#. TRANSLATORS: Purpose helptext for an Europeans building: Construction Site
#: addons/europeans_all.wad/tribes/initialization/units.lua:6353 input:6353
#: standard
msgctxt "europeans_building"
msgid "A new building is being built at this construction site."
msgstr "En aquest lloc es construeix un edifici."

#. TRANSLATORS: Lore helptext for an Europeans building: Dismantle Site
#: addons/europeans_all.wad/tribes/initialization/units.lua:6360 input:6360
#: standard
msgctxt "europeans_building"
msgid "‘New paths will appear when you are willing to tear down the old.’"
msgstr "«Quan intentis destruir un camí, n'apareixeran de nous»."

#. TRANSLATORS: Lore author helptext for an Europeans building: Dismantle Site
#: addons/europeans_all.wad/tribes/initialization/units.lua:6362 input:6362
#: standard
msgctxt "europeans_building"
msgid "Proverb"
msgstr "Proverbi"

#. TRANSLATORS: Purpose helptext for an Europeans building: Dismantle Site
#: addons/europeans_all.wad/tribes/initialization/units.lua:6364 input:6364
#: standard
msgctxt "europeans_building"
msgid ""
"A building is being dismantled at this dismantle site, returning some of the "
"resources that were used during this building’s construction to your tribe’s "
"stores."
msgstr ""
"Es desmantella l'edifici i es recuperarà part dels materials de construcció, "
"que s'enviaran als magatzems del clan."

