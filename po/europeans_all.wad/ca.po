#: addons/europeans_all.wad/tribes/scripting/starting_conditions/headquarters_with_diker.lua:13
#: input:13 standard
msgid ""
"Start the game with your headquarters only. Enables dikers and disables "
"ports and shipyards."
msgstr ""
"Comença el joc només amb la teva seu. Habilita els dikers i desactiva els "
"ports i les drassanes."

#. TRANSLATORS: This is the name of a starting condition
#: addons/europeans_all.wad/tribes/scripting/starting_conditions/headquarters_with_seafaring.lua:11
