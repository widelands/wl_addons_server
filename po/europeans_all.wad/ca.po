#: addons/europeans_all.wad/tribes/initialization/units.lua:2071 input:2071
#: standard
msgctxt "barbarians_worker"
msgid "Plants and harvests reed fields."
msgstr "Planta i collia camps de canyes."

#. TRANSLATORS: Helptext for a Barbarian worker: Farmer
#: addons/europeans_all.wad/tribes/initialization/units.lua:2080 input:2080
#: standard
msgctxt "barbarians_worker"
msgid "Plants fields."
msgstr "Camps de plantes."

#. TRANSLATORS: Helptext for an Amazon worker: Cassava Farmer
#: addons/europeans_all.wad/tribes/initialization/units.lua:2089 input:2089
#: standard
msgctxt "amazons_worker"
msgid "Grows cassava."
msgstr "Cultiva la mandioca."

#. TRANSLATORS: Helptext for an Amazon worker: Cocoa Farmer
#: addons/europeans_all.wad/tribes/initialization/units.lua:2098 input:2098
#: standard
msgctxt "amazons_worker"
msgid "Grows cocoa."
msgstr "Cultiva cacau."

#. TRANSLATORS: Helptext for an Atlantean worker: Farmer
#: addons/europeans_all.wad/tribes/initialization/units.lua:2107 input:2107
#: standard
msgctxt "atlanteans_worker"
msgid "Plants and harvests cornfields."
msgstr "Planta i collia camps de blat de moro."

#. TRANSLATORS: Helptext for an Atlantean worker: Blackroot Farmer
#: addons/europeans_all.wad/tribes/initialization/units.lua:2116 input:2116
#: standard
msgctxt "atlanteans_worker"
msgid "Plants and harvests blackroot."
msgstr "Planta i recull arrel negre."

#. TRANSLATORS: Helptext for an Empire worker: Farmer
#: addons/europeans_all.wad/tribes/initialization/units.lua:2125 input:2125
#: standard
msgctxt "empire_worker"
msgid "Plants fields."
msgstr "Camps de plantes."

#. TRANSLATORS: Helptext for an Empire worker: Vine Farmer
#: addons/europeans_all.wad/tribes/initialization/units.lua:2134 input:2134
#: standard
msgctxt "empire_worker"
msgid "Grows grapevines."
msgstr "Conrea vinya."

#. TRANSLATORS: Helptext for a Frisian worker: Gardener
#: addons/europeans_all.wad/tribes/initialization/units.lua:2143 input:2143
#: standard
msgctxt "frisians_worker"
msgid "Plants and harvests reed fields."
msgstr "Planta i collia camps de canyes."

#. TRANSLATORS: Helptext for a Frisian worker: Farmer
#: addons/europeans_all.wad/tribes/initialization/units.lua:2152 input:2152
#: standard
msgctxt "frisians_worker"
msgid "Plants fields."
msgstr "Camps de plantes."

#. TRANSLATORS: Helptext for a Frisian worker: Berry Farmer
#: addons/europeans_all.wad/tribes/initialization/units.lua:2161 input:2161
#: standard
msgctxt "frisians_worker"
msgid "Plants berry bushes."
msgstr "Planta arbustos de baies."

#. TRANSLATORS: Helptext for a Frisian worker: Fruit Collector
#: addons/europeans_all.wad/tribes/initialization/units.lua:2170 input:2170
#: standard
msgctxt "frisians_worker"
msgid "Gathers berries."
msgstr "Recull baies."

#. TRANSLATORS: Helptext for a Barbarian worker: Cattle Breeder
#: addons/europeans_all.wad/tribes/initialization/units.lua:2182 input:2182
#: standard
msgctxt "barbarians_worker"
msgid "Breeds strong oxen for adding them to the transportation system."
msgstr "Cria bous forts per afegir-los al sistema de transport."

#. TRANSLATORS: Helptext for an Amazon worker: Tapir Breeder
#: addons/europeans_all.wad/tribes/initialization/units.lua:2191 input:2191
#: standard
msgctxt "amazons_worker"
msgid "Breeds tapirs for adding them to the transportation system."
msgstr "Cria tapirs per afegir-los al sistema de transport."

#. TRANSLATORS: Helptext for an Atlantean worker: Spider Breeder
#: addons/europeans_all.wad/tribes/initialization/units.lua:2200 input:2200
#: standard
msgctxt "atlanteans_worker"
msgid "Breeds spiders for silk."
msgstr "Cria aranyes per a la seda."

#. TRANSLATORS: Helptext for an Atlantean worker: Horse Breeder
#: addons/europeans_all.wad/tribes/initialization/units.lua:2209 input:2209
#: standard
msgctxt "atlanteans_worker"
msgid ""
"Breeds the strong Atlantean horses for adding them to the transportation "
"system."
msgstr ""
"Cria els forts cavalls atlantes per afegir-los al sistema de transport."

#. TRANSLATORS: Helptext for an Empire worker: Donkey Breeder
#: addons/europeans_all.wad/tribes/initialization/units.lua:2218 input:2218
#: standard
msgctxt "empire_worker"
msgid ""
"Breeds cute and helpful donkeys for adding them to the transportation system."
msgstr "Cria rucs simpàtics i útils per afegir-los al sistema de transport."

#. TRANSLATORS: Helptext for an Empire worker: Pig Breeder
#: addons/europeans_all.wad/tribes/initialization/units.lua:2227 input:2227
#: standard
msgctxt "empire_worker"
msgid "Breeds pigs."
msgstr "Cria porcs."

#. TRANSLATORS: Helptext for an Empire worker: Shepherd
#: addons/europeans_all.wad/tribes/initialization/units.lua:2236 input:2236
#: standard
msgctxt "empire_worker"
msgid "Keeping sheep."
msgstr "Tenint ovelles."

#. TRANSLATORS: Helptext for a Frisian worker: Beekeeper
#: addons/europeans_all.wad/tribes/initialization/units.lua:2245 input:2245
#: standard
msgctxt "frisians_worker"
msgid "Lets bees swarm over flowers, then gathers the honey."
msgstr ""
"Deixa que les abelles pululin sobre les flors, després recullen la mel."

#. TRANSLATORS: Helptext for a Frisian worker: Reindeer Breeder
#: addons/europeans_all.wad/tribes/initialization/units.lua:2254 input:2254
#: standard
msgctxt "frisians_worker"
msgid "Breeds reindeer as carriers and for their fur."
msgstr "Cria rens com a portadors i pel seu pelatge."

#. TRANSLATORS: Helptext for a Barbarian worker: Fisher
#: addons/europeans_all.wad/tribes/initialization/units.lua:2266 input:2266
#: standard
msgctxt "barbarians_worker"
msgid "Catches fish in the sea."
msgstr "Agafa peixos al mar."

#. TRANSLATORS: Helptext for an Atlantean worker: Fisher
#: addons/europeans_all.wad/tribes/initialization/units.lua:2275 input:2275
#: standard
msgctxt "atlanteans_worker"
msgid "The fisher fishes delicious fish."
msgstr "El pescador pesca un peix deliciós."

#. TRANSLATORS: Helptext for an Empire worker: Fisher
#: addons/europeans_all.wad/tribes/initialization/units.lua:2284 input:2284
#: standard
msgctxt "empire_worker"
msgid "Catches fish in the sea."
msgstr "Agafa peixos al mar."

#. TRANSLATORS: Helptext for a Frisian worker: Fisher
#: addons/europeans_all.wad/tribes/initialization/units.lua:2293 input:2293
#: standard
msgctxt "frisians_worker"
msgid "Catches fish in the sea."
msgstr "Agafa peixos al mar."

#. TRANSLATORS: Helptext for a Barbarian worker: Hunter
#: addons/europeans_all.wad/tribes/initialization/units.lua:2302 input:2302
#: standard
msgctxt "barbarians_worker"
msgid "The hunter brings fresh, raw meat to the colonists."
msgstr "El caçador porta carn fresca i crua als colons."

#. TRANSLATORS: Helptext for an Amazon worker: Hunter-Gatherer
#: addons/europeans_all.wad/tribes/initialization/units.lua:2311 input:2311
#: standard
msgctxt "amazons_worker"
msgid "The hunter-gatherer gets fresh fish and raw meat for the tribe."
msgstr "El caçador-recol·lector obté peix fresc i carn crua per a la tribu."

#. TRANSLATORS: Helptext for an Atlantean worker: Hunter
#: addons/europeans_all.wad/tribes/initialization/units.lua:2320 input:2320
#: standard
msgctxt "atlanteans_worker"
msgid "The hunter brings fresh, raw meat to the colonists."
msgstr "El caçador porta carn fresca i crua als colons."

#. TRANSLATORS: Helptext for an Empire worker: Hunter
#: addons/europeans_all.wad/tribes/initialization/units.lua:2329 input:2329
#: standard
msgctxt "empire_worker"
msgid "The hunter brings fresh, raw meat to the colonists."
msgstr "El caçador porta carn fresca i crua als colons."

#. TRANSLATORS: Helptext for a Frisian worker: Hunter
#: addons/europeans_all.wad/tribes/initialization/units.lua:2338 input:2338
#: standard
msgctxt "frisians_worker"
msgid "The hunter brings fresh, raw meat to the colonists."
msgstr "El caçador porta carn fresca i crua als colons."

#. TRANSLATORS: Helptext for a Barbarian worker: Gamekeeper
#: addons/europeans_all.wad/tribes/initialization/units.lua:2347 input:2347
#: standard
msgctxt "barbarians_worker"
msgid ""
"The gamekeeper makes sure that the natural population of animals never drops "
"too low."
msgstr ""
"El guardacaça s'assegura que la població natural d'animals mai baixi massa."

#. TRANSLATORS: Helptext for an Amazon worker: Wilderness Keeper
#: addons/europeans_all.wad/tribes/initialization/units.lua:2356 input:2356
#: standard
msgctxt "amazons_worker"
msgid "Breeds game or fish."
msgstr "Cria caça o peix."

#. TRANSLATORS: Helptext for an Atlantean worker: Fish Breeder
#: addons/europeans_all.wad/tribes/initialization/units.lua:2365 input:2365
#: standard
msgctxt "atlanteans_worker"
msgid "Breeds fish."
msgstr "Cria peixos."

#. TRANSLATORS: Helptext for an Atlantean worker: Miller
#: addons/europeans_all.wad/tribes/initialization/units.lua:2377 input:2377
#: standard
msgctxt "atlanteans_worker"
msgid ""
"Grinds blackroots and corn to produce blackroot flour and cornmeal, "
"respectively."
msgstr ""
"Tritura les arrels negres i el blat de moro per produir farina d'arrel negra "
"i farina de blat de moro, respectivament."

#. TRANSLATORS: Helptext for an Empire worker: Miller
#: addons/europeans_all.wad/tribes/initialization/units.lua:2386 input:2386
#: standard
msgctxt "empire_worker"
msgid "Grinds wheat to produce flour."
msgstr "Mòlta blat per produir farina."

#. TRANSLATORS: Helptext for a Barbarian worker: Baker
#: addons/europeans_all.wad/tribes/initialization/units.lua:2395 input:2395
#: standard
msgctxt "barbarians_worker"
msgid "Bakes pitta bread for the miners, soldiers and scouts."
msgstr "Enforna pa pitta per als miners, soldats i exploradors."

#. TRANSLATORS: Helptext for an Amazon worker: Cook
#: addons/europeans_all.wad/tribes/initialization/units.lua:2404 input:2404
#: standard
msgctxt "amazons_worker"
msgid "Prepares rations, bakes cassava bread and brews chocolate."
msgstr "Prepara racions, cuina pa de mandioca i elabora xocolata."

#. TRANSLATORS: Helptext for an Atlantean worker: Baker
#: addons/europeans_all.wad/tribes/initialization/units.lua:2413 input:2413
#: standard
msgctxt "atlanteans_worker"
msgid "Bakes bread for workers."
msgstr "Cuina pa per als treballadors."

#. TRANSLATORS: Helptext for an Empire worker: Baker
#: addons/europeans_all.wad/tribes/initialization/units.lua:2422 input:2422
#: standard
msgctxt "empire_worker"
msgid "Bakes bread for workers."
msgstr "Cuina pa per als treballadors."

#. TRANSLATORS: Helptext for a Frisian worker: Baker
#: addons/europeans_all.wad/tribes/initialization/units.lua:2431 input:2431
#: standard
msgctxt "frisians_worker"
msgid "Bakes bread for miners and soldiers."
msgstr "Enforna pa per a miners i soldats."

#. TRANSLATORS: Helptext for a Frisian worker: Master Baker
#: addons/europeans_all.wad/tribes/initialization/units.lua:2440 input:2440
#: standard
msgctxt "frisians_worker"
msgid "This baker is skilled enough to bake bread sweetened with honey."
msgstr "Aquest forner és prou hàbil per coure pa endolcit amb mel."

#. TRANSLATORS: Helptext for a Barbarian worker: Brewer
#: addons/europeans_all.wad/tribes/initialization/units.lua:2452 input:2452
#: standard
msgctxt "barbarians_worker"
msgid "Produces beer to keep the miners strong and happy."
msgstr "Produeix cervesa per mantenir els miners forts i feliços."

#. TRANSLATORS: Helptext for a Barbarian worker: Master Brewer
#: addons/europeans_all.wad/tribes/initialization/units.lua:2461 input:2461
#: standard
msgctxt "barbarians_worker"
msgid "Produces the finest ales to keep soldiers strong and happy in training."
msgstr ""
"Produeix les millors cerveses per mantenir els soldats forts i feliços en "
"l'entrenament."

#. TRANSLATORS: Helptext for an Empire worker: Brewer
#: addons/europeans_all.wad/tribes/initialization/units.lua:2470 input:2470
#: standard
msgctxt "empire_worker"
msgid "Produces beer."
msgstr "Produeix cervesa."

#. TRANSLATORS: Helptext for an Empire worker: Vintner
#: addons/europeans_all.wad/tribes/initialization/units.lua:2479 input:2479
#: standard
msgctxt "empire_worker"
msgid "Produces wine."
msgstr "Produeix vi."

#. TRANSLATORS: Helptext for a Frisian worker: Brewer
#: addons/europeans_all.wad/tribes/initialization/units.lua:2488 input:2488
#: standard
msgctxt "frisians_worker"
msgid "Brews beer."
msgstr "Elabora cervesa."

#. TRANSLATORS: Helptext for a Frisian worker: Master Brewer
#: addons/europeans_all.wad/tribes/initialization/units.lua:2497 input:2497
#: standard
msgctxt "frisians_worker"
msgid "Brews beer and mead."
msgstr "Elabora cervesa i hidromiel."

#. TRANSLATORS: Helptext for an Atlantean worker: Smoker
#: addons/europeans_all.wad/tribes/initialization/units.lua:2506 input:2506
#: standard
msgctxt "atlanteans_worker"
msgid "Smokes meat and fish."
msgstr "Fuma carn i peix."

#. TRANSLATORS: Helptext for a Frisian worker: Smoker
#: addons/europeans_all.wad/tribes/initialization/units.lua:2515 input:2515
#: standard
msgctxt "frisians_worker"
msgid "Refines meat and fish by smoking them."
msgstr "Refina la carn i el peix fumant-los."

#. TRANSLATORS: Helptext for a Barbarian worker: Innkeeper
#: addons/europeans_all.wad/tribes/initialization/units.lua:2524 input:2524
#: standard
msgctxt "barbarians_worker"
msgid "Produces food for miners."
msgstr "Produeix aliments per als miners."

#. TRANSLATORS: Helptext for an Empire worker: Innkeeper
#: addons/europeans_all.wad/tribes/initialization/units.lua:2533 input:2533
#: standard
msgctxt "empire_worker"
msgid "Produces food for miners."
msgstr "Produeix aliments per als miners."

#. TRANSLATORS: Helptext for a Frisian worker: Landlady
#: addons/europeans_all.wad/tribes/initialization/units.lua:2542 input:2542
#: standard
msgctxt "frisians_worker"
msgid "Prepares rations and meals for miners and scouts."
msgstr "Prepara racions i menjars per a miners i exploradors."

#. TRANSLATORS: Helptext for a Barbarian worker: Stonemason
#: addons/europeans_all.wad/tribes/initialization/units.lua:2554 input:2554
#: standard
msgctxt "barbarians_worker"
msgid "Cuts raw pieces of granite out of rocks in the vicinity."
msgstr "Talla peces crues de granit de les roques dels voltants."

#. TRANSLATORS: Helptext for an Amazon worker: Stonecutter
#: addons/europeans_all.wad/tribes/initialization/units.lua:2563 input:2563
#: standard
msgctxt "amazons_worker"
msgid ""
"Cuts blocks of granite out of rocks in the vicinity or mines granite and "
"quartz in stone mines."
msgstr ""
"Talla blocs de granit de les roques dels voltants o extreu granit i quars a "
"les mines de pedra."

#. TRANSLATORS: Helptext for an Atlantean worker: Stonecutter
#: addons/europeans_all.wad/tribes/initialization/units.lua:2572 input:2572
#: standard
msgctxt "atlanteans_worker"
msgid "Cuts blocks of granite out of rocks in the vicinity."
msgstr "Talla blocs de granit de les roques dels voltants."

#. TRANSLATORS: Helptext for an Empire worker: Stonemason
#: addons/europeans_all.wad/tribes/initialization/units.lua:2581 input:2581
#: standard
msgctxt "empire_worker"
msgid "Cuts blocks of granite and marble out of rocks in the vicinity."
msgstr "Talla blocs de granit i marbre de les roques dels voltants."

#. TRANSLATORS: Helptext for a Frisian worker: Stonemason
#: addons/europeans_all.wad/tribes/initialization/units.lua:2590 input:2590
#: standard
msgctxt "frisians_worker"
msgid "Cuts raw pieces of granite out of rocks in the vicinity."
msgstr "Talla peces crues de granit de les roques dels voltants."

#. TRANSLATORS: Helptext for a Frisian worker: Clay Digger
#: addons/europeans_all.wad/tribes/initialization/units.lua:2599 input:2599
#: standard
msgctxt "frisians_worker"
msgid "Makes clay out of mud and water."
msgstr "Fa argila amb fang i aigua."

#. TRANSLATORS: Helptext for an Amazon worker: Gold Digger
#: addons/europeans_all.wad/tribes/initialization/units.lua:2608 input:2608
#: standard
msgctxt "amazons_worker"
msgid ""
"Works hard in the gold dwellings in mountains to obtain gold by washing it "
"from gravel."
msgstr ""
"Treballa dur a les cases d'or de les muntanyes per obtenir or rentant-lo de "
"grava."

