#: input:4738 input:4751 input:4764 input:4777 standard
msgctxt "europeans_building"
msgid "Roads and trees along the shoreline block fishing."
msgstr "Els camins i els arbres al llarg de la costa bloqueja la pesca."

#. TRANSLATORS: Purpose helptext for a Europeans production site: Aqua Farm
#: addons/europeans_all.wad/tribes/initialization/units.lua:4785 input:4785
#: standard
msgctxt "europeans_building"
msgid "Breeds fish as food for soldiers and miners."
msgstr "Cria peixos com a aliment per a soldats i miners."

#. TRANSLATORS: Note helptext for a Europeans production site: Aqua Farm
#: addons/europeans_all.wad/tribes/initialization/units.lua:4787 input:4787
#: standard
msgctxt "europeans_building"
msgid ""
"The aqua farm needs holes in the ground that were dug by a clay pit’s worker "
"nearby to use as fishing ponds."
msgstr ""
"La granja aquàtica necessita forats al terra que van ser excavats per un "
"treballador d'un pou d'argila proper per utilitzar-los com a estanys de "
"pesca."

#. TRANSLATORS: Purpose helptext for a Europeans production site: Beekeeper's House
#: addons/europeans_all.wad/tribes/initialization/units.lua:4794 input:4794
#: standard
msgctxt "europeans_building"
msgid "Keeps bees and lets them swarm over flowering fields to produce honey."
msgstr "Cuida abelles i les condueix cap a camps de flors per obtenir-ne mel."

#. TRANSLATORS: Note helptext for a Europeans production site: Beekeeper's House
#: addons/europeans_all.wad/tribes/initialization/units.lua:4796 input:4796
#: standard
msgctxt "europeans_building"
msgid ""
"Needs medium-sized fields (barley, wheat, reed, corn or blackroot) or bushes "
"(berry bushes or grapevines) nearby."
msgstr ""
"Necessita camps de mida mitjana (ordi, blat, canya, blat de moro o arrel "
"negra) o arbustos (arbusts de baies o vinya) propers."

#. TRANSLATORS: Purpose helptext for a Europeans production site: Charcoal Burner's House
#: addons/europeans_all.wad/tribes/initialization/units.lua:4803 input:4803
#: standard
msgctxt "europeans_building"
msgid "Burns logs into charcoal."
msgstr "Crema troncs per fer-ne carbó vegetal."

#. TRANSLATORS: Note helptext for a Europeans production site: Charcoal Burner's House
#: addons/europeans_all.wad/tribes/initialization/units.lua:4805 input:4805
#: standard
msgctxt "europeans_building"
msgid ""
"The charcoal burner’s house needs holes in the ground that were dug by a "
"clay pit’s worker nearby to erect charcoal stacks in them."
msgstr ""
"La casa del carboner necessita forats al terra que van ser excavats per un "
"treballador d'un pou d'argila a prop per aixecar-hi piles de carbó."

#. TRANSLATORS: Purpose helptext for an Europeans production site: Gold Spinning Mill
#: addons/europeans_all.wad/tribes/initialization/units.lua:4812 input:4812
#: standard
msgctxt "europeans_building"
msgid "Spins gold thread out of gold."
msgstr "Gira fil d'or a partir d'or."

#. TRANSLATORS: Note helptext for an Europeans production site: Gold Spinning Mill
#: addons/europeans_all.wad/tribes/initialization/units.lua:4814 input:4814
#: standard
msgctxt "europeans_building"
msgid "Do not build until you have a steady gold supply."
msgstr "No construïu fins que tingueu un subministrament d'or constant."

