msgid "Works deep in the mines to obtain coal, iron, gold or granite."
msgstr ""
"Treballa en profunditat a les mines per obtenir carbó, ferro, or o granit."

#. TRANSLATORS: Helptext for an Atlantean worker: Miner
#: addons/europeans_all.wad/tribes/initialization/units.lua:2644 input:2644
#: standard
msgctxt "atlanteans_worker"
msgid "Works deep in the mines to obtain coal, iron, gold or precious stones."
msgstr ""
"Treballa en profunditat a les mines per obtenir carbó, ferro, or o pedres "
"precioses."

