#: addons/time-limitted-peaceful.wad/addon:6 input:6 standard
msgid ""
"The game is peaceful for 45 minutes.<br><br>(For a different time adapt the "
"constant in the code in 'init.lua'.)"
msgstr ""
"Dat Speel is 45 Menüten freedsaam.<br><br>(För eene anner Tied, pass de "
"Fasttahl in de Quelltext in »init.lua« an.)"

#: addons/time-limitted-peaceful.wad/addon:9 input:9 standard
msgid "Time limited peaceful mode"
msgstr "Tiedbegrenzt freedsaam Speel"

#: addons/time-limitted-peaceful.wad/init.lua:32 input:32 standard
msgid "Peaceful mode ends now"
msgstr "Freedsaam Speel ennt nu"

#: addons/time-limitted-peaceful.wad/init.lua:33 input:33 standard
msgid "All players can attack each other. (Team mates excluded of course.)"
msgstr ""
"All Spelers könen eenanner nu angriepen. (Bit up Klottjenfrünnen natürelk.)"

#: addons/time-limitted-peaceful.wad/init.lua:81 input:81 standard
msgid "win condition config"
msgstr "Instllens för Upgaav tum Winnen"

#: addons/time-limitted-peaceful.wad/init.lua:92 input:92 standard
msgid "Peaceful mode for ..."
msgstr "Freedsaam Speel för …"

#: addons/time-limitted-peaceful.wad/init.lua:93 input:93 standard
msgid "Duration of peaceful mode"
msgstr "Längde vun de freedsaam Speel"
