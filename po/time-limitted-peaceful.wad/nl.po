#: addons/time-limitted-peaceful.wad/addon:6 input:6 standard
msgid ""
"The game is peaceful for 45 minutes.<br><br>(For a different time adapt the "
"constant in the code in 'init.lua'.)"
msgstr ""
"Het spel verloopt 45 minuten lang rustig.<br><br>(Pas de constante in de "
"code in ‘init.lua’ aan als je een andere tijdsduur wilt.)"

#: addons/time-limitted-peaceful.wad/addon:9 input:9 standard
msgid "Time limited peaceful mode"
msgstr "Tijdgebonden vreedzame modus"

#: addons/time-limitted-peaceful.wad/init.lua:32 standard input:32
msgid "Peaceful mode ends now"
msgstr "Vreedzame modus eindigt nu"

#: addons/time-limitted-peaceful.wad/init.lua:33 standard input:33
msgid "All players can attack each other. (Team mates excluded of course.)"
msgstr ""
"Alle spelers kunnen elkaar aanvallen. (Teamgenoten uitgezonderd natuurlijk)."

#: addons/time-limitted-peaceful.wad/init.lua:81 standard input:81
msgid "win condition config"
msgstr "winvoorwaarde configuratie"

#: addons/time-limitted-peaceful.wad/init.lua:92 standard input:92
msgid "Peaceful mode for ..."
msgstr "Vredige modus voor ..."

#: addons/time-limitted-peaceful.wad/init.lua:93 standard input:93
msgid "Duration of peaceful mode"
msgstr "Duur van de vredige modus"
