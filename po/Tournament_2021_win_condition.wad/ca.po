#: addons/Tournament_2021_win_condition.wad/addon:4
#: addons/Tournament_2021_win_condition.wad/init.lua:32 input:9 input:32
#: standard
msgid "Tournament 2021 Win Condition"
msgstr "Condició de victòria del torneig del 2021"

#: addons/Tournament_2021_win_condition.wad/addon:5 input:6 standard
msgid ""
"Win Condition for the 2021 Tournament: Create 10 Heroes without any coal "
"from mountains"
msgstr ""
"Condició de victòria del torneig del 2021: Creeu 10 herois sense carbó de "
"les muntanyes."

#: addons/Tournament_2021_win_condition.wad/init.lua:35 input:35 standard
msgid ""
"The player who has at least %1% fully trained soldier in his warehouses wins "
"the game."
msgid_plural ""
"The player who has at least %1% fully trained soldiers in his warehouses "
"wins the game."
msgstr[0] ""
"El jugador que tingui al menys %1% soldat entrenat completament als seus "
"magatzems guanyarà la partida."
msgstr[1] ""
"El jugador que tingui almenys %1% soldats entrenats completament als seus "
"magatzems guanyarà la partida."

#: addons/Tournament_2021_win_condition.wad/init.lua:41 input:41 standard
msgid "Number of heroes"
msgstr "Nombre d'herois"

#: addons/Tournament_2021_win_condition.wad/init.lua:98 input:98 standard
msgid "Hero created!"
msgstr "S'ha creat un heroi!"

#: addons/Tournament_2021_win_condition.wad/init.lua:99 input:99 standard
msgid "%1% has created a hero!"
msgstr "%1% ha creat un heroi!"

#: addons/Tournament_2021_win_condition.wad/init.lua:101 input:101 standard
msgid "You have a new Hero!"
msgstr "Teniu un heroi nou!"

#: addons/Tournament_2021_win_condition.wad/init.lua:103 input:103 standard
msgid "Hero Statistics:"
msgstr "Estadístiques d'herois:"

#. TRANSLATORS: "Player x has y Heroes"
#: addons/Tournament_2021_win_condition.wad/init.lua:106 input:106 standard
msgid "%1% has %2%"
msgstr "%1% té %2%."

#: addons/Tournament_2021_win_condition.wad/init.lua:106 input:106 standard
msgid "%1% hero"
msgid_plural "%1% heroes"
msgstr[0] "%1% heroi"
msgstr[1] "%1% herois"

#. TRANSLATORS: This is an item in a list in the form "Player Name: 3 heroes"
#: addons/Tournament_2021_win_condition.wad/init.lua:119 input:119 standard
msgid "%1%: %2% hero"
msgid_plural "%1%: %2% heroes"
msgstr[0] "%1%: %2% heroi"
