msgid "Burns scrap_wood into charcoal."
msgstr "Verbrandt afvalhout tot houtskool."

#. TRANSLATORS: Purpose helptext for an Europeans production site: Charcoal Kiln
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:1687
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:1694 input:1687
#: input:1694 standard
msgctxt "europeans_building"
msgid "Burns scrap_wood or logs into charcoal."
msgstr "Verbrandt afvalhout of houtblokken tot houtskool."

#. TRANSLATORS: Purpose helptext for a Europeans production site: Lime Kiln
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:1701 input:1701
#: standard
msgctxt "europeans_building"
msgid ""
"Processes water and granite to make ‘grout’, a substance that solidifies and "
"so reinforces masonry."
msgstr ""
"Verwerkt water en graniet tot ‘voegmiddel’, een substantie die uithardt en "
"zo metselwerk versterkt."

#. TRANSLATORS: Note helptext for a Europeans production site: Lime Kiln
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:1703 input:1703
#: standard
msgctxt "europeans_building"
msgid "The lime kiln’s output will only go to construction sites that need it."
msgstr ""
"De opbrengst van de kalkoven gaat alleen naar bouwplaatsen die deze nodig "
"hebben."

#. TRANSLATORS: Purpose helptext for an Europeans production site: Brick Kiln
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:1710 input:1710
#: standard
msgctxt "europeans_building"
msgid ""
"Processes clay and granite to make bricks, a building material for advanced "
"buildings."
msgstr ""
"Verwerkt klei en graniet tot bakstenen, een bouwmateriaal voor geavanceerde "
"gebouwen."

#. TRANSLATORS: Note helptext for a Europeans production site: Brick Kiln
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:1712 input:1712
#: standard
msgctxt "europeans_building"
msgid ""
"The brick kiln’s output will only go to construction sites that need it."
msgstr ""
"De opbrengst van de steenoven gaat alleen naar bouwplaatsen die deze nodig "
"hebben."

#. TRANSLATORS: Purpose helptext for an Europeans production site: Stonemason's House
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:1719 input:1719
#: standard
msgctxt "europeans_building"
msgid ""
"Processes clay and granite to make bricks and ‘grout’. Additionally carves "
"marble columns out of marble."
msgstr ""
"Verwerkt klei en graniet tot bakstenen en ‘voegmiddel’. Daarnaast snijdt hij "
"marmeren zuilen uit marmer."

#. TRANSLATORS: Note helptext for a Europeans production site: Stonemason's House
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:1721 input:1721
#: standard
msgctxt "europeans_building"
msgid ""
"The stonemason’s house's output will only go to construction sites that need "
"it. Marble column only used by advanced buildings."
msgstr ""
"De opbrengst van het steenhouwershuis gaat alleen naar bouwplaatsen die het "
"nodig hebben. Marmeren zuilen worden alleen gebruikt in geavanceerde "
"gebouwen."

