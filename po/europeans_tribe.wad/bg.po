#. TRANSLATORS: Helptext for an Europeans ware: Water, part 1
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:95 input:95
#: standard
msgctxt "ware"
msgid "Water is the essence of life!"
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Water, part 2
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:97 input:97
#: standard
msgctxt "europeans_ware"
msgid ""
"Water is used by the gardener, by the forester, by all farms, and in the "
"bakery and the brewery. The fish farm and the sheep farm need to be supplied "
"with water, too."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Log, part 1
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:108 input:108
#: standard
msgctxt "europeans_ware"
msgid ""
"Logs are an important basic building material. They are produced by felling "
"trees."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Log, part 2
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:110 input:110
#: standard
msgctxt "europeans_ware"
msgid ""
"European lumberjacks fell the trees; foresters take care of the supply of "
"trees. Logs are also used by the charcoal kiln, the shipyard and the sawmill."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Planks, part 1
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:121 input:121
#: standard
msgctxt "europeans_ware"
msgid "Planks are an important building material."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Planks, part 2
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:123 input:123
#: standard
msgctxt "europeans_ware"
msgid "They are produced out of logs by the sawmill."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Planks, part 3
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:125 input:125
#: standard
msgctxt "europeans_ware"
msgid "They are also used by the ferryyard and shipyard."
msgstr ""

#. TRANSLATORS: Helptext for a Europeans ware: Blackwood
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:135 input:135
#: standard
msgctxt "europeans_ware"
msgid ""
"This fire-hardened wood is as hard as iron and it is used for several "
"buildings. It is produced out of logs in the wood hardener (basic sawmill)."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Balsa
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:145 input:145
#: standard
msgctxt "europeans_ware"
msgid ""
"Balsa wood is an important trade ware. Balsa trees are cut by an experienced "
"woodcutter."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Ironwood
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:156 input:156
#: standard
msgctxt "europeans_ware"
msgid ""
"This very hard wood is as hard as iron. It is cut by a very experienced "
"woodcutter."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Scrap wood, part 1
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:167 input:167
#: standard
msgctxt "europeans_ware"
msgid ""
"Scrap wood is a waste material that arises from the demolition of buildings "
"or from sawmills."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Scrap wood, part 2
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:169 input:169
#: standard
msgctxt "europeans_ware"
msgid "It can be processed into charcoal in charcoal kilns."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Reed, part 1
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:183 input:183
#: standard
msgctxt "europeans_ware"
msgid "Reed is an important building material."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Reed, part 2
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:185 input:185
#: standard
msgctxt "europeans_ware"
msgid "It is produced by the reed yard."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Cotton, part 1
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:196 input:196
#: standard
msgctxt "europeans_ware"
msgid "Cotton is a raw material used to make clothing."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Cotton, part 2
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:198 input:198
#: standard
msgctxt "europeans_ware"
msgid "It is produced by normal farms."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Cloth
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:208 input:208
#: standard
msgctxt "europeans_ware"
msgid "Cloth is needed to build several buildings. It is produced out of reed."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Rubber, part 1
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:218 input:218
#: standard
msgctxt "europeans_ware"
msgid "Rubber is needed to make improved armor and boots."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Rubber, part 2
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:220 input:220
#: standard
msgctxt "europeans_ware"
msgid "It is produced in tree nursery or in rubber farm."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Armor
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:230 input:230
#: standard
msgctxt "europeans_ware"
msgid ""
"Raw material for some sorts of armor. It is produced in the weaving mill out "
"of wool, cotton or reed."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Liana
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:240 input:240
#: standard
msgctxt "europeans_ware"
msgid "Lianas grow on trees. Very durable ropes are made out of them."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Rope
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:251 input:251
#: standard
msgctxt "europeans_ware"
msgid ""
"This rope is made out of lianas. It is used for armor dresses and to "
"construct buildings and ships."
msgstr ""

#. TRANSLATORS: Helptext for a Europeans ware: Honey
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:264 input:264
#: standard
msgctxt "europeans_ware"
msgid ""
"Honey is produced by bees belonging to a farm. It is used to feed animals."
msgstr ""

#. TRANSLATORS: Helptext for a Europeans ware: Fruit
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:273 input:273
#: standard
msgctxt "europeans_ware"
msgid ""
"Fruit are berries gathered from berry bushes by a fruit collector. They are "
"used to brew fruit wine."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Wool
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:282 input:282
#: standard
msgctxt "europeans_ware"
msgid ""
"The animal farm produces leather, which is used as a raw material for making "
"boots."
msgstr ""

#. TRANSLATORS: Helptext for a Europeans ware: Fur
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:291 input:291
#: standard
msgctxt "europeans_ware"
msgid ""
"Fur is won from reindeer in a reindeer farm. It is woven into cloth or "
"turned into fur garments for soldiers."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Wool
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:300 input:300
#: standard
msgctxt "europeans_ware"
msgid ""
"Wool is the hair of sheep. Weaving mills use it to make armor. Animal farms "
"with level 4 or 5 can produce wool."
msgstr ""

#. TRANSLATORS: Helptext for an Atlantean ware: Spider Silk
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:309 input:309
#: standard
msgctxt "atlanteans_ware"
msgid ""
"Spider silk is produced by spiders, which are bred by spider farms. It can "
"be processed into spidercloth or tabards in a weaving mill, or used to make "
"tools in the toolsmithy."
msgstr ""

#. TRANSLATORS: Helptext for an Atlantean ware: Spidercloth
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:318 input:318
#: standard
msgctxt "atlanteans_ware"
msgid ""
"Spidercloth is made out of spider silk in a weaving mill. It is used in the "
"shipyard. Also some higher developed buildings need spidercloth for their "
"construction."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Coal, part 1
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:331 input:331
#: standard
msgctxt "ware"
msgid "Coal is mined in coal mines or produced out of logs by a charcoal kiln."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Coal, part 2
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:333 input:333
#: standard
msgctxt "europeans_ware"
msgid ""
"The fires of the Europeans smelting works and smithies are usually fed with "
"coal."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Granite, part 1
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:344 input:344
#: standard
msgctxt "europeans_ware"
msgid "Granite is a basic building material."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Granite, part 2
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:346 input:346
#: standard
msgctxt "europeans_ware"
msgid "The Europeans produces granite blocks in quarries."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Granite, part 1
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:357 input:357
#: standard
msgctxt "europeans_ware"
msgid "Grout is a basic building material."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Granite, part 2
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:359 input:359
#: standard
msgctxt "europeans_ware"
msgid ""
"The Europeans produces grout in lime kiln or stonemasons house out of "
"granite and water."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Clay, part 1
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:370 input:370
#: standard
msgctxt "europeans_ware"
msgid "Clay is needed to make bricks."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Clay, part 2
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:372 input:372
#: standard
msgctxt "europeans_ware"
msgid "The Europeans gets clay from gardeners house."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Brick, part 1
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:383 input:383
#: standard
msgctxt "europeans_ware"
msgid "Brick is a basic building material."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Brick, part 2
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:385 input:385
#: standard
msgctxt "europeans_ware"
msgid ""
"The Europeans produces bricks in lime kiln or stonemasons house out of clay, "
"granite and water."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Marble
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:395 input:395
#: standard
msgctxt "europeans_ware"
msgid ""
"Marble is the beautiful stone which is cut out of the mountains or produced "
"in a quarry. Marble is used as a building material and gets chiseled into "
"marble columns in the stonemason’s house."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Marble Column
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:404 input:404
#: standard
msgctxt "europeans_ware"
msgid ""
"Marble columns represent the high culture of the Europeans, so they are "
"needed for nearly every advanced building. They are produced out of marble "
"at a stonemason’s house."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Iron Ore, part 1
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:417 input:417
#: standard
msgctxt "default_ware"
msgid "Ore is mined in ore mines."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Iron Ore, part 2
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:419 input:419
#: standard
msgctxt "europeans_ware"
msgid "It is smelted in a smelting works to retrieve all the metals."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Gold, part 1
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:430 input:430
#: standard
msgctxt "ware"
msgid "Gold is the most valuable of all metals, and it is smelted out of ore."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Gold, part 2
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:432 input:432
#: standard
msgctxt "europeans_ware"
msgid ""
"It is produced by the smelting works. Some valuable buildings need gold to "
"be built."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Copper Coin
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:443 input:443
#: standard
msgctxt "ware"
msgid ""
"Copper coins are money made of copper or bronze (copper and tin). Its the "
"standard barter object."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Silver Coin
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:454 input:454
#: standard
msgctxt "ware"
msgid "Silver coins are money made of silver. Its a valuable barter object."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Gold Coin
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:465 input:465
#: standard
msgctxt "ware"
msgid "Gold coins are money made of gold. Its most valuable barter object."
msgstr ""

#. TRANSLATORS: Helptext for an Europeans ware: Quartz
#: addons/europeans_tribe.wad/tribes/initialization/units.lua:475 input:475
#: standard
